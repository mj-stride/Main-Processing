@{
    ViewData["Title"] = "Generate Survey Reports";
    ViewData["Section"] = "Processing";
    Layout = "_Layout";
}

@section Styles {
    <style>
        /* Only scope the specific UI logic that shared.css doesn't cover */
        #loadingOverlay {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.75);
            backdrop-filter: blur(3px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }

            #loadingOverlay[aria-hidden="false"] {
                display: flex;
            }

        #logPanel {
            background-color: #0f172a;
            border-radius: 8px;
            height: 210px;
            overflow-y: auto;
            text-align: left;
            padding: 12px 14px;
            font-family: 'Courier New', Consolas, monospace;
            font-size: 11.5px;
            display: none;
            border: 1px solid #334155;
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.4);
        }

            #logPanel .l-default {
                color: #e2e8f0;
            }

            #logPanel .l-success {
                color: #4ade80;
                font-weight: 600;
            }

            #logPanel .l-warn {
                color: #f59e0b;
            }

            #logPanel .l-error {
                color: #f87171;
                font-weight: 700;
            }

            #logPanel .l-section {
                color: #38bdf8;
                font-weight: 700;
                margin-top: 4px;
            }

            #logPanel .l-debug {
                color: #64748b;
            }
    </style>
}

<div class="page-content">
    <div class="mx-auto w-100" style="max-width: 800px;">

        <div id="loadingOverlay" role="status" aria-hidden="true" aria-live="polite">
            <div class="premium-card p-4 p-md-5 text-center mb-0 bg-white" style="width: min(600px, 94vw);">
                <div class="spinner-border mb-3" role="status" style="color: var(--color-primary); width: 2.2rem; height: 2.2rem;"></div>
                <h5 class="fw-bold mb-1" style="color: var(--color-text-main);">Generating Reports…</h5>
                <p id="loadingMsg" class="small text-muted mb-3">Uploading files to compilation engine…</p>

                <div class="progress mb-1" style="height: 10px; border-radius: 999px; background-color: var(--color-border);">
                    <div id="progressBar" class="progress-bar" style="background: linear-gradient(90deg, var(--color-primary), #2f6db5); width: 0%; transition: width 0.4s ease;"></div>
                </div>
                <div id="progressLabel" class="small fw-bold mb-3 text-end" style="color: var(--color-primary); font-size: 0.8rem;">0%</div>

                <div id="logPanel" role="log" aria-label="Server processing log" class="mb-3"></div>

                <span class="small fw-medium text-danger" style="font-size: 0.8rem;">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i> Do not refresh or close this tab.
                </span>
            </div>
        </div>

        <header class="mb-4 d-flex align-items-center gap-3">
            <div class="rounded-3 d-flex align-items-center justify-content-center shadow-sm flex-shrink-0"
                 style="background-color: var(--color-accent); color: #ffffff; width: 60px; height: 60px;">
                <i class="bi bi-file-earmark-bar-graph-fill" style="font-size: 2.2rem;"></i>
            </div>
            <div>
                <h1 class="h3 fw-bold mb-0" style="color: var(--color-text-main);">@ViewData["Title"]</h1>
                <p class="text-muted mb-0" style="font-size: 0.95rem;">Upload complete Region folders or ZIP packages to build executive DOCX annexes</p>
            </div>
        </header>

        <section class="premium-card mb-4 bg-white">
            <h5 class="fw-bold mb-4" style="color: var(--color-primary);">Select Survey Architecture</h5>

            <input type="file" id="folderInput" webkitdirectory directory multiple class="d-none" />
            <input type="file" id="zipInput" accept=".zip" multiple class="d-none" />

            <div id="dropZone" tabindex="0" role="button" class="drop-zone mb-3">
                <div class="d-flex gap-3 justify-content-center align-items-center mb-1">
                    <i class="bi bi-folder-fill"></i>
                    <span class="small fw-medium text-muted fs-6">or</span>
                    <i class="bi bi-file-earmark-zip-fill"></i>
                </div>
                <p>Drag &amp; drop your master <strong>Region</strong> folder or ZIP archive here</p>

                <div class="d-flex justify-content-center gap-2 my-1">
                    <button type="button" class="btn btn-sm btn-action m-0" onclick="document.getElementById('folderInput').click()">
                        Browse Folder
                    </button>
                    <button type="button" class="btn btn-sm btn-action m-0" onclick="document.getElementById('zipInput').click()">
                        Browse ZIP
                    </button>
                </div>

                <span class="drop-zone-subtext mt-1">
                    Required: <code class="bg-light px-1 rounded border">Region / RoadName / SurveyDate / VehicleType / SegmentAnalysis</code>
                </span>
            </div>

            <div id="fileLabel" aria-live="polite"></div>

            <div id="uploadError" class="alert alert-danger mt-3 py-2 text-center small fw-semibold" style="display: none;">
                <i class="bi bi-exclamation-triangle-fill me-1"></i> Please select a valid Region folder or ZIP package.
            </div>

            <div class="d-flex justify-content-center mt-4">
                <button id="btnGenerate" class="btn-ttds w-auto px-5" onclick="startGeneration()">
                    <i class="bi bi-cpu-fill me-2"></i> Compile Executive Reports
                </button>
            </div>

            <div id="serverError" class="alert alert-danger mt-3 small fw-medium text-pre-wrap" style="display: none;"></div>
        </section>
    </div>
</div>
@section Scripts {
    <script>
        (function () {
            let selectedFiles = []; // [{ file, relativePath }]

            const dropZone     = document.getElementById('dropZone');
            const folderInput  = document.getElementById('folderInput');
            const zipInput     = document.getElementById('zipInput');
            const overlay      = document.getElementById('loadingOverlay');
            const progressBar  = document.getElementById('progressBar');
            const progressLabel = document.getElementById('progressLabel');
            const loadingMsg   = document.getElementById('loadingMsg');
            const logPanel     = document.getElementById('logPanel');
            const serverError  = document.getElementById('serverError');

            let lastLogCount   = 0;
            let pollTimer      = null;

            // 1. Mandatory UI Scrubber on BFCache Page Restore
            window.addEventListener('pageshow', function () {
                if (folderInput) folderInput.value = '';
                if (zipInput) zipInput.value = '';
                selectedFiles = [];
                const label = document.getElementById('fileLabel');
                if (label) label.innerHTML = '';
                if (overlay) {
                    overlay.style.display = 'none';
                    overlay.setAttribute('aria-hidden', 'true');
                }
                const btn = document.getElementById('btnGenerate');
                if (btn) btn.disabled = false;
                if (pollTimer) clearInterval(pollTimer);
            });

            // Folder Browse Listener
            folderInput.addEventListener('change', () => {
                zipInput.value = "";
                selectedFiles = Array.from(folderInput.files).map(f => ({
                    file: f, relativePath: f.webkitRelativePath || f.name
                }));
                renderSummary();
            });

            // ZIP Browse Listener (Fixed JS typo)
            zipInput.addEventListener('change', () => {
                folderInput.value = "";
                selectedFiles = Array.from(zipInput.files).map(f => ({
                    file: f, relativePath: f.name
                }));
                renderSummary();
            });

            // Recursive File Walk for Drag & Drop
            function readEntryAsFile(entry) { return new Promise(res => entry.file(f => res(f), () => res(null))); }
            function readAllEntries(reader) {
                return new Promise(res => {
                    let all = [];
                    (function batch() {
                        reader.readEntries(entries => {
                            if (!entries.length) { res(all); return; }
                            all = all.concat(entries); batch();
                        }, () => res(all));
                    })();
                });
            }
            async function traverseEntry(entry, path) {
                if (entry.isFile) {
                    const f = await readEntryAsFile(entry);
                    return f ? [{ file: f, relativePath: path + entry.name }] : [];
                }
                if (entry.isDirectory) {
                    const children = await readAllEntries(entry.createReader());
                    const results  = await Promise.all(children.map(c => traverseEntry(c, path + entry.name + '/')));
                    return results.flat();
                }
                return [];
            }

            if (dropZone) {
                ['dragenter','dragover'].forEach(ev => dropZone.addEventListener(ev, e => {
                    e.preventDefault();
                    dropZone.style.borderColor = 'var(--color-primary)';
                    dropZone.style.backgroundColor = '#e2e8f0';
                }));
                ['dragleave','dragend'].forEach(ev => dropZone.addEventListener(ev, () => {
                    dropZone.style.borderColor = 'var(--color-border)';
                    dropZone.style.backgroundColor = 'var(--color-bg)';
                }));

                dropZone.addEventListener('drop', async e => {
                    e.preventDefault();
                    dropZone.style.borderColor = 'var(--color-border)';
                    dropZone.style.backgroundColor = 'var(--color-bg)';

                    if(folderInput) folderInput.value = "";
                    if(zipInput) zipInput.value = "";

                    const items = e.dataTransfer?.items;
                    if (items?.length && items[0].webkitGetAsEntry) {
                        const entries = Array.from(items).map(i => i.webkitGetAsEntry()).filter(Boolean);
                        const results = await Promise.all(entries.map(en => traverseEntry(en, '')));
                        selectedFiles = results.flat();
                    } else if (e.dataTransfer?.files?.length) {
                        selectedFiles = Array.from(e.dataTransfer.files).map(f => ({
                            file: f, relativePath: f.webkitRelativePath || f.name
                        }));
                    }
                    renderSummary();
                });
            }

            function detectSurveys(entries) {
                const seen = new Map();
                entries.forEach(({ relativePath }) => {
                    const idx = relativePath.indexOf('/SegmentAnalysis');
                    if (idx === -1) return;
                    const seg = relativePath.substring(0, idx + '/SegmentAnalysis'.length);
                    if (seen.has(seg)) return;
                    const parts = seg.split('/').filter(Boolean);
                    const i = parts.lastIndexOf('SegmentAnalysis');
                    if (i >= 4) seen.set(seg, {
                        region: parts[i-4], roadName: parts[i-3], surveyDate: parts[i-2], vehicleType: parts[i-1]
                    });
                });
                return Array.from(seen.values());
            }

            function fmtBytes(b) {
                if (b < 1024) return b + ' B';
                if (b < 1048576) return (b/1024).toFixed(1) + ' KB';
                return (b/1048576).toFixed(1) + ' MB';
            }

            function getVehicleIcon(type) {
                const t = type.toLowerCase();
                if (t.includes('car')) return 'bi-car-front-fill';
                if (t.includes('bus')) return 'bi-bus-front-fill';
                if (t.includes('uv'))  return 'bi-taxi-front-fill';
                return 'bi-car-front-fill';
            }

            function renderSummary() {
                const label = document.getElementById('fileLabel');
                const err = document.getElementById('uploadError');
                if (!label) return;
                if (!selectedFiles.length) { label.innerHTML = ''; return; }
                if (err) err.style.display = 'none';

                const total = selectedFiles.reduce((s, e) => s + (e.file.size || 0), 0);
                const zips = selectedFiles.filter(f => f.file.name.toLowerCase().endsWith('.zip'));
                const folders = selectedFiles.filter(f => !f.file.name.toLowerCase().endsWith('.zip'));
                const surveys = detectSurveys(folders);

                let html = `
                    <div class="mt-4">
                        <div class="d-flex align-items-center justify-content-between p-2 px-3 rounded-2 mb-2 bg-light border">
                            <span class="small fw-bold" style="color: var(--color-primary);">
                                <i class="bi bi-folder2-open me-1"></i> ${selectedFiles.length} binary file(s) staged
                            </span>
                            <span class="badge bg-white text-dark border">${fmtBytes(total)}</span>
                        </div>`;

                if (zips.length > 0) {
                    html += `
                        <div class="p-2 px-3 rounded-2 mb-2 border" style="background-color: #eff6ff; border-color: #bfdbfe !important;">
                            <span class="small fw-bold" style="color: #1d4ed8;">
                                <i class="bi bi-file-earmark-zip-fill me-1"></i> ${zips.length} master ZIP archive(s) staged for extraction
                            </span>
                        </div>`;
                }

                if (surveys.length > 0) {
                    const items = surveys.map(s => `
                        <div class="d-flex align-items-center justify-content-between p-2 px-3 rounded-2 mb-1 border bg-white">
                            <div class="d-flex align-items-center gap-2 text-truncate me-2">
                                <i class="bi ${getVehicleIcon(s.vehicleType)}" style="color: var(--color-accent);"></i>
                                <span class="small fw-bold text-dark text-truncate">${s.region} <span class="text-muted fw-normal">/</span> ${s.roadName} <span class="text-muted fw-normal">/</span> ${s.surveyDate}</span>
                            </div>
                            <span class="badge border fw-semibold text-secondary flex-shrink-0" style="background-color: var(--color-bg); font-size:0.75rem;">${s.vehicleType}</span>
                        </div>`).join('');

                    html += `
                        <p class="small fw-bold mb-2 mt-3" style="color: #15803d;">
                            <i class="bi bi-check2-circle me-1"></i> ${surveys.length} survey hierarchy(s) validated:
                        </p>
                        <div style="max-height: 220px; overflow-y: auto; padding-right: 4px;">${items}</div>`;
                } else if (zips.length === 0) {
                    html += `
                        <div class="alert alert-warning py-2 small fw-medium mb-0 text-center">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i> No valid <code>/SegmentAnalysis</code> sub-folders detected.
                        </div>`;
                }

                label.innerHTML = html + `</div>`;
            }

            function setProgress(pct, msg) {
                pct = Math.min(100, Math.max(0, Math.round(pct)));
                if(progressBar) progressBar.style.width = pct + '%';
                if(progressLabel) progressLabel.textContent = pct + '%';
                if (msg && loadingMsg) loadingMsg.textContent = msg;
            }

            const MILESTONES = [
                [/Reading CSV files/i,              35], [/Calculating Directional/i,        45],
                [/Calculating Segment/i,            52], [/Saved Directional Averages/i,     58],
                [/Trip LineString created/i,        64], [/Saved Survey Map/i,               72],
                [/Generating DOCX Report/i,         80], [/Saved Survey Report/i,            88],
                [/Generating ANNEX/i,               92], [/Saved Survey Annex/i,             96],
                [/All reports bundled/i,            99]
            ];

            function logsToProgress(logs) {
                let max = 32;
                for (const line of logs) for (const [re, pct] of MILESTONES) if (re.test(line)) max = Math.max(max, pct);
                return max;
            }

            function lineClass(line) {
                if (/✅/.test(line)) return 'l-success';
                if (/⚠️|SKIPPED/i.test(line)) return 'l-warn';
                if (/❌|fail|error/i.test(line)) return 'l-error';
                if (/^▶/.test(line)) return 'l-section';
                if (/^\s*(->|\[TRIP\]|\[CP\]|\[GIS\])/.test(line)) return 'l-debug';
                return 'l-default';
            }

            function appendLogs(newLines) {
                if(!logPanel) return;
                newLines.forEach(line => {
                    const el = document.createElement('div'); el.className = lineClass(line); el.textContent = line;
                    logPanel.appendChild(el);
                });
                logPanel.scrollTop = logPanel.scrollHeight;
            }

            function uploadFiles() {
                return new Promise((resolve, reject) => {
                    const fd = new FormData();
                    selectedFiles.forEach(({ file, relativePath }) => fd.append('files', file, relativePath));

                    const xhr = new XMLHttpRequest();
                    xhr.upload.addEventListener('progress', e => {
                        if (e.lengthComputable) setProgress((e.loaded / e.total) * 28, `Uploading binaries… ${fmtBytes(e.loaded)} / ${fmtBytes(e.total)}`);
                    });

                    xhr.addEventListener('load', () => {
                        if (xhr.status === 200) {
                            try { resolve(JSON.parse(xhr.responseText).jobId); }
                            catch(err) { reject(new Error("Failed to parse server response token.")); }
                        } else reject(new Error(xhr.responseText || `HTTP Error ${xhr.status}`));
                    });

                    xhr.addEventListener('error', () => reject(new Error('Network drop — verify the compilation API is reachable.')));
                    xhr.open('POST', '/api/Report/submit'); xhr.send(fd);
                });
            }

            async function pollStatus(jobId) {
                try {
                    const res = await fetch(`/api/Report/status/${jobId}`);
                    if (!res.ok) throw new Error(`Status check failed: ${res.status}`);
                    return await res.json();
                } catch (e) { return { state: 'Running', logs: [], error: null }; }
            }

            function startPolling(jobId) {
                setProgress(30, 'Initializing compilation engine…');
                if(logPanel) { logPanel.style.display = 'block'; logPanel.innerHTML = ''; }
                lastLogCount = 0;

                pollTimer = setInterval(async () => {
                    const status = await pollStatus(jobId);

                    if (status.logs && status.logs.length > lastLogCount) {
                        appendLogs(status.logs.slice(lastLogCount));
                        lastLogCount = status.logs.length;
                        setProgress(logsToProgress(status.logs));
                    }

                    if (status.state === 'Done') {
                        clearInterval(pollTimer);
                        setProgress(100, '✅ Annex compilation finished. Dispatching master ZIP…');
                        setTimeout(() => triggerDownload(jobId), 500);
                    } else if (status.state === 'Failed') {
                        clearInterval(pollTimer); setProgress(0);
                        if(overlay) { overlay.style.display = 'none'; overlay.setAttribute('aria-hidden', 'true'); }
                        showError(`Engine execution halted:\n${status.error || 'Check backend terminal for stack trace.'}`);
                        const btn = document.getElementById('btnGenerate'); if(btn) btn.disabled = false;
                    }
                }, 1500);
            }

            function triggerDownload(jobId) {
                const a = document.createElement('a'); a.href = `/api/Report/download/${jobId}`; a.style.display = 'none';
                document.body.appendChild(a); a.click(); document.body.removeChild(a);

                setTimeout(() => {
                    if(overlay) { overlay.style.display = 'none'; overlay.setAttribute('aria-hidden', 'true'); }
                    const btn = document.getElementById('btnGenerate'); if(btn) btn.disabled = false;
                }, 1500);
            }

            window.startGeneration = async function () {
                const err = document.getElementById('uploadError'); const btn = document.getElementById('btnGenerate');
                if (!selectedFiles.length) { if (err) err.style.display = 'block'; return; }

                if (err) err.style.display = 'none';
                if(serverError) serverError.style.display = 'none';

                if(btn) btn.disabled = true;
                if(overlay) { overlay.setAttribute('aria-hidden', 'false'); overlay.style.display = 'flex'; }
                if(logPanel) logPanel.style.display = 'none';
                setProgress(0, 'Packaging local binaries…');

                try { const jobId = await uploadFiles(); startPolling(jobId); }
                catch (e) {
                    if(overlay) { overlay.style.display = 'none'; overlay.setAttribute('aria-hidden', 'true'); }
                    showError(e.message); if(btn) btn.disabled = false;
                }
            };

            function showError(msg) {
                if(!serverError) return;
                serverError.textContent = msg; serverError.style.display = 'block';
            }
        })();
    </script>
}