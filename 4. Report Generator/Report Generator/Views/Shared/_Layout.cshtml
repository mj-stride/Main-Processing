<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Report Generator</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        body {
            background: #f4f6f8;
            color: #1f2937;
        }

        .app-nav {
            background: #211d71;
            color: #fff;
            padding: 0.85rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .app-nav .brand {
            font-weight: 700;
            font-size: 1.1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .app-nav .section-badge {
            background: rgba(255,255,255,0.15);
            border-radius: 999px;
            padding: 4px 14px;
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 0.3px;
        }

        .page-wrapper {
            max-width: 900px;
            margin: 2rem auto;
            padding: 0 1rem 3rem;
        }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>
    <nav class="app-nav">
        <span class="brand">
            Report Generator
        </span>
        @if (ViewData["Section"] != null)
        {
            <span class="section-badge">@ViewData["Section"]</span>
        }
    </nav>

    @RenderBody()

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
