@{
    ViewData["Title"] = "GPX Clean – Public Utility Vehicle";
    ViewData["Section"] = "Clean and Snap (PUV)";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<style>
    #loadingOverlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.55);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }

    #loadingCard {
        width: min(520px, 92vw);
        background: #fff;
        border-radius: 12px;
        padding: 18px 18px 14px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.25);
        border: 1px solid #e5e5e5;
    }

    #loadingTitle {
        font-weight: 600;
        margin-bottom: 8px;
        font-size: 1.05rem;
    }

    #loadingMsg {
        font-size: 0.92rem;
        color: #555;
        margin-bottom: 12px;
    }

    .progress {
        height: 12px;
        border-radius: 999px;
        overflow: hidden;
        background: #e9ecef;
    }

    .progress-bar {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, #1d4470, #2f6db5);
        transition: width 0.35s ease;
    }

    /* Upload card */
    .upload-card {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid #ccc;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        padding: 1.5rem;
    }

        .upload-card h5 {
            font-weight: 700;
            font-size: 1rem;
            margin-bottom: 1rem;
        }

    /* Dashed drop zone */
    .drop-zone {
        border: 2px dashed #aab4c4;
        border-radius: 12px;
        background: #e8ecf0;
        padding: 2.5rem 1rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        cursor: pointer;
        transition: background 0.15s;
    }

        .drop-zone:hover {
            background: #dde3ea;
        }

        .drop-zone i {
            font-size: 3rem;
            color: #da471f;
        }

        .drop-zone p {
            font-size: 0.88rem;
            color: #555;
            margin: 0;
            text-align: center;
        }

    /* Hidden real input */
    #zipFiles {
        display: none;
    }

    /* Pill button — reused from Index */
    .btn-ttds {
        background: #1d4470;
        color: #eeeeee;
        border: none;
        border-radius: 999px;
        font-size: 0.88rem;
        font-weight: 600;
        padding: 10px 36px;
        transition: background 0.18s, transform 0.1s;
    }

        .btn-ttds:hover {
            background: #245490;
            color: #eeeeee;
            transform: translateY(-1px);
        }

        .btn-ttds:active {
            transform: translateY(0);
        }

        .btn-ttds:disabled {
            background: #5a7fa8;
            color: #ccc;
        }

    /* File list */
    .file-list-header {
        font-size: 0.82rem;
        font-weight: 700;
        color: #1d4470;
        margin-bottom: 0.5rem;
    }

    .file-list-scroll {
        max-height: 220px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .file-list-scroll::-webkit-scrollbar {
            width: 6px;
        }

        .file-list-scroll::-webkit-scrollbar-track {
            background: #f0f0f0;
            border-radius: 999px;
        }

        .file-list-scroll::-webkit-scrollbar-thumb {
            background: #aab4c4;
            border-radius: 999px;
        }

    .file-item {
        display: flex;
        align-items: center;
        gap: 10px;
        background: #f0f4f8;
        border: 1px solid #d0d8e4;
        border-radius: 8px;
        padding: 8px 12px;
    }

        .file-item i {
            color: #da471f;
            font-size: 1.1rem;
            flex-shrink: 0;
        }

    .file-item-name {
        font-size: 0.82rem;
        color: #333;
        word-break: break-all;
        flex: 1;
    }

    .file-item-size {
        font-size: 0.75rem;
        color: #888;
        flex-shrink: 0;
    }
</style>

<!-- LOADING OVERLAY -->
<div id="loadingOverlay">
    <div id="loadingCard">
        <div id="loadingTitle">Preparing preview…</div>
        <div id="loadingMsg">Uploading ZIP(s) and extracting GPX points. Please wait.</div>
        <div class="progress">
            <div id="progressBar" class="progress-bar"></div>
        </div>
        <div class="small text-muted mt-2">Don't refresh or go back while processing.</div>
    </div>
</div>

<!-- Page heading -->
<div class="mb-4 d-flex align-items-center gap-3">
    <i class="bi bi-bus-front-fill" style="font-size: 2.8rem;"></i>
    <h1 class="fw-bold mb-0" style="font-size: 2rem;">GPX Clean – Public Utility Vehicle</h1>
</div>

<!-- Upload card -->
<div class="upload-card">
    <h5>Upload GPX Files</h5>

    <form id="uploadForm"
          method="post"
          action="/gpx/preview-map"
          enctype="multipart/form-data"
          onsubmit="return startUpload();">

        @Html.AntiForgeryToken()

        <input type="file"
               name="files"
               id="zipFiles"
               multiple
               accept=".zip"
               onchange="updateFileLabel(this)" />

        <!-- Dashed drop zone -->
        <div class="drop-zone" onclick="document.getElementById('zipFiles').click()">
            <i class="bi bi-map"></i>
            <p>Drag and drop or browse for .zip files containing .gpx files.</p>
        </div>

        <!-- File list -->
        <div id="fileLabel"></div>
        <p id="uploadError" style="display:none; font-size:0.82rem; color:#c0392b; text-align:center; margin-top:0.5rem;">
            <i class="bi bi-exclamation-circle me-1"></i>Please select at least one .zip file before continuing.
        </p>

        <div class="d-flex justify-content-center mt-4">
            <button id="btnPreview" type="submit" class="btn-ttds">
                Preview on Map
            </button>
        </div>

    </form>
</div>

<script>
    let fakeProgressTimer = null;

    function updateFileLabel(input) {
        const label = document.getElementById('fileLabel');
        if (!label) return;

        if (input.files && input.files.length > 0) {
            const err = document.getElementById('uploadError');
            if (err) err.style.display = 'none';
            const files = Array.from(input.files);
            const items = files.map(f => {
                const kb = (f.size / 1024).toFixed(1);
                return `
                    <div class="file-item">
                        <i class="bi bi-file-zip"></i>
                        <span class="file-item-name">${f.name}</span>
                        <span class="file-item-size">${kb} KB</span>
                    </div>
                `;
            }).join('');

            label.innerHTML = `
                <div style="margin-top: 1rem;">
                    <p class="file-list-header">
                        <i class="bi bi-folder2-open me-1"></i>
                        ${files.length} file${files.length > 1 ? 's' : ''} selected
                    </p>
                    <div class="file-list-scroll">${items}</div>
                </div>
            `;
        } else {
            label.innerHTML = '';
        }
    }

    function startFakeProgress() {
        const bar = document.getElementById("progressBar");
        if (!bar) return;
        bar.style.width = "0%";
        let progress = 0;
        if (fakeProgressTimer) clearInterval(fakeProgressTimer);
        fakeProgressTimer = setInterval(() => {
            if (progress < 60)      progress += (Math.random() * 10) + 6;
            else if (progress < 85) progress += (Math.random() * 6) + 2;
            else if (progress < 95) progress += (Math.random() * 2) + 0.5;
            else                    progress = 10;
            bar.style.width = Math.min(progress, 95).toFixed(0) + "%";
        }, 350);
    }

        function startUpload() {
        const overlay   = document.getElementById("loadingOverlay");
        const fileInput = document.getElementById("zipFiles");
        const btn       = document.getElementById("btnPreview");
        const err       = document.getElementById("uploadError");

        if (!fileInput || !fileInput.files || fileInput.files.length === 0) {
            if (err) {
                err.style.display = 'block';
            }
            return false;
        }

        if (err) err.style.display = 'none';
        overlay.style.display = "flex";
        if (btn) btn.disabled = true;
        overlay.getBoundingClientRect();
        startFakeProgress();
        return true;
    }

    // Drag-and-drop support
    document.addEventListener('DOMContentLoaded', () => {
        const zone  = document.querySelector('.drop-zone');
        const input = document.getElementById('zipFiles');
        if (!zone || !input) return;

        zone.addEventListener('dragover', e => {
            e.preventDefault();
            zone.style.background = '#d0d8e2';
        });
        zone.addEventListener('dragleave', () => {
            zone.style.background = '#e8ecf0';
        });
        zone.addEventListener('drop', e => {
            e.preventDefault();
            zone.style.background = '#e8ecf0';
            input.files = e.dataTransfer.files;
            updateFileLabel(input);
        });
    });
</script>