@model List<Travel_Time_and_Delay_Web_Application.Models.GpxRecord>
@using System.Linq
@using System.Text.Json

@{
    ViewData["Title"] = "GPX Results Preview";

    var fileGroups = Model
        .GroupBy(r => r.FilePath)
        .OrderBy(g => g.Key)
        .ToList();
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container py-4">
    <h1 class="mb-1">Preview of GPX Data</h1>
    <p class="text-muted mb-4">Showing first @Model.Count rows</p>

    <!-- SPEED CHART -->
    <div class="card mb-4">
        <div class="card-body">
            <canvas id="speedChart" height="80"></canvas>
        </div>
    </div>

    <!-- TABLE PREVIEW -->
    <div class="card mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Group</th>
                            <th>Timestamp</th>
                            <th>Lat</th>
                            <th>Lon</th>
                            <th>Speed</th>
                            <th>File</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td>@r.Group</td>
                                <td>@r.Timestamp?.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>@r.SnappedLat</td>
                                <td>@r.SnappedLon</td>
                                <td>@r.Speed</td>
                                <td class="text-break">@r.FilePath</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- FILES + MAP -->
    <div class="row g-4">

        <!-- LEFT: FILE SELECTION -->
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">

                    <h5 class="card-title">Files</h5>

                    <form id="selectedFilesForm"
                          method="post"
                          class="d-flex flex-column gap-2">

                        @Html.AntiForgeryToken()

                        <!-- REQUIRED -->
                        <input type="hidden" name="batchId" value="@ViewBag.BatchId" />

                        <!-- container for dynamic selectedFiles[] -->
                        <div id="selectedFilesContainer"></div>

                        <div class="border rounded p-2" style="max-height:65vh; overflow:auto;">
                            @foreach (var grp in fileGroups)
                            {
                                var chkId = "chk_" + Guid.NewGuid().ToString("N");

                                <div class="form-check mb-2">
                                    <input class="form-check-input file-checkbox"
                                           type="checkbox"
                                           id="@chkId"
                                           data-file="@grp.Key"
                                           checked />

                                    <label class="form-check-label text-break" for="@chkId">
                                        @grp.Key
                                        <small class="text-muted">(@grp.Count() pts)</small>
                                    </label>
                                </div>
                            }
                        </div>

                        <!-- ACTION BUTTONS -->
                        <button type="submit"
                                formaction="/gpx/cleaned-only-view"
                                class="btn btn-primary">
                            View Cleaned Only
                        </button>

                        <button type="submit"
                                formaction="/gpx/process-selected"
                                class="btn btn-success">
                            Download CSV ZIP
                        </button>

                        <a href="/gpx/upload" class="btn btn-outline-secondary">
                            Back
                        </a>

                    </form>
                </div>
            </div>
        </div>

        <!-- RIGHT: MAP -->
        <div class="col-md-9">
            <div class="card h-100">
                <div class="card-body">
                    <div id="map"
                         style="height:65vh; border-radius:8px; border:1px solid #dee2e6;">
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- =======================
     CHART.JS
     ======================= -->
<script>
    (function () {
        const labels = @Html.Raw(JsonSerializer.Serialize(
                        Model.Select(r => r.Timestamp?.ToString("HH:mm:ss"))
                ));

        const speeds = @Html.Raw(JsonSerializer.Serialize(
                        Model.Select(r => r.Speed)
                ));

        new Chart(document.getElementById('speedChart'), {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Speed',
                    data: speeds,
                    borderWidth: 2,
                    pointRadius: 0,
                    tension: 0.25
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    x: { ticks: { maxTicksLimit: 10 } },
                    y: { beginAtZero: true }
                }
            }
        });
    })();
</script>

<!-- =======================
     LEAFLET
     ======================= -->
<link rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
    const map = L.map('map').setView([12.8797, 121.7740], 5);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 20
    }).addTo(map);

    const previewData = @Html.Raw(JsonSerializer.Serialize(Model));

    function updateMap() {
        map.eachLayer(l => {
            if (!(l instanceof L.TileLayer)) map.removeLayer(l);
        });

        const selectedFiles = Array
            .from(document.querySelectorAll('.file-checkbox:checked'))
            .map(cb => cb.dataset.file);

        const markers = [];

        previewData
            .filter(r => selectedFiles.includes(r.FilePath))
            .forEach(r => {
                if (r.SnappedLat && r.SnappedLon) {
                    const m = L.circleMarker(
                        [r.SnappedLat, r.SnappedLon],
                        { radius: 3 }
                    ).addTo(map);
                    markers.push(m);
                }
            });

        if (markers.length) {
            map.fitBounds(L.featureGroup(markers).getBounds().pad(0.2));
        }
    }

    document
        .querySelectorAll('.file-checkbox')
        .forEach(cb => cb.addEventListener('change', updateMap));

    updateMap();

    /* ============
       FORM SUBMIT
       ============ */
    const form = document.getElementById("selectedFilesForm");
    const container = document.getElementById("selectedFilesContainer");

    form.addEventListener("submit", function () {
        container.innerHTML = "";

        document
            .querySelectorAll(".file-checkbox:checked")
            .forEach(cb => {
                const inp = document.createElement("input");
                inp.type = "hidden";
                inp.name = "selectedFiles";
                inp.value = cb.dataset.file;
                container.appendChild(inp);
            });
    });
</script>
