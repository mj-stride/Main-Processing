@model Travel_Time_and_Delay_Web_Application.Models.GpxCleanedOnlyVm
@using System.Text.Json

@{
    ViewData["Title"] = "Cleaned Trips Only";
    ViewData["Section"] = "Clean and Snap (PUV)";
    var tripCount = Model.Trips?.Count ?? 0;
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
    /* Viewport-filling flex wrapper */
    .preview-view-wrapper {
        display: flex;
        flex-direction: column;
        flex: 1;
        gap: 1.25rem;
        min-height: 0;
    }

    .preview-body-grid {
        display: flex;
        gap: 1.5rem;
        flex: 1;
        min-height: 0;
    }

    /* LEFT PANEL: The Scrollable Container */
    .panel-left {
        width: 350px;
        flex-shrink: 0;
        background: var(--color-surface);
        border-radius: 12px;
        border: 1px solid var(--color-border);
        box-shadow: var(--shadow-sm);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        max-height: calc(100vh - 130px);
    }

    .panel-left-header {
        padding: 1rem 1.25rem 0.75rem;
        font-weight: 700;
        font-size: 0.95rem;
        color: var(--color-primary);
        border-bottom: 1px solid var(--color-border);
        background-color: var(--color-surface);
    }

    .trip-list-scroll {
        flex: 1 1 auto;
        overflow-y: auto;
        min-height: 0; /* Crucial for scrollability */
        padding: 0.75rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .trip-list-scroll::-webkit-scrollbar {
            width: 6px;
        }

        .trip-list-scroll::-webkit-scrollbar-track {
            background: var(--color-bg);
        }

        .trip-list-scroll::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 999px;
        }

    /* Selection Controls */
    .selection-controls {
        display: flex;
        gap: 6px;
        padding: 0.75rem 1rem;
        flex-shrink: 0;
        border-bottom: 1px solid var(--color-border);
        background: var(--color-surface);
    }

    .btn-sel {
        font-size: 0.72rem;
        font-weight: 600;
        border-radius: 999px;
        padding: 4px 12px;
        border: 1px solid var(--color-border);
        background: var(--color-surface);
        color: var(--color-text-main);
        cursor: pointer;
        transition: all 0.15s ease;
    }

        .btn-sel:hover {
            background: var(--color-bg);
            border-color: var(--color-primary);
        }

        .btn-sel.warning {
            color: #b45309;
            border-color: #fcd34d;
            background: #fffbeb;
        }

    /* Trip Row */
    .trip-row {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        background: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        padding: 8px 10px;
        cursor: pointer;
        transition: all 0.15s ease;
    }

        .trip-row:hover {
            background: #f1f5f9;
            border-color: #cbd5e1;
        }

        .trip-row input[type="checkbox"] {
            accent-color: var(--color-primary);
            margin-top: 3px;
            cursor: pointer;
        }

    .trip-row-title {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--color-primary);
    }

    .trip-row-meta {
        font-size: 0.7rem;
        color: var(--color-text-muted);
    }

    .trip-row-zip {
        font-size: 0.7rem;
        color: #94a3b8;
    }

    /* RIGHT PANEL */
    .panel-right {
        flex: 1;
        min-width: 0;
        background: var(--color-surface);
        border-radius: 12px;
        border: 1px solid var(--color-border);
        box-shadow: var(--shadow-sm);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    #map {
        flex: 1;
        min-height: 0;
        width: 100%;
        background: #e5e7eb;
    }

    .map-footer {
        padding: 0.75rem 1.25rem;
        font-size: 0.82rem;
        color: var(--color-text-muted);
        border-top: 1px solid var(--color-border);
    }

    /* Action styling */
    .panel-left-actions {
        padding: 1rem;
        border-top: 1px solid var(--color-border);
        background: var(--color-surface);
    }

    .btn-ttds-next {
        background: var(--color-accent) !important;
        color: #fff;
    }

        .btn-ttds-next:hover {
            background: var(--color-accent-hover) !important;
        }
</style>

<div class="preview-view-wrapper py-4 px-2">

    <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-3 pb-3 border-bottom" style="border-color: var(--color-border) !important;">
        <div>
            <h1 class="fw-bold mb-1 d-flex align-items-center gap-2" style="font-size: 1.85rem; color: var(--color-text-main);">
                <i class="bi bi-check2-circle" style="color: var(--color-accent);"></i> Cleaned Trips
            </h1>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Batch: @Model.BatchId • @tripCount valid trip(s) remaining</p>
        </div>
        <a href="/gpx/preview-map/@Model.BatchId" class="btn-action">
            <i class="bi bi-arrow-left"></i> Back to Map
        </a>
    </div>

    <div class="preview-body-grid">

        <div class="panel-left">
            <div class="panel-left-header">
                <i class="bi bi-signpost-split me-2"></i>Select Trips
            </div>

            <div class="selection-controls">
                <button type="button" class="btn-sel" id="selectAllBtn">All</button>
                <button type="button" class="btn-sel" id="deselectAllBtn">None</button>
                <button type="button" class="btn-sel warning" id="toggleBtn">Toggle</button>
            </div>

            <form id="cleanedActionForm" method="post" class="d-flex flex-column flex-grow-1" style="min-height:0;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="batchId" value="@Model.BatchId" />
                <div id="selectedFilesContainer"></div>

                <div class="trip-list-scroll">
                    @for (int i = 0; i < tripCount; i++)
                    {
                        var t = Model.Trips[i];
                        var id = "trip_" + i;
                        <label class="trip-row" for="@id">
                            <input class="trip-checkbox" type="checkbox" id="@id"
                                   data-files='@Html.Raw(JsonSerializer.Serialize(t.SourceZipFiles))' checked />
                            <div class="trip-row-body">
                                <div class="trip-row-title">@t.VehicleCode @t.TripId (@t.Direction-@t.PartIndex)</div>
                                <div class="trip-row-meta">
                                    <i class="bi bi-geo"></i> @(t.DetectedRegionId ?? "UNK") |
                                    <i class="bi bi-road"></i> @(t.DetectedRoadName ?? "UNK") | @(t.Points?.Count ?? 0) pts
                                </div>
                                <div class="trip-row-zip"><i class="bi bi-file-zip"></i> @t.SourceZipFileName</div>
                            </div>
                        </label>
                    }
                </div>

                <div class="panel-left-actions">
                    <button type="submit" formaction="/gpx/process-selected" class="btn-ttds btn-ttds-next">
                        <i class="bi bi-download me-2"></i>Download CSV ZIP
                    </button>
                </div>
            </form>
        </div>

        <div class="panel-right">
            <div id="map"></div>
            <div class="map-footer d-flex align-items-center justify-content-between">
                <span><i class="bi bi-info-circle-fill me-1" style="color:var(--color-primary)"></i>Click lines to toggle selection</span>
                <a href="https://localhost:7046/" class="btn-ttds btn-ttds-next" style="width:auto; padding:4px 16px;">
                    Next: Processing <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const vm = @Html.Raw(JsonSerializer.Serialize(Model));
        const trips = vm.trips || vm.Trips || [];
        const map = L.map('map').setView([12.8797, 121.7740], 6);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 20 }).addTo(map);

        setTimeout(() => { map.invalidateSize(); }, 250);

        let layers = [];

        function updateMap() {
            layers.forEach(l => map.removeLayer(l));
            layers = [];
            const boundsList = [];

            trips.forEach((t, i) => {
                const cb = document.getElementById("trip_" + i);
                if (!cb || !cb.checked) return;

                const pts = t.points || t.Points || [];
                const latlngs = pts.map(p => {
                    const lat = p.snappedLat ?? p.SnappedLat ?? p.lat ?? p.Lat ?? p.latitude ?? p.Latitude ?? p.item1 ?? p.Item1;
                    const lon = p.snappedLon ?? p.SnappedLon ?? p.lon ?? p.Lon ?? p.longitude ?? p.Longitude ?? p.item2 ?? p.Item2;
                    return (lat != null && lon != null) ? [lat, lon] : null;
                }).filter(Boolean);

                if (latlngs.length < 2) return;

                const line = L.polyline(latlngs, { weight: 4, color: '#1d4470', opacity: 0.9 }).addTo(map);
                line.on("click", () => { cb.checked = !cb.checked; updateMap(); });
                layers.push(line);
                boundsList.push(line.getBounds());

                const s = t.start || t.Start;
                const e = t.end || t.End;

                if ((s?.lat ?? s?.Lat) != null) {
                    const sm = L.circleMarker([s.lat ?? s.Lat, s.lon ?? s.Lon], { radius: 6, color: '#16a34a', fillColor: '#16a34a', fillOpacity: 1 }).addTo(map);
                    layers.push(sm);
                }
                if ((e?.lat ?? e?.Lat) != null) {
                    const em = L.circleMarker([e.lat ?? e.Lat, e.lon ?? e.Lon], { radius: 6, color: '#dc2626', fillColor: '#dc2626', fillOpacity: 1 }).addTo(map);
                    layers.push(em);
                }
            });

            if (boundsList.length) {
                let b = boundsList[0];
                for (let i = 1; i < boundsList.length; i++) b = b.extend(boundsList[i]);
                map.fitBounds(b.pad(0.15));
            }
        }

        // Event Bindings
        document.querySelectorAll(".trip-checkbox").forEach(cb => cb.addEventListener("change", updateMap));
        document.getElementById("selectAllBtn").addEventListener("click", () => { document.querySelectorAll(".trip-checkbox").forEach(cb => cb.checked = true); updateMap(); });
        document.getElementById("deselectAllBtn").addEventListener("click", () => { document.querySelectorAll(".trip-checkbox").forEach(cb => cb.checked = false); updateMap(); });
        document.getElementById("toggleBtn").addEventListener("click", () => { document.querySelectorAll(".trip-checkbox").forEach(cb => cb.checked = !cb.checked); updateMap(); });

        updateMap();
    </script>
}