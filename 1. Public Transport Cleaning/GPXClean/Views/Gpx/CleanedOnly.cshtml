@model Travel_Time_and_Delay_Web_Application.Models.GpxCleanedOnlyVm
@using System.Text.Json

@{
    ViewData["Title"] = "Cleaned Trips Only";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-2">
        <div>
            <h3 class="mb-0">Cleaned Trips Only</h3>
            <div class="text-muted">Batch: @Model.BatchId | Trips: @(Model.Trips?.Count ?? 0)</div>
        </div>

        <div class="d-flex gap-2">
            <a href="/gpx/preview-map/@Model.BatchId" class="btn btn-outline-secondary">
                Back to Map Preview
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- LEFT: Trip selection + actions -->
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">

                    <h5 class="card-title mb-2">Trips (Cleaned)</h5>

                    <!-- Selection buttons -->
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <button type="button" class="btn btn-sm btn-primary" id="selectAllBtn">Select All</button>
                        <button type="button" class="btn btn-sm btn-secondary" id="deselectAllBtn">Deselect All</button>
                        <button type="button" class="btn btn-sm btn-warning" id="toggleBtn">Switch Selection</button>
                    </div>

                    <form id="cleanedActionForm" method="post" class="d-flex flex-column gap-2">
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="batchId" value="@Model.BatchId" />
                        <div id="selectedFilesContainer"></div>

                        <div class="border rounded p-2" style="max-height: 60vh; overflow:auto;">
                            @for (int i = 0; i < (Model.Trips?.Count ?? 0); i++)
                            {
                                var t = Model.Trips[i];
                                var id = "trip_" + i;

                                <div class="form-check mb-2">
                                    <input class="form-check-input trip-checkbox"
                                           type="checkbox"
                                           id="@id"
                                           data-files='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(t.SourceZipFiles))'
                                           checked />
                                    <label class="form-check-label text-break" for="@id">
                                        <div class="fw-semibold">
                                            @t.VehicleCode @t.TripId (@t.Direction-@t.PartIndex)
                                        </div>

                                        <div class="small text-muted">
                                            @(t.DetectedRegionId ?? "UNK") | @(t.DetectedRoadName ?? "UNK")
                                            • @(t.Points?.Count ?? 0) pts
                                        </div>

                                        <div class="small text-muted">
                                            ZIP: @t.SourceZipFileName
                                        </div>
                                    </label>
                                </div>
                            }
                        </div>

                        <button type="submit"
                                formaction="/gpx/process-selected"
                                class="btn btn-success">
                            Download CSV ZIP (Selected)
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- RIGHT: Map -->
        <div class="col-md-9">
            <div class="card h-100">
                <div class="card-body">
                    <div id="map" style="height: 70vh; border-radius: 8px; border: 1px solid #dee2e6;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        const vm = @Html.Raw(JsonSerializer.Serialize(Model));
        const trips = vm.trips || vm.Trips || [];

        const map = L.map('map').setView([12.8797, 121.7740], 6);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 20
        }).addTo(map);

        let layers = [];

        function clearLayers() {
            layers.forEach(layer => map.removeLayer(layer));
            layers = [];
        }

        function updateMap() {
            clearLayers();

            const boundsList = [];

            trips.forEach((t, i) => {
                const cb = document.getElementById("trip_" + i);
                if (!cb || !cb.checked) return;

                const pts = t.points || t.Points || [];
                if (!pts || pts.length < 2) return;

                const latlngs = pts.map(p => {
                    const lat =
                        p.snappedLat ?? p.SnappedLat ??
                        p.lat ?? p.Lat ??
                        p.latitude ?? p.Latitude ??
                        p.item1 ?? p.Item1;

                    const lon =
                        p.snappedLon ?? p.SnappedLon ??
                        p.lon ?? p.Lon ??
                        p.longitude ?? p.Longitude ??
                        p.item2 ?? p.Item2;

                    return (lat != null && lon != null) ? [lat, lon] : null;
                }).filter(Boolean);

                if (latlngs.length < 2) return;

                const line = L.polyline(latlngs, {
                    weight: 4,
                    color: "#0d6efd",
                    opacity: 0.9
                }).addTo(map);

                line.bindPopup(`
                    <div>
                        <strong>${t.vehicleCode || t.VehicleCode || ""} ${t.tripId || t.TripId || ""}</strong><br/>
                        ${(t.direction || t.Direction || "")}-${(t.partIndex || t.PartIndex || "")}<br/>
                        ${(t.detectedRegionId || t.DetectedRegionId || "UNK")} | ${(t.detectedRoadName || t.DetectedRoadName || "UNK")}
                    </div>
                `);

                // Click line to toggle checkbox selection
                line.on("click", () => {
                    cb.checked = !cb.checked;
                    updateMap();
                });

                layers.push(line);
                boundsList.push(line.getBounds());

                const s = t.start || t.Start;
                const e = t.end || t.End;

                if ((s?.lat ?? s?.Lat) != null && (s?.lon ?? s?.Lon) != null) {
                    const sm = L.circleMarker(
                        [s.lat ?? s.Lat, s.lon ?? s.Lon],
                        {
                            radius: 6,
                            color: "green",
                            fillColor: "green",
                            fillOpacity: 1
                        }
                    ).addTo(map);

                    sm.bindPopup(`Start: ${t.vehicleCode || t.VehicleCode || ""} ${t.tripId || t.TripId || ""}`);
                    layers.push(sm);
                }

                if ((e?.lat ?? e?.Lat) != null && (e?.lon ?? e?.Lon) != null) {
                    const em = L.circleMarker(
                        [e.lat ?? e.Lat, e.lon ?? e.Lon],
                        {
                            radius: 6,
                            color: "red",
                            fillColor: "red",
                            fillOpacity: 1
                        }
                    ).addTo(map);

                    em.bindPopup(`End: ${t.vehicleCode || t.VehicleCode || ""} ${t.tripId || t.TripId || ""}`);
                    layers.push(em);
                }
            });

            if (boundsList.length) {
                let b = boundsList[0];
                for (let i = 1; i < boundsList.length; i++) {
                    b = b.extend(boundsList[i]);
                }
                map.fitBounds(b.pad(0.15));
            } else {
                map.setView([12.8797, 121.7740], 6);
            }
        }

        // checkbox change -> redraw map
        document.querySelectorAll(".trip-checkbox").forEach(cb => {
            cb.addEventListener("change", updateMap);
        });

        // Select All
        document.getElementById("selectAllBtn").addEventListener("click", () => {
            document.querySelectorAll(".trip-checkbox").forEach(cb => {
                cb.checked = true;
            });
            updateMap();
        });

        // Deselect All
        document.getElementById("deselectAllBtn").addEventListener("click", () => {
            document.querySelectorAll(".trip-checkbox").forEach(cb => {
                cb.checked = false;
            });
            updateMap();
        });

        // Switch Selection
        document.getElementById("toggleBtn").addEventListener("click", () => {
            document.querySelectorAll(".trip-checkbox").forEach(cb => {
                cb.checked = !cb.checked;
            });
            updateMap();
        });

        updateMap();

        // Submit selected ZIP files to controller
        const form = document.getElementById("cleanedActionForm");
        const container = document.getElementById("selectedFilesContainer");

        form.addEventListener("submit", function () {
            container.innerHTML = "";

            const all = new Set();

            document.querySelectorAll(".trip-checkbox:checked").forEach(cb => {
                try {
                    const arr = JSON.parse(cb.getAttribute("data-files") || "[]");
                    arr.forEach(z => all.add(z));
                } catch (e) {
                    console.error("Invalid data-files JSON:", e);
                }
            });

            all.forEach(z => {
                const inp = document.createElement("input");
                inp.type = "hidden";
                inp.name = "selectedFiles";
                inp.value = z;
                container.appendChild(inp);
            });
        });
    </script>
}