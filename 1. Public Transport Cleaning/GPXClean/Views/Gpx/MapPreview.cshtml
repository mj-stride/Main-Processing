@model Travel_Time_and_Delay_Web_Application.Models.GpxPreviewVm
@using System.Text.Json

@{
    ViewData["Title"] = "Preview GPX on Map";
    ViewData["Section"] = "Clean and Snap (PUV)";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
    html, body {
        height: 100%;
        margin: 0;
    }

    .preview-wrapper {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 48px);
        padding: 1rem;
        gap: 1rem;
        box-sizing: border-box;
    }

    .preview-heading {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
    }

        .preview-heading h1 {
            font-size: 1.5rem;
            font-weight: 700;
            margin: 0;
        }

        .preview-heading .meta {
            font-size: 0.82rem;
            color: #666;
            margin-top: 2px;
        }

    .preview-body {
        display: flex;
        gap: 1rem;
        flex: 1;
        min-height: 0;
    }

    /* LEFT PANEL */
    .panel-left {
        width: 320px;
        flex-shrink: 0;
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid #ccc;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .panel-left-header {
        padding: 1rem 1rem 0.5rem;
        font-weight: 700;
        font-size: 0.95rem;
        color: #1d4470;
        flex-shrink: 0;
        border-bottom: 1px solid #e0e6ee;
    }

    .file-list-scroll {
        flex: 1;
        overflow-y: auto;
        padding: 0.75rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .file-list-scroll::-webkit-scrollbar {
            width: 5px;
        }

        .file-list-scroll::-webkit-scrollbar-track {
            background: #f0f0f0;
            border-radius: 999px;
        }

        .file-list-scroll::-webkit-scrollbar-thumb {
            background: #aab4c4;
            border-radius: 999px;
        }

    .file-row {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #f0f4f8;
        border: 1px solid #d0d8e4;
        border-radius: 8px;
        padding: 7px 10px;
        cursor: pointer;
        transition: background 0.12s;
    }

        .file-row:hover {
            background: #e2eaf3;
        }

        .file-row input[type="checkbox"] {
            accent-color: #1d4470;
            flex-shrink: 0;
            width: 15px;
            height: 15px;
            cursor: pointer;
        }

    .file-row-name {
        font-size: 0.78rem;
        color: #333;
        word-break: break-all;
        flex: 1;
        line-height: 1.3;
    }

    .file-row-pts {
        font-size: 0.72rem;
        color: #888;
        flex-shrink: 0;
        white-space: nowrap;
    }

    /* Action buttons */
    .panel-left-actions {
        padding: 0.75rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 8px;
        border-top: 1px solid #e0e6ee;
        flex-shrink: 0;
    }

    .btn-ttds {
        background: #1d4470;
        color: #eeeeee;
        border: none;
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 600;
        padding: 9px 16px;
        width: 100%;
        text-align: center;
        transition: background 0.18s, transform 0.1s;
        cursor: pointer;
        text-decoration: none;
        display: block;
    }

        .btn-ttds:hover {
            background: #245490;
            color: #eeeeee;
            transform: translateY(-1px);
        }

        .btn-ttds:active {
            transform: translateY(0);
        }

        .btn-ttds.secondary {
            background: transparent;
            color: #555;
            border: 1.5px solid #bbb;
        }

            .btn-ttds.secondary:hover {
                background: #f0f0f0;
                color: #555;
            }

        .btn-ttds:disabled {
            background: #5a7fa8;
            color: #ccc;
            pointer-events: none;
        }

    .action-divider {
        border: none;
        border-top: 1px dashed #d0d8e4;
        margin: 2px 0;
    }

    /* RIGHT PANEL */
    .panel-right {
        flex: 1;
        min-width: 0;
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid #ccc;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    #map {
        flex: 1;
        min-height: 0;
        width: 100%;
    }

    .map-footer {
        padding: 0.5rem 1rem;
        font-size: 0.78rem;
        color: #888;
        border-top: 1px solid #e0e6ee;
        flex-shrink: 0;
    }

    /* Loading overlay */
    #loadingOverlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.55);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }

    #loadingCard {
        width: min(520px, 92vw);
        background: #fff;
        border-radius: 12px;
        padding: 18px 18px 14px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.25);
        border: 1px solid #e5e5e5;
    }

    #loadingTitle {
        font-weight: 600;
        margin-bottom: 8px;
        font-size: 1.05rem;
    }

    #loadingMsg {
        font-size: 0.92rem;
        color: #555;
        margin-bottom: 12px;
    }

    .progress {
        height: 12px;
        border-radius: 999px;
        overflow: hidden;
        background: #e9ecef;
    }

    .progress-bar {
        width: 30%;
        height: 100%;
        background: linear-gradient(90deg, #1d4470, #2f6db5);
        animation: indeterminate 1.1s infinite ease-in-out;
    }

    @@keyframes indeterminate {
        0% {
            transform: translateX(-120%);
        }

        100% {
            transform: translateX(420%);
        }
    }

    .disabled-clicks {
        pointer-events: none;
        opacity: .75;
    }

    @@media (max-width: 767px) {
        .preview-body {
            flex-direction: column;
        }

        .panel-left {
            width: 100%;
            max-height: 45vh;
        }

        .panel-right {
            min-height: 50vh;
        }
    }
</style>

<!-- Loading overlay -->
<div id="loadingOverlay">
    <div id="loadingCard">
        <div id="loadingTitle">Cleaning selected files…</div>
        <div id="loadingMsg">Grouping trips and preparing cleaned preview. Please wait.</div>
        <div class="progress">
            <div class="progress-bar"></div>
        </div>
        <div class="small text-muted mt-2">Don't refresh or go back while processing.</div>
    </div>
</div>

<div class="preview-wrapper">

    <!-- Heading -->
    <div class="preview-heading">
        <div>
            <h1><i class="bi bi-map me-2" style="color: #da471f;"></i>GPX Map Preview</h1>
            <div class="meta">
                <i class="bi bi-collection me-1"></i>Batch: @Model.BatchId
                &nbsp;·&nbsp;
                <i class="bi bi-files me-1"></i>@Model.Files.Count file@(Model.Files.Count != 1 ? "s" : "")
            </div>
        </div>
        <a id="btnBack" href="/gpx/upload" class="btn-ttds secondary" style="width:auto; padding:8px 20px;">
            <i class="bi bi-arrow-left me-1"></i> Back to Upload
        </a>
    </div>

    <!-- Body -->
    <div class="preview-body">

        <!-- LEFT -->
        <div class="panel-left">
            <div class="panel-left-header">
                <i class="bi bi-folder2-open me-1"></i> Files
            </div>

            <form id="processForm" method="post" action="/gpx/process-selected" style="display:contents;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="batchId" value="@Model.BatchId" />

                <div class="file-list-scroll">
                    @{
                        var idx = 0;
                    }
                    @foreach (var f in Model.Files)
                    {
                        var safeId = "chk_" + idx;
                        idx++;
                        <label class="file-row" for="@safeId">
                            <input class="file-check"
                                   type="checkbox"
                                   value="@f.FileName"
                                   id="@safeId"
                                   name="selectedFiles"
                                   checked />
                            <span class="file-row-name">@f.FileName</span>
                            <span class="file-row-pts">@(f.Points?.Count ?? 0) pts</span>
                        </label>
                    }
                </div>
            </form>

            <div class="panel-left-actions">
                <button id="btnClean"
                        type="submit"
                        form="processForm"
                        formaction="/gpx/cleaned-only-view"
                        class="btn-ttds">
                    <i class="bi bi-check2-circle me-1"></i> Continue (Clean Selected)
                </button>
            </div>
        </div>

        <!-- RIGHT: Map -->
        <div class="panel-right">
            <div id="map"></div>
            <div class="map-footer">
                <i class="bi bi-info-circle me-1"></i>
                Toggle files on the left to show or hide their routes on the map.
            </div>
        </div>

    </div>
</div>

<script>
    const map = L.map('map');
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 20,
        attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    const vm = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));
    const files = vm.files ?? vm.Files ?? [];

    console.log("files:", files);
    console.log("first file:", files[0]);
    console.log("first point:", (files[0]?.points ?? files[0]?.Points)?.[0]);

    function toLatLngArray(pts) {
        return (pts || []).map(p => {
            if (Array.isArray(p) && p.length >= 2) return [p[0], p[1]];
            const lat = (p.lat ?? p.Lat ?? p.latitude ?? p.Latitude ?? p.item1 ?? p.Item1);
            const lon = (p.lon ?? p.Lon ?? p.longitude ?? p.Longitude ?? p.item2 ?? p.Item2);
            return (lat != null && lon != null) ? [lat, lon] : null;
        }).filter(Boolean);
    }

    const layers = {};
    const bounds = L.latLngBounds();

    files.forEach(f => {
        const name = f.fileName ?? f.FileName ?? '';
        const pts = f.points ?? f.Points ?? [];
        const latlngs = toLatLngArray(pts);
        if (latlngs.length >= 2) {
            const layer = L.polyline(latlngs, { weight: 3, color: '#1d4470' }).addTo(map);
            layers[name] = layer;
            latlngs.forEach(ll => bounds.extend(ll));
        }
    });

    if (bounds.isValid()) map.fitBounds(bounds, { padding: [20, 20] });
    else map.setView([12.8797, 121.7740], 6);

    document.querySelectorAll('.file-check').forEach(cb => {
        cb.addEventListener('change', e => {
            const key = e.target.value || '';
            const layer = layers[key];
            if (!layer) return;
            if (e.target.checked) layer.addTo(map);
            else map.removeLayer(layer);
        });
    });

        (function () {
        const form = document.getElementById("processForm");
        const overlay = document.getElementById("loadingOverlay");
        const btnClean = document.getElementById("btnClean");
        const btnBack = document.getElementById("btnBack");

        if (!form || !overlay) return;

        form.addEventListener("submit", function () {
            overlay.style.display = "flex";
            if (btnClean) btnClean.disabled = true;
            if (btnBack) btnBack.classList.add("disabled-clicks");
        });
    })();
</script>