@model Travel_Time_and_Delay_Web_Application.Models.GpxPreviewVm

@using System.Text.Json
@using System.Linq

@{
    ViewData["Title"] = "Snapped Preview (Selected)";
    ViewData["Section"] = "Clean and Snap (PUV)";
    var fileGroups = Model.Files
        .OrderBy(f => f.FileName)
        .ToList();
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
    /* Full-height layout */
    html, body {
        height: 100%;
        margin: 0;
    }

    .preview-wrapper {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 48px); /* subtract topbar height */
        padding: 1rem;
        gap: 1rem;
        box-sizing: border-box;
    }

    /* Page heading row */
    .preview-heading {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
    }

        .preview-heading h1 {
            font-size: 1.5rem;
            font-weight: 700;
            margin: 0;
        }

        .preview-heading .meta {
            font-size: 0.82rem;
            color: #666;
            margin-top: 2px;
        }

    /* Main content row */
    .preview-body {
        display: flex;
        gap: 1rem;
        flex: 1;
        min-height: 0;
    }

    /* LEFT PANEL */
    .panel-left {
        width: 360px;
        flex-shrink: 0;
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid #ccc;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .panel-left-header {
        padding: 1rem 1rem 0.5rem;
        font-weight: 700;
        font-size: 0.95rem;
        color: #1d4470;
        flex-shrink: 0;
        border-bottom: 1px solid #e0e6ee;
    }

    .file-list-scroll {
        flex: 1;
        overflow-y: auto;
        padding: 0.75rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .file-list-scroll::-webkit-scrollbar {
            width: 5px;
        }

        .file-list-scroll::-webkit-scrollbar-track {
            background: #f0f0f0;
            border-radius: 999px;
        }

        .file-list-scroll::-webkit-scrollbar-thumb {
            background: #aab4c4;
            border-radius: 999px;
        }

    /* File row */
    .file-row {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #f0f4f8;
        border: 1px solid #d0d8e4;
        border-radius: 8px;
        padding: 7px 10px;
        cursor: pointer;
        transition: background 0.12s;
    }

        .file-row:hover {
            background: #e2eaf3;
        }

        .file-row input[type="checkbox"] {
            accent-color: #1d4470;
            flex-shrink: 0;
            width: 15px;
            height: 15px;
            cursor: pointer;
        }

    .file-row-name {
        font-size: 0.78rem;
        color: #333;
        word-break: break-all;
        flex: 1;
        line-height: 1.3;
    }

    .file-row-pts {
        font-size: 0.72rem;
        color: #888;
        flex-shrink: 0;
        white-space: nowrap;
    }

    /* Action buttons panel */
    .panel-left-actions {
        padding: 0.75rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 8px;
        border-top: 1px solid #e0e6ee;
        flex-shrink: 0;
    }

    /* Pill button — reused */
    .btn-ttds {
        background: #1d4470;
        color: #eeeeee;
        border: none;
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 600;
        padding: 9px 16px;
        width: 100%;
        text-align: center;
        transition: background 0.18s, transform 0.1s;
        cursor: pointer;
    }

        .btn-ttds:hover {
            background: #245490;
            color: #eeeeee;
            transform: translateY(-1px);
        }

        .btn-ttds:active {
            transform: translateY(0);
        }

        .btn-ttds.success {
            background: #1a6640;
        }

            .btn-ttds.success:hover {
                background: #1f7a4c;
            }

        .btn-ttds.outline {
            background: transparent;
            color: #1d4470;
            border: 1.5px solid #1d4470;
        }

            .btn-ttds.outline:hover {
                background: #e8eef5;
            }

        .btn-ttds.secondary {
            background: transparent;
            color: #555;
            border: 1.5px solid #bbb;
        }

            .btn-ttds.secondary:hover {
                background: #f0f0f0;
            }

    /* RIGHT PANEL — map */
    .panel-right {
        flex: 1;
        min-width: 0;
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid #ccc;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    #map {
        flex: 1;
        min-height: 0;
        width: 100%;
        border-radius: 16px;
    }

    .map-footer {
        padding: 0.5rem 1rem;
        font-size: 0.78rem;
        color: #888;
        border-top: 1px solid #e0e6ee;
        flex-shrink: 0;
    }

    /* Responsive */
    @@media (max-width: 767px) {
        .preview-body {
            flex-direction: column;
        }

        .panel-left {
            width: 100%;
            max-height: 40vh;
        }

        .panel-right {
            min-height: 50vh;
        }
    }
</style>

<div class="preview-wrapper">

    <!-- Heading -->
    <div class="preview-heading">
        <div>
            <h1><i class="bi bi-map me-2" style="color: #da471f;"></i>Snapped Data Preview</h1>
            <div class="meta">
                <i class="bi bi-collection me-1"></i>Batch: @Model.BatchId
                &nbsp;·&nbsp;
                <i class="bi bi-files me-1"></i>@Model.Files.Count file@(Model.Files.Count != 1 ? "s" : "")
            </div>
        </div>
        <a href="/gpx/upload" class="btn-ttds secondary" style="width: auto; padding: 8px 20px; text-decoration: none;">
            <i class="bi bi-arrow-left me-1"></i> Back to Upload
        </a>
    </div>

    <!-- Body -->
    <div class="preview-body">

        <!-- LEFT: file list + actions -->
        <div class="panel-left">
            <div class="panel-left-header">
                <i class="bi bi-folder2-open me-1"></i> Selected Files
            </div>

            <form id="actionForm" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="batchId" value="@Model.BatchId" />
                <div id="selectedFilesContainer"></div>

                <div class="file-list-scroll">
                    @foreach (var f in fileGroups)
                    {
                        var chkId = "chk_" + Guid.NewGuid().ToString("N");
                        <label class="file-row" for="@chkId">
                            <input class="form-check-input file-checkbox"
                                   type="checkbox"
                                   id="@chkId"
                                   data-file="@f.FileName"
                                   checked />
                            <span class="file-row-name">@f.FileName</span>
                            <span class="file-row-pts">@(f.Points?.Count ?? 0) pts</span>
                        </label>
                    }
                </div>

                <div class="panel-left-actions">
                    <button type="submit" formaction="/gpx/cleaned-only-view" class="btn-ttds">
                        <i class="bi bi-eye me-1"></i> View Cleaned Only
                    </button>
                    <button type="submit" formaction="/gpx/process-selected" class="btn-ttds success">
                        <i class="bi bi-download me-1"></i> Download CSV ZIP
                    </button>
                    <button type="submit" formaction="/gpx/preview-snapped-selected" class="btn-ttds outline">
                        <i class="bi bi-map me-1"></i> Preview Snapped
                    </button>
                </div>

            </form>
        </div>

        <!-- RIGHT: map -->
        <div class="panel-right">
            <div id="map"></div>
            <div class="map-footer">
                <i class="bi bi-info-circle me-1"></i>
                Showing snapped points only (light-decimated). Toggle files on the left to preview what will be processed.
            </div>
        </div>

    </div>
</div>

<script>
    const vm = @Html.Raw(JsonSerializer.Serialize(Model));
    const files = vm.files || vm.Files || [];

    const map = L.map('map').setView([12.8797, 121.7740], 5);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 20 }).addTo(map);

    let drawnLayers = [];

    function clearDrawn() {
        drawnLayers.forEach(l => map.removeLayer(l));
        drawnLayers = [];
    }

    function toLatLngArray(pts) {
        return (pts || []).map(p => {
            if (Array.isArray(p) && p.length >= 2) return [p[0], p[1]];
            const lat = (p.lat ?? p.Lat ?? p.latitude ?? p.Latitude ?? p.item1 ?? p.Item1);
            const lon = (p.lon ?? p.Lon ?? p.longitude ?? p.Longitude ?? p.item2 ?? p.Item2);
            return (lat != null && lon != null) ? [lat, lon] : null;
        }).filter(Boolean);
    }

    function updateMap() {
        clearDrawn();
        const selected = Array.from(document.querySelectorAll(".file-checkbox:checked"))
            .map(cb => cb.dataset.file);
        const bounds = L.latLngBounds();
        let hasAny = false;

        files.forEach(f => {
            const fname = f.fileName ?? f.FileName ?? "";
            if (!selected.includes(fname)) return;
            const pts = f.points ?? f.Points ?? [];
            const latlngs = toLatLngArray(pts);
            if (latlngs.length < 2) return;

            const line = L.polyline(latlngs, { weight: 3, color: '#1d4470' }).addTo(map);
            drawnLayers.push(line);
            latlngs.forEach(ll => bounds.extend(ll));
            hasAny = true;

            const s = f.start ?? f.Start;
            const e = f.end ?? f.End;
            if (s) {
                const sLat = s.lat ?? s.Lat, sLon = s.lon ?? s.Lon;
                if (sLat != null && sLon != null)
                    drawnLayers.push(L.circleMarker([sLat, sLon], { radius: 6, color: '#da471f' }).addTo(map));
            }
            if (e) {
                const eLat = e.lat ?? e.Lat, eLon = e.lon ?? e.Lon;
                if (eLat != null && eLon != null)
                    drawnLayers.push(L.circleMarker([eLat, eLon], { radius: 6, color: '#1a6640' }).addTo(map));
            }
        });

        if (hasAny && bounds.isValid()) map.fitBounds(bounds.pad(0.2));
    }

    document.querySelectorAll(".file-checkbox").forEach(cb => cb.addEventListener("change", updateMap));
    updateMap();

    const form = document.getElementById("actionForm");
    const container = document.getElementById("selectedFilesContainer");
    form.addEventListener("submit", function () {
        container.innerHTML = "";
        document.querySelectorAll(".file-checkbox:checked").forEach(cb => {
            const inp = document.createElement("input");
            inp.type = "hidden";
            inp.name = "selectedFiles";
            inp.value = cb.dataset.file;
            container.appendChild(inp);
        });
    });
</script>