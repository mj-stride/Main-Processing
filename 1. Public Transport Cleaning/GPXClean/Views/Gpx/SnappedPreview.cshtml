@* @model Travel_Time_and_Delay_Web_Application.Models.GpxPreviewVm *@
@model Travel_Time_and_Delay_Web_Application.Models.GpxPreviewVm

@using System.Text.Json
@using System.Linq

@{
    ViewData["Title"] = "Snapped Preview (Selected)";
    var fileGroups = Model.Files
        .OrderBy(f => f.FileName)
        .ToList();
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-2">
        <div>
            <h3 class="mb-0">Snapped Data Preview (Selected)</h3>
            <div class="text-muted">Batch: @Model.BatchId | Files: @Model.Files.Count</div>
        </div>
        <a href="/gpx/upload" class="btn btn-outline-secondary">Back to Upload</a>
    </div>

    <div class="row g-4">
        <!-- LEFT: FILE LIST + ACTIONS -->
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">

                    <h5 class="card-title mb-2">Selected Files</h5>

                    <!-- IMPORTANT: one form for ALL actions -->
                    <form id="actionForm" method="post" class="d-flex flex-column gap-2">
                        @Html.AntiForgeryToken()

                        <!-- send batchId -->
                        <input type="hidden" name="batchId" value="@Model.BatchId" />

                        <!-- dynamic selectedFiles[] -->
                        <div id="selectedFilesContainer"></div>

                        <div class="border rounded p-2" style="max-height: 55vh; overflow:auto;">
                            @foreach (var f in fileGroups)
                            {
                                var chkId = "chk_" + Guid.NewGuid().ToString("N");
                                <div class="form-check mb-2">
                                    <input class="form-check-input file-checkbox"
                                           type="checkbox"
                                           id="@chkId"
                                           data-file="@f.FileName"
                                           checked />
                                    <label class="form-check-label text-break" for="@chkId">
                                        @f.FileName
                                        <small class="text-muted">(@(f.Points?.Count ?? 0) pts)</small>
                                    </label>
                                </div>
                            }
                        </div>

                        <!-- ACTION BUTTONS -->
                        <button type="submit"
                                formaction="/gpx/cleaned-only-view"
                                class="btn btn-primary">
                            View Cleaned Only
                        </button>

                        <button type="submit"
                                formaction="/gpx/process-selected"
                                class="btn btn-success">
                            Download CSV ZIP
                        </button>
                        <button type="submit"
                                formaction="/gpx/preview-snapped-selected"
                                class="btn btn-outline-primary">
                            Preview Snapped (Selected)
                        </button>

                        <a href="/gpx/upload" class="btn btn-outline-secondary">Back</a>
                    </form>

                </div>
            </div>
        </div>

        <!-- RIGHT: MAP -->
        <div class="col-md-9">
            <div class="card h-100">
                <div class="card-body">
                    <div id="map" style="height: 65vh; border-radius: 8px; border: 1px solid #dee2e6;"></div>
                    <div class="small text-muted mt-2">
                        Showing SNAPPED points only (light-decimated). Toggle files on the left to preview what will be processed/downloaded.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // server data
    const vm = @Html.Raw(JsonSerializer.Serialize(Model));
    const files = vm.files || vm.Files || [];

    // map init
    const map = L.map('map').setView([12.8797, 121.7740], 5);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 20 }).addTo(map);

    let drawnLayers = [];

    function clearDrawn() {
      drawnLayers.forEach(l => map.removeLayer(l));
      drawnLayers = [];
    }

    function toLatLngArray(pts) {
      return (pts || []).map(p => {
        // supports: {lat,lon} / {Lat,Lon} / [lat,lon] / {Item1,Item2}
        if (Array.isArray(p) && p.length >= 2) return [p[0], p[1]];
        const lat = (p.lat ?? p.Lat ?? p.latitude ?? p.Latitude ?? p.item1 ?? p.Item1);
        const lon = (p.lon ?? p.Lon ?? p.longitude ?? p.Longitude ?? p.item2 ?? p.Item2);
        return (lat != null && lon != null) ? [lat, lon] : null;
      }).filter(Boolean);
    }

    function updateMap() {
      clearDrawn();

      const selected = Array.from(document.querySelectorAll(".file-checkbox:checked"))
        .map(cb => cb.dataset.file);

      const bounds = L.latLngBounds();
      let hasAny = false;

      files.forEach(f => {
        const fname = f.fileName ?? f.FileName ?? "";
        if (!selected.includes(fname)) return;

        const pts = f.points ?? f.Points ?? [];
        const latlngs = toLatLngArray(pts);
        if (latlngs.length < 2) return;

        const line = L.polyline(latlngs, { weight: 3 }).addTo(map);
        drawnLayers.push(line);

        latlngs.forEach(ll => bounds.extend(ll));
        hasAny = true;

        // optional start/end if your model has it (safe)
        const s = f.start ?? f.Start;
        const e = f.end ?? f.End;

        if (s) {
          const sLat = s.lat ?? s.Lat;
          const sLon = s.lon ?? s.Lon;
          if (sLat != null && sLon != null) {
            drawnLayers.push(L.circleMarker([sLat, sLon], { radius: 6 }).addTo(map));
          }
        }

        if (e) {
          const eLat = e.lat ?? e.Lat;
          const eLon = e.lon ?? e.Lon;
          if (eLat != null && eLon != null) {
            drawnLayers.push(L.circleMarker([eLat, eLon], { radius: 6 }).addTo(map));
          }
        }
      });

      if (hasAny && bounds.isValid()) map.fitBounds(bounds.pad(0.2));
    }

    document.querySelectorAll(".file-checkbox").forEach(cb => cb.addEventListener("change", updateMap));
    updateMap();

    // build selectedFiles[] on submit
    const form = document.getElementById("actionForm");
    const container = document.getElementById("selectedFilesContainer");

    form.addEventListener("submit", function () {
      container.innerHTML = "";
      document.querySelectorAll(".file-checkbox:checked").forEach(cb => {
        const inp = document.createElement("input");
        inp.type = "hidden";
        inp.name = "selectedFiles";
        inp.value = cb.dataset.file;
        container.appendChild(inp);
      });
    });
</script>

