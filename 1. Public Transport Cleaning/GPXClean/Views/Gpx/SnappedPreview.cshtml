@model Travel_Time_and_Delay_Web_Application.Models.GpxPreviewVm
@using System.Text.Json

@{
    ViewData["Title"] = "Preview Raw GPX Logs on Map";
    ViewData["Section"] = "Clean and Snap (PUV)";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
    /* 1. STRICT VIEWPORT LOCK: Outlaws outer browser scrolling */
    html, body {
        height: 100vh !important;
        overflow: hidden !important;
    }

    /* 2. MASTER BOUNDING BOX: Fits exactly between Topbar and Footer */
    .preview-view-wrapper {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 110px); /* 100vh minus Topbar (~60px), Footer (~40px), and margins */
        max-width: 1600px;
        margin: 0 auto;
        width: 100%;
    }

    /* Main split container */
    .preview-body-grid {
        display: flex;
        gap: 1.5rem;
        flex: 1;
        min-height: 0; /* Crucial flex lock */
    }

    /* LEFT PANEL */
    .panel-left {
        width: 350px;
        flex-shrink: 0;
        background: var(--color-surface);
        border-radius: 12px;
        border: 1px solid var(--color-border);
        box-shadow: var(--shadow-sm);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .panel-left-header {
        padding: 1rem 1.25rem 0.75rem;
        font-weight: 700;
        font-size: 0.95rem;
        color: var(--color-primary);
        border-bottom: 1px solid var(--color-border);
        background-color: var(--color-surface);
    }

    .file-list-scroll {
        flex: 1 1 auto;
        overflow-y: auto;
        min-height: 0; /* Forces long lists to spawn internal scrollbar */
        padding: 0.75rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .file-list-scroll::-webkit-scrollbar {
            width: 6px;
        }

        .file-list-scroll::-webkit-scrollbar-track {
            background: var(--color-bg);
        }

        .file-list-scroll::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 999px;
        }

    .file-toggle-row {
        display: flex;
        align-items: center;
        gap: 10px;
        background: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        padding: 6px 10px;
        cursor: pointer;
        transition: all 0.15s ease;
    }

        .file-toggle-row:hover {
            background: #f1f5f9;
            border-color: #cbd5e1;
        }

        .file-toggle-row input[type="checkbox"] {
            accent-color: var(--color-primary);
            margin-top: 2px;
            cursor: pointer;
        }

    .file-toggle-name {
        font-size: 0.8rem;
        color: var(--color-text-main);
        font-weight: 500;
        word-break: break-all;
        flex: 1;
        line-height: 1.25;
        margin-bottom: 0;
    }

    .file-toggle-pts {
        font-size: 0.72rem;
        color: var(--color-text-muted);
        background: #e2e8f0;
        padding: 2px 6px;
        border-radius: 4px;
        font-weight: 600;
    }

    .panel-left-actions {
        padding: 1rem;
        border-top: 1px solid var(--color-border);
        background: var(--color-surface);
    }

    /* RIGHT PANEL */
    .panel-right {
        flex: 1;
        min-width: 0;
        background: var(--color-surface);
        border-radius: 12px;
        border: 1px solid var(--color-border);
        box-shadow: var(--shadow-sm);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    #map {
        flex: 1;
        min-height: 0;
        width: 100%;
        background-color: #e5e7eb;
    }

    .map-footer {
        padding: 0.75rem 1.25rem;
        font-size: 0.82rem;
        color: var(--color-text-muted);
        border-top: 1px solid var(--color-border);
        background: var(--color-surface);
    }

    /* Processing Modal */
    #loadingOverlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(3px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }

    #loadingCard {
        width: min(520px, 92vw);
        background: var(--color-surface);
        border-radius: 16px;
        padding: 28px 24px;
        box-shadow: var(--shadow-lg);
        border: 1px solid var(--color-border);
        text-align: center;
    }

    #loadingTitle {
        font-weight: 700;
        margin-bottom: 8px;
        font-size: 1.2rem;
        color: var(--color-text-main);
    }

    #loadingMsg {
        font-size: 0.92rem;
        color: var(--color-text-muted);
        margin-bottom: 20px;
    }

    .progress {
        height: 10px;
        border-radius: 999px;
        overflow: hidden;
        background: var(--color-border);
        margin-bottom: 12px;
    }

    .progress-bar {
        width: 30%;
        height: 100%;
        background: linear-gradient(90deg, var(--color-primary), #3b82f6);
        animation: indeterminate 1.1s infinite ease-in-out;
    }

    @@keyframes indeterminate {
        0%

    {
        transform: translateX(-120%);
    }

    100% {
        transform: translateX(420%);
    }

    }

    .disabled-clicks {
        pointer-events: none;
        opacity: 0.75;
    }
</style>

<div id="loadingOverlay">
    <div id="loadingCard">
        <div class="spinner-border mb-3" role="status" style="color: var(--color-primary); width: 2.2rem; height: 2.2rem;">
            <span class="visually-hidden">Loading...</span>
        </div>
        <div id="loadingTitle">Cleaning survey logs…</div>
        <div id="loadingMsg">Filtering outlier GPS jumps and grouping trip paths. Please wait.</div>
        <div class="progress">
            <div class="progress-bar"></div>
        </div>
        <div class="small mt-2" style="color: var(--color-text-muted);">Don't refresh or navigate away while processing.</div>
    </div>
</div>

<div class="preview-view-wrapper py-3 px-2">

    <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-3 pb-3 border-bottom flex-shrink-0" style="border-color: var(--color-border) !important;">
        <div>
            <h1 class="fw-bold mb-1 d-flex align-items-center gap-2" style="font-size: 1.75rem; color: var(--color-text-main);">
                <i class="bi bi-map-fill" style="color: var(--color-accent);"></i> Raw GPX Route Inspection
            </h1>
            <div class="d-flex align-items-center gap-2" style="font-size: 0.85rem; color: var(--color-text-muted);">
                <span><strong class="text-dark">Batch:</strong> @Model.BatchId</span>
                <span>•</span>
                <span>@Model.Files.Count survey log@(Model.Files.Count != 1 ? "s" : "") parsed</span>
            </div>
        </div>

        <a id="btnBack" href="/gpx/upload" class="btn-action">
            <i class="bi bi-arrow-left"></i> Back to Packages
        </a>
    </div>

    <div class="preview-body-grid pt-2">

        <div class="panel-left">
            <div class="panel-left-header">
                <i class="bi bi-files me-2"></i>Parsed Package Logs
            </div>

            <form id="processForm" method="post" action="/gpx/process-selected" class="d-flex flex-column flex-grow-1" style="min-height: 0;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="batchId" value="@Model.BatchId" />

                <div class="file-list-scroll">
                    @foreach (var f in Model.Files)
                    {
                        var safeId = "chk_" + Guid.NewGuid().ToString("N");
                        <label class="file-toggle-row" for="@safeId">
                            <input class="form-check-input file-check"
                                   type="checkbox"
                                   value="@f.FileName"
                                   id="@safeId"
                                   name="selectedFiles"
                                   checked />
                            <span class="file-toggle-name">@f.FileName</span>
                            <span class="file-toggle-pts">@(f.Points?.Count ?? 0)</span>
                        </label>
                    }
                </div>

                <div class="panel-left-actions mt-auto">
                    <button id="btnClean" type="submit" formaction="/gpx/cleaned-only-view" class="btn-ttds w-100 d-flex align-items-center justify-content-center gap-2">
                        <i class="bi bi-magic"></i> Run Algorithm (Clean Selected)
                    </button>
                </div>
            </form>
        </div>

        <div class="panel-right">
            <div id="map"></div>
            <div class="map-footer d-flex align-items-center gap-2">
                <i class="bi bi-info-circle-fill" style="color: var(--color-primary);"></i>
                <span>Showing uncleaned, raw GPS telemetry. Toggle layers on the left to include/exclude routes.</span>
            </div>
        </div>

    </div>
</div>

<script>
    const map = L.map('map');
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 20,
        attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    // Re-measure canvas after flex container finishes calculating
    setTimeout(() => { map.invalidateSize(); }, 250);

    const vm = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));
    const files = vm.files ?? vm.Files ?? [];

    function toLatLngArray(pts) {
        return (pts || []).map(p => {
            if (Array.isArray(p) && p.length >= 2) return [p[0], p[1]];
            const lat = (p.lat ?? p.Lat ?? p.latitude ?? p.Latitude ?? p.item1 ?? p.Item1);
            const lon = (p.lon ?? p.Lon ?? p.longitude ?? p.Longitude ?? p.item2 ?? p.Item2);
            return (lat != null && lon != null) ? [lat, lon] : null;
        }).filter(Boolean);
    }

    const layers = {};
    const bounds = L.latLngBounds();

    files.forEach(f => {
        const name = f.fileName ?? f.FileName ?? '';
        const pts = f.points ?? f.Points ?? [];
        const latlngs = toLatLngArray(pts);
        if (latlngs.length >= 2) {
            const layer = L.polyline(latlngs, { weight: 3.5, color: '#1d4470', opacity: 0.85 }).addTo(map);
            layers[name] = layer;
            latlngs.forEach(ll => bounds.extend(ll));
        }
    });

    if (bounds.isValid()) map.fitBounds(bounds, { padding: [30, 30] });
    else map.setView([12.8797, 121.7740], 6);

    document.querySelectorAll('.file-check').forEach(cb => {
        cb.addEventListener('change', e => {
            const key = e.target.value || '';
            const layer = layers[key];
            if (!layer) return;
            if (e.target.checked) layer.addTo(map);
            else map.removeLayer(layer);
        });
    });

    // Modal Trigger Logic
    (function () {
        const form = document.getElementById("processForm");
        const overlay = document.getElementById("loadingOverlay");
        const btnClean = document.getElementById("btnClean");
        const btnBack = document.getElementById("btnBack");

        if (!form || !overlay) return;

        form.addEventListener("submit", function () {
            overlay.style.display = "flex";
            if (btnClean) btnClean.disabled = true;
            if (btnBack) btnBack.classList.add("disabled-clicks");
        });
    })();
</script>