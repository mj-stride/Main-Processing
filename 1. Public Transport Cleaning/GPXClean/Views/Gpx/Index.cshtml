@{
    ViewData["Title"] = "GPX Clean – Public Utility Vehicle";
    ViewData["Section"] = "Clean and Snap (PUV)";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<style>
    .upload-view-wrapper {
        max-width: 860px;
        margin: 0 auto;
        width: 100%;
    }

    #loadingOverlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(3px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }

    #loadingCard {
        width: min(520px, 92vw);
        background: var(--color-surface);
        border-radius: 16px;
        padding: 28px 24px;
        box-shadow: var(--shadow-lg);
        border: 1px solid var(--color-border);
        text-align: center;
    }

    #loadingTitle {
        font-weight: 700;
        margin-bottom: 8px;
        font-size: 1.2rem;
        color: var(--color-text-main);
    }

    #loadingMsg {
        font-size: 0.92rem;
        color: var(--color-text-muted);
        margin-bottom: 20px;
    }

    .progress {
        height: 10px;
        border-radius: 999px;
        overflow: hidden;
        background: var(--color-border);
        margin-bottom: 12px;
    }

    .progress-bar {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, var(--color-primary), #3b82f6);
        transition: width 0.35s ease;
    }

    .drop-zone {
        border: 2px dashed #94a3b8;
        border-radius: 12px;
        background: var(--color-bg);
        padding: 3rem 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .drop-zone:hover {
            background: #f1f5f9;
            border-color: var(--color-primary);
        }

        .drop-zone i {
            font-size: 3.4rem;
            color: var(--color-accent);
            line-height: 1;
            transition: transform 0.2s ease;
        }

        .drop-zone:hover i {
            transform: scale(1.08);
        }

        .drop-zone p {
            font-size: 0.95rem;
            color: var(--color-text-main);
            font-weight: 600;
            margin: 0;
            text-align: center;
        }

        .drop-zone .drop-zone-subtext {
            font-size: 0.82rem;
            color: var(--color-text-muted);
            text-align: center;
        }

    #zipFiles {
        display: none;
    }

    .file-list-header {
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--color-primary);
        margin-bottom: 0.6rem;
    }

    .file-list-scroll {
        max-height: 220px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding-right: 4px;
    }

        .file-list-scroll::-webkit-scrollbar {
            width: 6px;
        }

        .file-list-scroll::-webkit-scrollbar-track {
            background: var(--color-bg);
            border-radius: 999px;
        }

        .file-list-scroll::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 999px;
        }

    .file-item {
        display: flex;
        align-items: center;
        gap: 12px;
        background: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        padding: 10px 14px;
        transition: border-color 0.15s ease;
    }

        .file-item:hover {
            border-color: #cbd5e1;
        }

        .file-item i {
            color: var(--color-accent);
            font-size: 1.2rem;
            flex-shrink: 0;
        }

    .file-item-name {
        font-size: 0.85rem;
        color: var(--color-text-main);
        font-weight: 500;
        word-break: break-all;
        flex: 1;
    }

    .file-item-size {
        font-size: 0.75rem;
        color: var(--color-text-muted);
        background: #e2e8f0;
        padding: 2px 8px;
        border-radius: 999px;
        font-weight: 600;
        flex-shrink: 0;
    }
</style>

<div id="loadingOverlay">
    <div id="loadingCard">
        <div class="spinner-border mb-3" role="status" style="color: var(--color-primary); width: 2.2rem; height: 2.2rem;">
            <span class="visually-hidden">Loading...</span>
        </div>
        <div id="loadingTitle">Preparing preview…</div>
        <div id="loadingMsg">Uploading ZIP(s) and extracting GPX points. Please wait.</div>
        <div class="progress">
            <div id="progressBar" class="progress-bar"></div>
        </div>
        <div class="small mt-2" style="color: var(--color-text-muted);">Don't refresh or go back while processing.</div>
    </div>
</div>

<div class="upload-view-wrapper py-4 px-2">

    <div class="mb-4 d-flex align-items-center gap-3 pb-3 border-bottom" style="border-color: var(--color-border) !important;">
        <div class="p-2 rounded-3 d-flex align-items-center justify-content-center" style="background-color: var(--color-accent); color: #ffffff;">
            <i class="bi bi-bus-front-fill" style="font-size: 2.2rem; line-height: 1;"></i>
        </div>
        <div>
            <h1 class="fw-bold mb-1" style="font-size: 1.85rem; color: var(--color-text-main);">GPX Clean</h1>
            <p class="mb-0" style="color: var(--color-text-muted); font-size: 0.95rem;">Public Utility Vehicle Data Processor</p>
        </div>
    </div>

    <div class="premium-card p-4 p-md-5">
        <h5 class="fw-bold mb-4" style="color: var(--color-text-main); font-size: 1.1rem;">
            <i class="bi bi-cloud-upload me-2" style="color: var(--color-accent);"></i>Upload Survey Packages
        </h5>

        <form id="uploadForm"
              method="post"
              action="/gpx/preview-map"
              enctype="multipart/form-data"
              onsubmit="return startUpload();">

            @Html.AntiForgeryToken()

            <input type="file"
                   name="files"
                   id="zipFiles"
                   multiple
                   accept=".zip"
                   onchange="updateFileLabel(this)" />

            <div class="drop-zone" onclick="document.getElementById('zipFiles').click()">
                <i class="bi bi-file-earmark-zip-fill mb-1"></i>
                <p>Drag and drop packages here or click to browse</p>
                <span class="drop-zone-subtext">Accepts multiple .zip archives containing .gpx survey logs</span>
            </div>

            <div id="fileLabel"></div>

            <div id="uploadError" class="alert alert-danger mt-3 py-2 px-3" style="display:none; font-size:0.875rem; border-radius: 8px;">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>Please select at least one .zip package before continuing.
            </div>

            <div class="d-flex justify-content-end mt-4 pt-2">
                <button id="btnPreview" type="submit" class="btn-ttds d-inline-flex align-items-center gap-2">
                    <i class="bi bi-map-fill"></i> Preview on Map
                </button>
            </div>

        </form>
    </div>
</div>

<script>
    let fakeProgressTimer = null;

    function updateFileLabel(input) {
        const label = document.getElementById('fileLabel');
        if (!label) return;

        if (input.files && input.files.length > 0) {
            const err = document.getElementById('uploadError');
            if (err) err.style.display = 'none';
            const files = Array.from(input.files);
            const items = files.map(f => {
                const kb = (f.size / 1024).toFixed(1);
                return `
                    <div class="file-item">
                        <i class="bi bi-file-earmark-zip-fill"></i>
                        <span class="file-item-name">${f.name}</span>
                        <span class="file-item-size">${kb} KB</span>
                    </div>
                `;
            }).join('');

            label.innerHTML = `
                <div style="margin-top: 1.5rem;">
                    <p class="file-list-header">
                        <i class="bi bi-folder2-open me-1"></i>
                        ${files.length} package${files.length > 1 ? 's' : ''} ready for processing
                    </p>
                    <div class="file-list-scroll">${items}</div>
                </div>
            `;
        } else {
            label.innerHTML = '';
        }
    }

    function startFakeProgress() {
        const bar = document.getElementById("progressBar");
        if (!bar) return;
        bar.style.width = "0%";
        let progress = 0;
        if (fakeProgressTimer) clearInterval(fakeProgressTimer);
        fakeProgressTimer = setInterval(() => {
            if (progress < 60)      progress += (Math.random() * 10) + 6;
            else if (progress < 85) progress += (Math.random() * 6) + 2;
            else if (progress < 95) progress += (Math.random() * 2) + 0.5;
            else                    progress = 95;
            bar.style.width = Math.min(progress, 95).toFixed(0) + "%";
        }, 350);
    }

    function startUpload() {
        const overlay   = document.getElementById("loadingOverlay");
        const fileInput = document.getElementById("zipFiles");
        const btn       = document.getElementById("btnPreview");
        const err       = document.getElementById("uploadError");

        if (!fileInput || !fileInput.files || fileInput.files.length === 0) {
            if (err) err.style.display = 'block';
            return false;
        }

        if (err) err.style.display = 'none';
        overlay.style.display = "flex";
        if (btn) btn.disabled = true;
        startFakeProgress();
        return true;
    }

    document.addEventListener('DOMContentLoaded', () => {
        const zone  = document.querySelector('.drop-zone');
        const input = document.getElementById('zipFiles');
        if (!zone || !input) return;

        zone.addEventListener('dragover', e => {
            e.preventDefault();
            zone.style.borderColor = 'var(--color-primary)';
            zone.style.background = '#e2e8f0';
        });
        zone.addEventListener('dragleave', () => {
            zone.style.borderColor = '#94a3b8';
            zone.style.background = 'var(--color-bg)';
        });
        zone.addEventListener('drop', e => {
            e.preventDefault();
            zone.style.borderColor = '#94a3b8';
            zone.style.background = 'var(--color-bg)';
            input.files = e.dataTransfer.files;
            updateFileLabel(input);
        });
    });
</script>