@{
    ViewData["Title"] = "GPX Clean – Public Utility Vehicle";
    ViewData["Section"] = "Clean and Snap (PUV)";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<style>
    /* Root fallbacks in case master layout misses them */
    :root {
        --color-surface-default: #ffffff;
        --color-border-default: #e2e8f0;
        --color-text-main-default: #0f172a;
        --color-text-muted-default: #64748b;
        --color-primary-default: #2563eb;
        --color-accent-default: #0284c7;
        --color-bg-default: #f8fafc;
    }

    .upload-view-wrapper {
        max-width: 860px;
        margin: 0 auto;
        width: 100%;
    }

    #loadingOverlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.75);
        backdrop-filter: blur(4px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }

    #loadingCard {
        width: min(520px, 92vw);
        background: var(--color-surface, var(--color-surface-default));
        border-radius: 16px;
        padding: 32px 24px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
        border: 1px solid var(--color-border, var(--color-border-default));
        text-align: center;
    }

    /* Guaranteed Native CSS Spinner Fallback */
    .custom-spinner {
        width: 2.5rem;
        height: 2.5rem;
        border: 0.3rem solid #e2e8f0;
        border-top-color: var(--color-primary, var(--color-primary-default));
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto 1.25rem auto;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    #loadingTitle {
        font-weight: 700;
        margin-bottom: 8px;
        font-size: 1.25rem;
        color: var(--color-text-main, var(--color-text-main-default));
    }

    #loadingMsg {
        font-size: 0.92rem;
        color: var(--color-text-muted, var(--color-text-muted-default));
        margin-bottom: 20px;
    }

    .progress {
        height: 10px;
        border-radius: 999px;
        overflow: hidden;
        background: var(--color-border, var(--color-border-default));
        margin-bottom: 12px;
        width: 100%;
    }

    .progress-bar {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, var(--color-primary, var(--color-primary-default)), #3b82f6);
        transition: width 0.35s ease;
    }

    .drop-zone {
        border: 2px dashed #94a3b8;
        border-radius: 12px;
        background: var(--color-bg, var(--color-bg-default));
        padding: 3rem 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .drop-zone:hover {
            background: #f1f5f9;
            border-color: var(--color-primary, var(--color-primary-default));
        }

        .drop-zone i {
            font-size: 3.4rem;
            color: var(--color-accent, var(--color-accent-default));
            line-height: 1;
            transition: transform 0.2s ease;
        }

        .drop-zone:hover i {
            transform: scale(1.08);
        }

        .drop-zone p {
            font-size: 0.95rem;
            color: var(--color-text-main, var(--color-text-main-default));
            font-weight: 600;
            margin: 0;
            text-align: center;
        }

        .drop-zone .drop-zone-subtext {
            font-size: 0.82rem;
            color: var(--color-text-muted, var(--color-text-muted-default));
            text-align: center;
        }

    #zipFiles {
        display: none;
    }

    .file-list-header {
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--color-primary, var(--color-primary-default));
        margin-bottom: 0.6rem;
    }

    .file-list-scroll {
        max-height: 220px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding-right: 4px;
    }

    .file-item {
        display: flex;
        align-items: center;
        gap: 12px;
        background: var(--color-bg, var(--color-bg-default));
        border: 1px solid var(--color-border, var(--color-border-default));
        border-radius: 8px;
        padding: 10px 14px;
    }

        .file-item i {
            color: var(--color-accent, var(--color-accent-default));
            font-size: 1.2rem;
        }

    .file-item-name {
        font-size: 0.85rem;
        color: var(--color-text-main, var(--color-text-main-default));
        font-weight: 500;
        word-break: break-all;
        flex: 1;
        text-align: left;
    }

    .file-item-size {
        font-size: 0.75rem;
        color: var(--color-text-muted, var(--color-text-muted-default));
        background: #e2e8f0;
        padding: 2px 8px;
        border-radius: 999px;
        font-weight: 600;
    }
</style>

<div id="loadingOverlay">
    <div id="loadingCard">
        <div class="custom-spinner" role="status"></div>
        <div id="loadingTitle">Preparing preview…</div>
        <div id="loadingMsg">Uploading ZIP(s) and extracting GPX points. Please wait.</div>
        <div id="progressPercent" style="font-size: 0.85rem; font-weight: 700; color: var(--color-primary, #2563eb); margin-bottom: 6px; transition: all 0.3s ease;">0%</div>
        <div class="progress">
            <div id="progressBar" class="progress-bar"></div>
        </div>
        <div class="small mt-2" style="color: var(--color-text-muted, #64748b);">Don't refresh or go back while processing.</div>
    </div>
</div>

<div class="upload-view-wrapper py-4 px-2">
    <div class="mb-4 d-flex align-items-center gap-3 pb-3 border-bottom" style="border-color: var(--color-border, #e2e8f0) !important;">
        <div class="p-2 rounded-3 d-flex align-items-center justify-content-center" style="background-color: var(--color-accent, #0284c7); color: #ffffff;">
            <i class="bi bi-bus-front-fill" style="font-size: 2.2rem; line-height: 1;"></i>
        </div>
        <div>
            <h1 class="fw-bold mb-1" style="font-size: 1.85rem; color: var(--color-text-main, #0f172a);">GPX Clean</h1>
            <p class="mb-0" style="color: var(--color-text-muted, #64748b); font-size: 0.95rem;">Public Utility Vehicle Data Processor</p>
        </div>
    </div>

    <div class="premium-card p-4 p-md-5">
        <h5 class="fw-bold mb-4" style="color: var(--color-text-main, #0f172a); font-size: 1.1rem;">
            <i class="bi bi-cloud-upload me-2" style="color: var(--color-accent, #0284c7);"></i>Upload Survey Packages
        </h5>

        <form id="uploadForm" method="post" enctype="multipart/form-data" onsubmit="handleAsyncUpload(event)">
            @Html.AntiForgeryToken()

            <input type="file" name="files" id="zipFiles" multiple accept=".zip" onchange="updateFileLabel(this)" />

            <div class="drop-zone" onclick="document.getElementById('zipFiles').click()">
                <i class="bi bi-file-earmark-zip-fill mb-1"></i>
                <p>Drag and drop packages here or click to browse</p>
                <span class="drop-zone-subtext">Accepts multiple .zip archives containing .gpx survey logs</span>
            </div>

            <div id="fileLabel"></div>

            <div id="uploadError" class="alert alert-danger mt-3 py-2 px-3" style="display:none; font-size:0.875rem; border-radius: 8px;">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>Please select at least one .zip package before continuing.
            </div>

            <div class="d-flex justify-content-end mt-4 pt-2">
                <button id="btnPreview" type="submit" class="btn-ttds d-inline-flex align-items-center gap-2">
                    <i class="bi bi-map-fill"></i> Preview on Map
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    let eventSource = null;

    function updateFileLabel(input) {
        const label = document.getElementById('fileLabel');
        const err = document.getElementById('uploadError');
        if (!label) return;

        if (input.files && input.files.length > 0) {
            if (err) err.style.display = 'none';
            const files = Array.from(input.files);

            const items = files.map(f => `
                <div class="file-item">
                    <i class="bi bi-file-earmark-zip-fill"></i>
                    <span class="file-item-name">${f.name}</span>
                    <span class="file-item-size">${(f.size / 1024).toFixed(1)} KB</span>
                </div>`).join('');

            label.innerHTML = `
                <div style="margin-top: 1.5rem;">
                    <p class="file-list-header"><i class="bi bi-folder2-open me-1"></i>${files.length} package${files.length > 1 ? 's' : ''} ready</p>
                    <div class="file-list-scroll">${items}</div>
                </div>`;
        } else {
            label.innerHTML = '';
        }
    }

    function setProgress(pct, title, msg) {
        const bar = document.getElementById("progressBar");
        const t = document.getElementById("loadingTitle");
        const m = document.getElementById("loadingMsg");
        const percent = document.getElementById("progressPercent");

        if (bar) bar.style.width = pct + "%";
        if (t && title) t.textContent = title;
        if (m && msg) m.textContent = msg;
        if (percent) percent.textContent = pct + "%";
    }

    async function handleAsyncUpload(event) {
        event.preventDefault(); // CRITICAL: Stops synchronous browser POST

        const overlay = document.getElementById("loadingOverlay");
        const fileInput = document.getElementById("zipFiles");
        const btn = document.getElementById("btnPreview");
        const err = document.getElementById("uploadError");
        const form = document.getElementById("uploadForm");

        if (!fileInput || !fileInput.files || fileInput.files.length === 0) {
            if (err) err.style.display = 'block';
            return;
        }

        if (err) err.style.display = 'none';
        overlay.style.display = "flex";
        if (btn) btn.disabled = true;

        const sessionId = crypto.randomUUID();
        const targetUrl = `/gpx/preview-map?sessionId=${sessionId}`;

        setProgress(5, "Connecting…", "Establishing secure stream with server.");

        // 1. Open SSE stream first
        eventSource = new EventSource(`/gpx/progress/${sessionId}`);

        eventSource.onmessage = (e) => {
            const data = JSON.parse(e.data);
            setProgress(data.percent, data.title, data.message);

            if (data.redirect) {
                eventSource.close();
                window.location.href = data.redirect;
            }

            if (data.error) {
                eventSource.close();
                overlay.style.display = 'none';
                if (btn) btn.disabled = false;
                alert("Processing Error: " + data.error);
            }
        };

        eventSource.onerror = () => {
            eventSource.close();
        };

        // 2. Dispatch payload asynchronously in background
        try {
            const formData = new FormData(form);
            const response = await fetch(targetUrl, {
                method: 'POST',
                body: formData
            });

            if (!response.ok) {
                throw new Error(`Server returned HTTP ${response.status}`);
            }
        } catch (error) {
            if (eventSource) eventSource.close();
            overlay.style.display = 'none';
            if (btn) btn.disabled = false;
            alert("Upload Failed: " + error.message);
        }
    }

    // Drag and Drop Initialization
    document.addEventListener('DOMContentLoaded', () => {
        const zone = document.querySelector('.drop-zone');
        const input = document.getElementById('zipFiles');
        if (!zone || !input) return;

        zone.addEventListener('dragover', e => {
            e.preventDefault();
            zone.style.borderColor = 'var(--color-primary, #2563eb)';
            zone.style.background = '#f1f5f9';
        });

        zone.addEventListener('dragleave', () => {
            zone.style.borderColor = '#94a3b8';
            zone.style.background = 'var(--color-bg, #f8fafc)';
        });

        zone.addEventListener('drop', e => {
            e.preventDefault();
            zone.style.borderColor = '#94a3b8';
            zone.style.background = 'var(--color-bg, #f8fafc)';
            input.files = e.dataTransfer.files;
            updateFileLabel(input);
        });
    });
</script>