<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} - GPXClean" : "GPXClean")</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="https://localhost:7171/css/shared.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        html, body {
            margin: 0;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .page-content {
            flex: 1;
            display: flex;
            flex-direction: column;
        }
    </style>
</head>
<body>

    <header class="topbar">
        <span class="title">@(ViewData["Section"] ?? "Clean and Snap (Private)")</span>

        <a href="https://localhost:7171/" class="btn-topbar">
            <i class="bi bi-grid-1x2-fill"></i> Dashboard
        </a>
    </header>

    <div class="page-content">
        <main role="main" class="flex-grow-1 d-flex flex-column w-100 pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        &copy; @DateTime.Now.Year Travel Time and Delay Survey
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>