@{
    Layout = null;

    var filename = ViewBag.Filename as string;
    var originalJson = ViewBag.OriginalPointsJson ?? "[]";
    var snappedJson = ViewBag.SnappedPointsJson ?? "[]";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@filename</title>

    <link rel="stylesheet"
          href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <style>
        html, body {
            width: 100%;
            height: 100%;
            margin: 0;
            padding: 0;
        }

        #map {
            width: 100%;
            height: 100%;
        }
    </style>
</head>

<body>
    <div id="map"></div>

    <script>
        const originalPoints = @Html.Raw(originalJson);
        const snappedPoints = @Html.Raw(snappedJson);

        if (!snappedPoints || snappedPoints.length === 0) {
            document.body.innerHTML =
                "<div style='padding:20px'>No map data found.</div>";
        } else {

            let sumLat = 0;
            let sumLon = 0;

            snappedPoints.forEach(p => {
                sumLat += p[0];
                sumLon += p[1];
            });

            const centerLat = sumLat / snappedPoints.length;
            const centerLon = sumLon / snappedPoints.length;

            const map = L.map("map", {
                zoomControl: true
            }).setView([centerLat, centerLon], 15);

            L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {
                maxZoom: 19,
                attribution: "&copy; OpenStreetMap contributors"
            }).addTo(map);

            if (originalPoints.length > 0) {
                L.polyline(originalPoints, {
                    color: "red",
                    weight: 4,
                    opacity: 0.8
                }).addTo(map);
            }

            L.polyline(snappedPoints, {
                color: "blue",
                weight: 4,
                opacity: 0.9
            }).addTo(map);

            L.circleMarker(snappedPoints[0], {
                radius: 7,
                color: "green",
                fillColor: "green",
                fillOpacity: 1
            }).addTo(map);

            L.circleMarker(snappedPoints[snappedPoints.length - 1], {
                radius: 7,
                color: "red",
                fillColor: "red",
                fillOpacity: 1
            }).addTo(map);

            const bounds = [];

            originalPoints.forEach(p => bounds.push(p));
            snappedPoints.forEach(p => bounds.push(p));

            map.fitBounds(bounds);
        }
    </script>

</body>
</html>