@{
    ViewData["Title"] = "Survey Data Process and Clean";
    ViewData["Section"] = "Clean and Snap (Private Transport)";
}

<style>
    /* Bounding limits to prevent ultra-wide container stretching */
    .upload-view-wrapper {
        max-width: 1060px;
        margin: 0 auto;
        width: 100%;
    }

    /* Dashed Drop Zones extending shared.css tokens */
    .drop-zone {
        border: 2px dashed #94a3b8; /* Muted Slate */
        border-radius: 12px;
        background: var(--color-bg);
        padding: 2.5rem 1.25rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        cursor: pointer;
        transition: all 0.2s ease;
        flex: 1; /* Forces equal vertical stretch across both columns */
    }

        .drop-zone:hover, .drop-zone.drag-over {
            background: #f1f5f9;
            border-color: var(--color-primary);
        }

        .drop-zone i {
            font-size: 3.2rem;
            color: var(--color-accent); /* Orange accent */
            line-height: 1;
            transition: transform 0.2s ease;
        }

        .drop-zone:hover i {
            transform: scale(1.08);
        }

        .drop-zone p {
            font-size: 0.9rem;
            color: var(--color-text-main);
            margin: 0;
            text-align: center;
        }

        .drop-zone .drop-label {
            font-size: 0.78rem;
            color: var(--color-text-muted);
            margin: 0;
            text-align: center;
        }

    /* Section Headings */
    .section-label {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--color-text-main);
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* Scoped File List Scrollbars */
    .file-list-header {
        font-size: 0.82rem;
        font-weight: 700;
        color: var(--color-primary);
        margin-bottom: 0.5rem;
    }

    .file-list-scroll {
        max-height: 170px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding-right: 4px;
    }

        .file-list-scroll::-webkit-scrollbar {
            width: 6px;
        }

        .file-list-scroll::-webkit-scrollbar-track {
            background: var(--color-bg);
            border-radius: 999px;
        }

        .file-list-scroll::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 999px;
        }

    .file-item {
        display: flex;
        align-items: center;
        gap: 10px;
        background: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        padding: 8px 12px;
    }

        .file-item i {
            color: var(--color-accent);
            font-size: 1.15rem;
            flex-shrink: 0;
        }

    .file-item-name {
        font-size: 0.82rem;
        color: var(--color-text-main);
        font-weight: 500;
        word-break: break-all;
        flex: 1;
    }

    .file-item-size {
        font-size: 0.75rem;
        color: var(--color-text-muted);
        background: #e2e8f0;
        padding: 2px 8px;
        border-radius: 999px;
        font-weight: 600;
        flex-shrink: 0;
    }

    .upload-error {
        display: none;
        font-size: 0.82rem;
        color: #dc2626;
        margin-top: 0.5rem;
        font-weight: 500;
    }

    /* Processing Modal */
    #loadingOverlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(3px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }

    #loadingCard {
        width: min(520px, 92vw);
        background: var(--color-surface);
        border-radius: 16px;
        padding: 28px 24px;
        box-shadow: var(--shadow-lg);
        border: 1px solid var(--color-border);
        text-align: center;
    }

    #loadingTitle {
        font-weight: 700;
        margin-bottom: 8px;
        font-size: 1.2rem;
        color: var(--color-text-main);
    }

    #loadingMsg {
        font-size: 0.92rem;
        color: var(--color-text-muted);
        margin-bottom: 20px;
    }

    .progress {
        height: 10px;
        border-radius: 999px;
        overflow: hidden;
        background: var(--color-border);
        margin-bottom: 12px;
    }

    .progress-bar {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, var(--color-primary), #3b82f6);
        transition: width 0.35s ease;
    }

    /* Error Toast */
    #errorToast {
        position: fixed;
        top: 24px;
        right: 24px;
        background-color: #dc2626;
        color: #ffffff;
        padding: 14px 20px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.9rem;
        display: none;
        z-index: 10000;
        box-shadow: var(--shadow-lg);
        min-width: 280px;
        border: 1px solid #b91c1c;
    }
</style>

<div id="loadingOverlay">
    <div id="loadingCard">
        <div class="spinner-border mb-3" role="status" style="color: var(--color-primary); width: 2.2rem; height: 2.2rem;">
            <span class="visually-hidden">Loading...</span>
        </div>
        <div id="loadingTitle">Processing survey logs…</div>
        <div id="loadingMsg">Uploading packages and parsing private vehicle telemetry. Please wait.</div>
        <div class="progress">
            <div id="progressBar" class="progress-bar"></div>
        </div>
        <div class="small mt-2" style="color: var(--color-text-muted);">Don't refresh or navigate away while processing.</div>
    </div>
</div>

<div id="errorToast">
    <i class="bi bi-exclamation-triangle-fill me-2"></i>
    <span id="errorToastMsg"></span>
</div>

<div class="upload-view-wrapper py-4 px-2">

    <div class="mb-4 d-flex align-items-center gap-3 pb-3 border-bottom" style="border-color: var(--color-border) !important;">
        <div class="p-2 rounded-3 d-flex align-items-center justify-content-center" style="background-color: var(--color-accent); color: #ffffff;">
            <i class="bi bi-car-front-fill" style="font-size: 2.2rem; line-height: 1;"></i>
        </div>
        <div>
            <h1 class="fw-bold mb-1" style="font-size: 1.85rem; color: var(--color-text-main);">GPX Clean</h1>
            <p class="mb-0" style="color: var(--color-text-muted); font-size: 0.95rem;">Private Transport Data Processor</p>
        </div>
    </div>

    <div class="premium-card p-4 p-md-5 mb-4">

        <form id="uploadForm"
              asp-controller="SurveyData"
              asp-action="Index"
              method="post"
              enctype="multipart/form-data"
              onsubmit="return handleSubmit(event);">

            @Html.AntiForgeryToken()

            <input type="file" id="csvFile" name="csvFile" accept=".csv" style="display:none;" onchange="updateFileLabel(this, 'csvLabel', 'csv')" />
            <input type="file" id="zipFiles" name="zipFiles" accept=".zip" multiple style="display:none;" onchange="updateFileLabel(this, 'zipLabel', 'zip')" />

            <div class="row g-4">

                <div class="col-md-6 d-flex flex-column">
                    <div class="section-label">
                        <span class="badge rounded-pill me-2" style="background-color: var(--color-primary); color: #fff;">1</span> Upload Geotab CSV Log
                    </div>

                    <div class="drop-zone" id="csvZone" onclick="document.getElementById('csvFile').click()">
                        <i class="bi bi-filetype-csv mb-1"></i>
                        <p>Drag and drop or browse for a <b>.csv</b> file</p>
                        <p class="drop-label">Exported Geotab CSV containing trip logs</p>
                    </div>

                    <div id="csvLabel"></div>
                    <div id="csvError" class="upload-error">
                        <i class="bi bi-exclamation-circle-fill me-1"></i> Please select a valid Geotab .csv file.
                    </div>
                </div>

                <div class="col-md-6 d-flex flex-column">
                    <div class="section-label">
                        <span class="badge rounded-pill me-2" style="background-color: var(--color-primary); color: #fff;">2</span> Upload Survey ZIP Archives
                    </div>

                    <div class="drop-zone" id="zipZone" onclick="document.getElementById('zipFiles').click()">
                        <i class="bi bi-file-earmark-zip-fill mb-1"></i>
                        <p>Drag and drop or browse for <b>.zip</b> packages</p>
                        <p class="drop-label">Accepts multiple survey log archives</p>
                    </div>

                    <div id="zipLabel"></div>
                    <div id="zipError" class="upload-error">
                        <i class="bi bi-exclamation-circle-fill me-1"></i> Please select at least one .zip package.
                    </div>
                </div>

            </div>

            <hr class="my-4" style="border-color: var(--color-border) !important;" />

            <div class="d-flex flex-column flex-sm-row align-items-center justify-content-between gap-3">
                <span class="text-muted small">
                    <i class="bi bi-info-circle-fill me-1" style="color: var(--color-primary);"></i> Output generates a distinct CSV batch per uploaded archive.
                </span>

                <button id="btnProcess" type="submit" class="btn-ttds px-5 py-2 w-auto ms-sm-auto d-inline-flex align-items-center gap-2">
                    <i class="bi bi-cpu-fill"></i> Process Files
                </button>
            </div>

        </form>
    </div>
</div>

<script>
    let fakeProgressTimer = null;

    async function handleSubmit(e) {
        e.preventDefault();

        const csvInput = document.getElementById("csvFile");
        const zipInput = document.getElementById("zipFiles");
        const csvErr   = document.getElementById("csvError");
        const zipErr   = document.getElementById("zipError");

        let valid = true;

        if (!csvInput || !csvInput.files || csvInput.files.length === 0) {
            if (csvErr) csvErr.style.display = "block";
            valid = false;
        }

        if (!zipInput || !zipInput.files || zipInput.files.length === 0) {
            if (zipErr) zipErr.style.display = "block";
            valid = false;
        }

        if (!valid) return false;

        const form = document.getElementById("uploadForm");
        const formData = new FormData(form);
        const overlay = document.getElementById("loadingOverlay");
        const btn = document.getElementById("btnProcess");

        if (overlay) overlay.style.display = "flex";
        if (btn) btn.disabled = true;

        startFakeProgress();

        try {
            const res = await fetch(form.action, {
                method: "POST",
                body: formData
            });

            const result = await res.json();

            if (overlay) overlay.style.display = "none";
            if (btn) btn.disabled = false;

            if (!result.success) {
                showError(result.message || "Processing failed during data extraction.");
                return;
            }

            window.location.href = result.redirect;

        } catch (err) {
            if (overlay) overlay.style.display = "none";
            if (btn) btn.disabled = false;
            showError("Network connection lost while communicating with the extraction engine.");
        }
    }

    function showError(message) {
        const toast = document.getElementById("errorToast");
        const msg = document.getElementById("errorToastMsg");
        if (!toast || !msg) return;

        msg.textContent = message;
        toast.style.display = "block";

        setTimeout(() => { toast.style.display = "none"; }, 4500);
    }

    function updateFileLabel(input, labelId, type) {
        const label = document.getElementById(labelId);
        if (!label) return;

        if (input.files && input.files.length > 0) {
            const files = Array.from(input.files);
            const icon = type === 'csv' ? 'bi-filetype-csv' : 'bi-file-earmark-zip-fill';

            const items = files.map(f => {
                const kb = (f.size / 1024).toFixed(1);
                return `
                    <div class="file-item">
                        <i class="bi ${icon}"></i>
                        <span class="file-item-name">${f.name}</span>
                        <span class="file-item-size">${kb} KB</span>
                    </div>`;
            }).join('');

            label.innerHTML = `
                <div class="mt-3">
                    <p class="file-list-header">
                        <i class="bi bi-folder2-open me-1"></i>
                        ${files.length} file${files.length > 1 ? 's' : ''} queued
                    </p>
                    <div class="file-list-scroll">${items}</div>
                </div>`;

            const errId = type === 'csv' ? 'csvError' : 'zipError';
            const err = document.getElementById(errId);
            if (err) err.style.display = 'none';
        } else {
            label.innerHTML = '';
        }
    }

    function startFakeProgress() {
        const bar = document.getElementById("progressBar");
        if (!bar) return;
        bar.style.width = "0%";
        let progress = 0;

        if (fakeProgressTimer) clearInterval(fakeProgressTimer);
        fakeProgressTimer = setInterval(() => {
            if (progress < 60)      progress += (Math.random() * 10) + 6;
            else if (progress < 85) progress += (Math.random() * 6) + 2;
            else if (progress < 95) progress += (Math.random() * 2) + 0.5;
            else                    progress = 95; // Capped to prevent snap-back glitch

            bar.style.width = Math.min(progress, 95).toFixed(0) + "%";
        }, 350);
    }

    function setupDropZone(zoneId, inputId, labelId, type) {
        const zone  = document.getElementById(zoneId);
        const input = document.getElementById(inputId);
        if (!zone || !input) return;

        zone.addEventListener('dragover', e => {
            e.preventDefault();
            zone.classList.add('drag-over');
        });

        zone.addEventListener('dragleave', () => {
            zone.classList.remove('drag-over');
        });

        zone.addEventListener('drop', e => {
            e.preventDefault();
            zone.classList.remove('drag-over');

            const dt = e.dataTransfer;
            const files = Array.from(dt.files).filter(f =>
                type === 'csv'
                    ? f.name.toLowerCase().endsWith('.csv')
                    : f.name.toLowerCase().endsWith('.zip')
            );

            if (!files.length) return;

            const dataTransfer = new DataTransfer();
            files.forEach(f => dataTransfer.items.add(f));
            input.files = dataTransfer.files;

            updateFileLabel(input, labelId, type);
        });
    }

    document.addEventListener('DOMContentLoaded', () => {
        setupDropZone('csvZone', 'csvFile', 'csvLabel', 'csv');
        setupDropZone('zipZone', 'zipFiles', 'zipLabel', 'zip');
    });
</script>