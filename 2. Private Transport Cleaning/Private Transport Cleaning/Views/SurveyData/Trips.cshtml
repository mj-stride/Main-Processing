@model List<PrivateTransportCleaning.Models.TripFile>

@{
    ViewData["Title"] = "Select Snapped Files";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

<style>
    body {
        background: #f8f9fa;
        padding: 20px;
    }

    .main-layout {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 20px;
        height: calc(100vh - 40px);
    }

    .side-panel {
        background: white;
        border: 1px solid #ddd;
        border-radius: 6px;
        padding: 15px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

        .side-panel h5 {
            font-weight: 700;
            margin-bottom: 10px;
        }

    .button-row {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-bottom: 12px;
    }

    .file-list {
        border: 1px solid #ddd;
        border-radius: 5px;
        padding: 8px;
        overflow-y: auto;
        flex: 1;
        background: #fff;
    }

    .file-item {
        display: flex;
        gap: 8px;
        margin-bottom: 12px;
        font-size: 13px;
    }

    .file-title {
        font-weight: 700;
        color: #000;
        word-break: break-word;
    }

    .file-meta {
        color: #555;
        line-height: 1.45;
        margin-top: 4px;
        word-break: break-word;
    }

    .map-panel {
        background: white;
        border: 1px solid #ddd;
        border-radius: 6px;
        padding: 15px;
        overflow: hidden;
    }

    iframe {
        width: 100%;
        height: 100%;
        min-height: 650px;
        border: 0;
        border-radius: 5px;
    }

    .download-btn {
        margin-top: 10px;
        width: 100%;
        font-weight: 600;
    }

    #map {
        width: 100%;
        height: 100%;
        min-height: 650px;
    }
</style>

<form method="post" action="/SurveyData/DownloadSelected">

    <div class="main-layout">

        <!-- LEFT PANEL -->
        <div class="side-panel">

            <h5>Trips (Cleaned)</h5>

            <div class="button-row">
                <button type="button" class="btn btn-primary btn-sm" onclick="selectAll()">Select All</button>
                <button type="button" class="btn btn-secondary btn-sm" onclick="deselectAll()">Deselect All</button>
                <button type="button" class="btn btn-warning btn-sm" onclick="toggleSelection()">Switch Selection</button>
            </div>

            <div class="file-list">

                @foreach (var item in Model)
                {
                    <div class="file-item">

                        <input type="checkbox" name="files" value="@item.FileName" class="file-checkbox" />

                        <div style="flex:1;">

                            <div class="file-title">
                                @item.FileName
                            </div>

                            <div class="file-meta">
                                Size: N/A<br />
                                CSV: @item.FileName
                            </div>

                            <button type="button"
                                    class="btn btn-outline-secondary btn-sm mt-1"
                                    onclick="loadTrip('@item.FileName')">
                                View Map
                            </button>

                            <a href="@item.DownloadUrl"
                               class="btn btn-outline-primary btn-sm mt-1">
                                Download
                            </a>

                        </div>

                    </div>
                }

            </div>

            <button type="submit" class="btn btn-success download-btn">
                Download CSV ZIP (Selected)
            </button>

        </div>

        <!-- RIGHT MAP PANEL -->
        <div class="map-panel">

            <div id="map"></div>

        </div>

    </div>

</form>

<script>
    function selectAll() {
        document.querySelectorAll('.file-checkbox')
            .forEach(cb => cb.checked = true);
    }

    function deselectAll() {
        document.querySelectorAll('.file-checkbox')
            .forEach(cb => cb.checked = false);
    }

    function toggleSelection() {
        document.querySelectorAll('.file-checkbox')
            .forEach(cb => cb.checked = !cb.checked);
    }
</script>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
    const map = L.map('map').setView([14.6, 121.0], 12);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    let currentLine = null;

    async function loadTrip(fileName) {

        const res = await fetch(`/SurveyData/GetTripData?file=${fileName}`);
        const data = await res.json();

        if (!data || data.length === 0) return;

        // remove old line
        if (currentLine) {
            map.removeLayer(currentLine);
        }

        currentLine = L.polyline(data, {
            color: '#3b82f6',
            weight: 4
        }).addTo(map);

        map.fitBounds(currentLine.getBounds());
    }

    // auto-load first file on page load
    document.addEventListener("DOMContentLoaded", () => {
        const firstBtn = document.querySelector("button[onclick^='loadTrip']");
        if (firstBtn) firstBtn.click();
    });
</script>