@model List<PrivateTransportCleaning.Models.TripFile>

@{
    Layout = null;
    ViewData["Title"] = "Trips (Cleaned)";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Trips (Cleaned)</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

    <style>

        body {
            background: #f8f9fa;
            padding: 20px;
            margin: 0;
            font-family: "Segoe UI", sans-serif;
        }

        .main-layout {
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: 20px;
            height: calc(100vh - 40px);
        }

        .side-panel {
            background: white;
            border: 1px solid #ddd;
            border-radius: 6px;
            padding: 15px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

            .side-panel h5 {
                font-weight: 700;
                margin-bottom: 10px;
            }

        .button-row {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            margin-bottom: 12px;
        }

        .file-list {
            border: 1px solid #ddd;
            border-radius: 5px;
            padding: 8px;
            overflow-y: auto;
            flex: 1;
            background: white;
        }

        .file-item {
            display: flex;
            gap: 8px;
            margin-bottom: 12px;
            font-size: 13px;
        }

        .file-title {
            font-weight: 700;
            color: black;
            word-break: break-word;
        }

        .file-meta {
            color: #555;
            line-height: 1.45;
            margin-top: 4px;
            word-break: break-word;
        }

        .download-btn {
            margin-top: 8px;
            width: 100%;
            font-weight: 600;
        }

        .map-panel {
            background: white;
            border: 1px solid #ddd;
            border-radius: 6px;
            padding: 15px;
            overflow: hidden;
        }

        iframe {
            width: 100%;
            height: 100%;
            min-height: 650px;
            border: 0;
            border-radius: 5px;
        }

    </style>
</head>
<body>

    <form asp-action="DownloadSelected" asp-controller="SurveyData" method="post">

        <div class="main-layout">

            <div class="side-panel">

                <h5>Trips (Cleaned)</h5>

                <div class="button-row">

                    <button type="button"
                            class="btn btn-primary btn-sm"
                            onclick="selectAll()">
                        Select All
                    </button>

                    <button type="button"
                            class="btn btn-secondary btn-sm"
                            onclick="deselectAll()">
                        Deselect All
                    </button>

                    <button type="button"
                            class="btn btn-warning btn-sm"
                            onclick="toggleSelection()">
                        Switch Selection
                    </button>

                </div>

                <div class="file-list">

                    @foreach (var file in Model)
                    {
                        <div class="file-item">

                            <input type="checkbox"
                                   class="file-checkbox"
                                   name="files"
                                   value="@file.FileName"
                                   checked />

                            <div>

                                <div class="file-title">
                                    @(file.FileName.Replace("_snapped.csv", ""))
                                </div>

                                <div class="file-meta">
                                    Size: @(Math.Round(file.FileSize / 1024.0, 2)) KB<br />
                                    CSV: @file.FileName
                                </div>

                                <a class="btn btn-outline-secondary btn-sm mt-1"
                                   target="mapFrame"
                                   href="@Url.Action("Preview", "SurveyData", new { file = file.FileName })">
                                    View Map
                                </a>

                                <a class="btn btn-outline-primary btn-sm mt-1"
                                   href="@Url.Action("Download", "SurveyData", new { file = file.FileName })">
                                    Download
                                </a>

                            </div>

                        </div>
                    }

                </div>

                <button type="submit"
                        class="btn btn-success download-btn">
                    Download CSV ZIP (Selected)
                </button>

            </div>

            <div class="map-panel">

                @if (Model.Any())
                {
                    <iframe name="mapFrame"
                            src="@Url.Action("Preview", "SurveyData", new { file = Model.First().FileName })">
                    </iframe>
                }
                else
                {
                    <div class="alert alert-warning">
                        No snapped files available.
                    </div>
                }

            </div>

        </div>

    </form>

    <script>

        function selectAll() {
            document.querySelectorAll('.file-checkbox')
                .forEach(cb => cb.checked = true);
        }

        function deselectAll() {
            document.querySelectorAll('.file-checkbox')
                .forEach(cb => cb.checked = false);
        }

        function toggleSelection() {
            document.querySelectorAll('.file-checkbox')
                .forEach(cb => cb.checked = !cb.checked);
        }

    </script>

</body>
</html>