@model List<PrivateTransportCleaning.Models.TripFile>

@{
    Layout = null;
    ViewData["Title"] = "Trips (Cleaned)";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
    html, body {
        height: 100%;
        margin: 0;
        overflow: hidden;
        font-family: "Segoe UI", sans-serif;
        background: #f4f6f9;
    }

    .topbar {
        position: sticky;
        top: 0;
        z-index: 999;
        background: #211d70;
        color: #eeeeee;
        padding: 14px 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 600;
    }

        .topbar a {
            background: #da471f;
            color: #ffffff;
            padding: 8px 18px;
            border-radius: 8px;
            text-decoration: none;
        }

    .page-header {
        padding: 14px 28px;
    }

    .page-title {
        font-size: 1.5rem;
        font-weight: 800;
        margin: 0;
    }

    .page-meta {
        font-size: 0.85rem;
        color: #666666;
    }

    .wrapper {
        display: grid;
        grid-template-columns: 340px 1fr;
        gap: 16px;
        height: calc(100vh - 140px);
        padding: 10px 28px 20px;
        box-sizing: border-box;
    }

    /* IMPORTANT FIX */
    .left-panel {
        background: #ffffff;
        border-radius: 14px;
        border: 1px solid #dddddd;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        min-height: 0;
        height: 100%;
    }

    .panel-header {
        padding: 14px;
        font-weight: 700;
        border-bottom: 1px solid #eeeeee;
        color: #1d4470;
        flex-shrink: 0;
    }

    .selection-controls {
        display: flex;
        gap: 6px;
        padding: 10px 14px;
        border-bottom: 1px solid #eeeeee;
        flex-wrap: wrap;
        flex-shrink: 0;
    }

    .btn-sel {
        font-size: 0.75rem;
        font-weight: 600;
        border-radius: 999px;
        padding: 4px 12px;
        border: 1.5px solid #1d4470;
        background: transparent;
        color: #1d4470;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

        .btn-sel:hover {
            background: #eef3ff;
        }

        .btn-sel.warning {
            border-color: #b57a00;
            color: #b57a00;
        }

            .btn-sel.warning:hover {
                background: #fdf3dc;
            }

    /* CRITICAL FIX: scroll works now */
    .file-list {
        flex: 1;
        min-height: 0;
        overflow-y: auto;
        padding: 12px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .file-card {
        display: flex;
        gap: 10px;
        padding: 10px;
        border-radius: 10px;
        background: #f3f6fb;
        border: 1px solid #d9e2f0;
    }

    .file-title {
        font-size: 0.85rem;
        font-weight: 700;
        color: #1d4470;
    }

    .file-meta {
        font-size: 0.75rem;
        color: #666666;
    }

    .btn-ttds {
        text-decoration: none;
        display: inline-block;
        padding: 4px 10px;
        font-size: 0.72rem;
        border-radius: 999px;
    }

    .outline {
        border: 1px solid #1d4470;
        color: #1d4470;
    }

    .secondary {
        border: 1px solid #bbbbbb;
        color: #555555;
    }

    /* FIXED FOOTER ALWAYS VISIBLE */
    .file-actions {
        padding: 12px;
        border-top: 1px solid #eeeeee;
        background: #ffffff;
        flex-shrink: 0;
    }

    .btn-main {
        width: 100%;
        background: #1d4470;
        color: #ffffff;
        border: none;
        padding: 10px;
        border-radius: 999px;
        font-weight: 600;
    }

    .right-panel {
        background: #ffffff;
        border-radius: 14px;
        border: 1px solid #dddddd;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

    #map {
        flex: 1;
        width: 100%;
        height: 100%;
    }

    .wrapper {
        height: calc(100vh - 140px);
        min-height: 0;
    }

    .left-panel {
        height: 100%;
        min-height: 0;
        display: flex;
        flex-direction: column;
    }

    form {
        display: flex;
        flex-direction: column;
        height: 100%;
        min-height: 0;
    }

    .file-list {
        flex: 1 1 auto;
        min-height: 0;
        overflow-y: auto !important;
    }

    .file-actions {
        flex-shrink: 0;
        position: sticky;
        bottom: 0;
        background: #ffffff;
        z-index: 5;
        border-top: 1px solid #eeeeee;
    }
</style>

<div class="topbar">
    <span>Clean and Snap (Private Transport)</span>
    <a href="/dashboard">Dashboard</a>
</div>

<div class="page-header">
    <h1 class="page-title">Cleaned Trips Only</h1>
    <div class="page-meta">
        <i class="bi bi-folder"></i> @Model.Count trips processed
    </div>
</div>

<div class="wrapper">

    <div class="left-panel">

        <div class="panel-header">Trips (Cleaned)</div>

        <div class="selection-controls">
            <button type="button" class="btn-sel" onclick="selectAll()">
                <i class="bi bi-check-all"></i> All
            </button>

            <button type="button" class="btn-sel" onclick="deselectAll()">
                <i class="bi bi-x-circle"></i> None
            </button>

            <button type="button" class="btn-sel warning" onclick="toggleAll()">
                <i class="bi bi-arrow-left-right"></i> Toggle
            </button>
        </div>

        <form method="post" asp-action="DownloadSelected">

            <div class="file-list">

                @foreach (var file in Model)
                {
                    <label class="file-card">
                        <input type="checkbox" name="files" value="@file.FileName" checked />

                        <div style="flex:1;">
                            <div class="file-title">
                                @(file.FileName != null
                                                            ? file.FileName.Replace("_snapped.csv", "").Replace(".csv", "")
                                                            : "Unknown")
                                                                    </div>

                            <div class="file-meta">
                                @(file.FileSize > 0
                                                            ? (file.FileSize / 1024.0).ToString("0.00") + " KB"
                                                            : "Unknown")
                        </div>

                            <div style="margin-top:6px; display:flex; gap:6px; flex-wrap:wrap;">
                                <a class="btn-ttds outline"
                                   href="javascript:void(0)"
                                   data-file="@file.FileName"
                                   onclick="loadTrip(this)">
                                    View Map
                                </a>

                                <a class="btn-ttds secondary"
                                   href="@file.DownloadUrl">
                                    Download
                                </a>
                            </div>
                        </div>
                    </label>
                                }

            </div>

            <div class="file-actions">
                <button class="btn-main" type="submit">
                    Download CSV ZIP
                </button>
            </div>

        </form>

    </div>

    <div class="right-panel">
        <div id="map"></div>
    </div>

</div>

<script>
    const map = L.map('map').setView([12.8797, 121.7740], 6);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 20
    }).addTo(map);

    let currentLayer = null;
    let markers = [];

    function clearMarkers() {
        markers.forEach(m => map.removeLayer(m));
        markers = [];
    }

    function loadTrip(el) {
        const file = el.getAttribute("data-file");

        fetch('/SurveyData/GetTripData?file=' + encodeURIComponent(file))
            .then(r => r.json())
            .then(points => {

                if (currentLayer) map.removeLayer(currentLayer);
                clearMarkers();

                if (!points || points.length < 2) return;

                const latlngs = points.map(p => [p[0], p[1]]);

                currentLayer = L.polyline(latlngs, {
                    color: '#1d4470',
                    weight: 4
                }).addTo(map);

                const startMarker = L.circleMarker(latlngs[0], {
                    radius: 6,
                    color: "green",
                    fillColor: "green",
                    fillOpacity: 1
                }).addTo(map);

                const endMarker = L.circleMarker(latlngs[latlngs.length - 1], {
                    radius: 6,
                    color: "red",
                    fillColor: "red",
                    fillOpacity: 1
                }).addTo(map);

                markers.push(startMarker);
                markers.push(endMarker);

                map.fitBounds(currentLayer.getBounds());
            });
    }

    function getBoxes() {
        return document.querySelectorAll("input[type='checkbox'][name='files']");
    }

    function selectAll() {
        getBoxes().forEach(c => c.checked = true);
    }

    function deselectAll() {
        getBoxes().forEach(c => c.checked = false);
    }

    function toggleAll() {
        getBoxes().forEach(c => c.checked = !c.checked);
    }
</script>