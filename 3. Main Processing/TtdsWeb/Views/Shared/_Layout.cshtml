<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "TTDS") - TtdsWeb</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="https://localhost:7171/css/shared.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TtdsWeb.styles.css" asp-append-version="true" />

    <style>
        /* CSS Variable Mapping for Shared Design System */
        :root {
            --color-primary: #211d70;
            --color-accent: #da471f;
            --color-bg: #eeeeee;
            --color-surface: #ffffff;
            --color-border: #dddddd;
            --color-text-main: #1d4470;
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.08);
        }

        body {
            background-color: var(--color-bg);
            font-family: 'Segoe UI', Arial, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            margin: 0;
        }

        /* Topbar locked to Design System */
        .topbar {
            background: var(--color-primary);
            color: #eeeeee;
            font-size: 0.95rem;
            font-weight: 600;
            padding: 14px 32px;
            letter-spacing: 0.01em;
            position: sticky;
            top: 0;
            z-index: 1030;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
        }

        .btn-topbar {
            background: var(--color-accent);
            color: #ffffff !important;
            border-radius: 6px;
            padding: 6px 16px;
            font-size: 0.85rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: opacity 0.15s;
        }

            .btn-topbar:hover {
                opacity: 0.9;
            }

        .page-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            padding: 1.5rem 2rem;
            min-height: 0; /* Ensures flex children can scroll */
        }

        .site-footer {
            flex-shrink: 0;
            font-size: 0.78rem;
            color: #666;
            padding: 1rem 0;
            text-align: center;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <header class="topbar">
        <span>@(ViewData["Section"] ?? "Processing")</span>
        <a href="https://localhost:7171/" class="btn-topbar">
            <i class="bi bi-grid-1x2"></i> Dashboard
        </a>
    </header>

    <div class="page-content">
        <main role="main" class="flex-grow-1 d-flex flex-column min-vh-0">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        &copy; @DateTime.Now.Year Travel Time and Delay Survey
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>