@{
    ViewData["Title"] = "Upload CSV";
    ViewData["Section"] = "Processing";
    Layout = "_Layout";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<style>
    :root{
        --primary:#1d4470;
        --accent:#da471f;
        --muted:#888;
        --card-bg:#ffffff;
        --card-border:#d0d8e4;
        --surf:#e8ecf0;
    }

    /* Loading overlay */
    #loadingOverlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.55);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }
    #loadingOverlay[aria-hidden="false"] { display:flex; }

    #loadingCard {
        width: min(520px, 92vw);
        background: var(--card-bg);
        border-radius: 12px;
        padding: 18px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.25);
        border: 1px solid #e5e5e5;
    }
    #loadingTitle { font-weight: 600; margin-bottom:8px; font-size:1.05rem; }
    #loadingMsg   { font-size:0.92rem; color:#555; margin-bottom:12px; }

    .progress { height:12px; border-radius:999px; overflow:hidden; background:#e9ecef; }
    .progress-bar { height:100%; width:0%; background:linear-gradient(90deg,var(--primary),#2f6db5); transition:width .35s ease; }

    /* Layout */
    .page-heading { display:flex; align-items:center; gap:1rem; margin-bottom:1rem; }
    .page-heading .icon { font-size:2.4rem; color:var(--primary); }

    /* Upload card */
    .upload-card {
        background: var(--card-bg);
        border-radius: 16px;
        border: 1px solid var(--card-border);
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        padding: 1.25rem;
    }
    .upload-card h5 { font-weight:700; font-size:1rem; margin-bottom:1rem; }

    /* Drop zone */
    .drop-zone {
        border: 2px dashed #aab4c4;
        border-radius: 12px;
        background: var(--surf);
        padding: 1.75rem 1rem;
        display:flex;
        flex-direction:column;
        align-items:center;
        justify-content:center;
        gap:0.5rem;
        cursor:pointer;
        transition:background .12s, transform .06s;
    }
    .drop-zone:hover { background:#dde3ea; transform:translateY(-1px); }
    .drop-zone.show-drag { background:#d0d8e2; }
    .drop-zone i { font-size:2.6rem; color:var(--accent); }
    .drop-zone p { font-size:0.92rem; color:#444; margin:0; text-align:center; }

    #csvFiles { display:none; }

    /* Buttons */
    .btn-ttds {
        background: var(--primary);
        color: #fff;
        border: none;
        border-radius: 999px;
        font-size:0.9rem;
        font-weight:600;
        padding:10px 28px;
        cursor:pointer;
    }
    .btn-ttds:disabled { opacity:0.6; cursor:not-allowed; }
    .btn-ttds.danger { background:var(--accent); }

    /* File list */
    .file-list-header { font-size:0.86rem; font-weight:700; color:var(--primary); margin-bottom:0.5rem; }
    .file-list-scroll { max-height:220px; overflow-y:auto; display:flex; flex-direction:column; gap:6px; padding-right:6px; }
    .file-item { display:flex; align-items:center; gap:10px; background:#f7fafc; border:1px solid var(--card-border); border-radius:8px; padding:8px 12px; }
    .file-item i { color:var(--accent); font-size:1.1rem; flex-shrink:0; }
    .file-item-name { font-size:0.86rem; color:#333; word-break:break-all; flex:1; }
    .file-item-size { font-size:0.78rem; color:var(--muted); flex-shrink:0; }

    .divider { border:none; border-top:1px dashed var(--card-border); margin:1rem 0; }
    .muted-note { font-size:0.86rem; color:var(--muted); text-align:center; margin:0; }
</style>

<div class="page-wrapper">

    <!-- LOADING OVERLAY -->
    <div id="loadingOverlay" role="status" aria-hidden="true" aria-live="polite">
        <div id="loadingCard">
            <div id="loadingTitle">Processing CSV…</div>
            <div id="loadingMsg">Uploading and processing your files. Please wait.</div>
            <div class="progress" aria-hidden="true">
                <div id="progressBar" class="progress-bar" role="progressbar" aria-valuemin="0" aria-valuemax="100"></div>
            </div>
            <div class="small text-muted mt-2">Don't refresh or go back while processing.</div>
        </div>
    </div>

    <!-- Page heading -->
    <header class="page-heading" aria-labelledby="pageTitle">
        <i class="bi bi-gear-wide-connected icon" aria-hidden="true"></i>
        <h1 id="pageTitle" class="fw-bold mb-0" style="font-size:1.7rem;">@ViewData["Title"]</h1>
    </header>

    <!-- Upload card -->
    <section class="upload-card" aria-labelledby="uploadTitle">
        <h5 id="uploadTitle">Upload CSV Files</h5>

        <form id="uploadForm"
              asp-action="Upload"
              asp-controller="Home"
              method="post"
              enctype="multipart/form-data"
              onsubmit="return startUpload();">

            <input type="file"
                   name="files"
                   id="csvFiles"
                   multiple
                   accept=".csv"
                   aria-label="CSV files"
                   onchange="updateFileLabel(this)" />

            <div class="drop-zone" id="dropZone" role="button" tabindex="0" aria-controls="csvFiles" title="Click or drop CSV files here">
                <i class="bi bi-filetype-csv" aria-hidden="true"></i>
                <p>Drag &amp; drop or click to browse .csv files</p>
            </div>

            <!-- File list -->
            <div id="fileLabel" aria-live="polite" style="margin-top:0.75rem"></div>

            <p id="uploadError" style="display:none; font-size:0.86rem; color:#c0392b; text-align:center; margin-top:0.5rem;">
                <i class="bi bi-exclamation-circle me-1" aria-hidden="true"></i>
                Please select at least one .csv file before continuing.
            </p>

            <div class="d-flex justify-content-center mt-4">
                <button id="btnUpload" type="submit" class="btn-ttds">
                    <i class="bi bi-upload me-1" aria-hidden="true"></i> Upload
                </button>
            </div>

        </form>

        <hr class="divider" />

        <!-- Reset section -->
        <div class="d-flex flex-column align-items-center gap-2">
            <p class="muted-note">
                <i class="bi bi-info-circle me-1" aria-hidden="true"></i>
                Clear previously uploaded data before starting a new session.
            </p>
            <form method="post" action="/reset_session">
                <button type="submit" class="btn-ttds danger">
                    <i class="bi bi-arrow-counterclockwise me-1" aria-hidden="true"></i> Reset / Clear Previous CP
                </button>
            </form>
        </div>
    </section>
</div>

<script>
    // Minimized global footprint
    (function () {
        let fakeProgressTimer = null;
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('csvFiles');
        const progressBar = document.getElementById('progressBar');
        const overlay = document.getElementById('loadingOverlay');

        function updateFileLabel(input) {
            const label = document.getElementById('fileLabel');
            if (!label) return;

            if (input.files && input.files.length > 0) {
                const err = document.getElementById('uploadError');
                if (err) err.style.display = 'none';
                const files = Array.from(input.files);
                const items = files.map(f => {
                    const kb = (f.size / 1024).toFixed(1);
                    return `
                        <div class="file-item">
                            <i class="bi bi-filetype-csv"></i>
                            <span class="file-item-name">${f.name}</span>
                            <span class="file-item-size">${kb} KB</span>
                        </div>
                    `;
                }).join('');

                label.innerHTML = `
                    <div>
                        <p class="file-list-header">
                            <i class="bi bi-folder2-open me-1"></i>
                            ${files.length} file${files.length > 1 ? 's' : ''} selected
                        </p>
                        <div class="file-list-scroll">${items}</div>
                    </div>
                `;
            } else {
                label.innerHTML = '';
            }
        }

        function startFakeProgress() {
            if (!progressBar) return;
            progressBar.style.width = "0%";
            let progress = 0;
            if (fakeProgressTimer) clearInterval(fakeProgressTimer);
            fakeProgressTimer = setInterval(() => {
                if (progress < 60)      progress += (Math.random() * 10) + 6;
                else if (progress < 85) progress += (Math.random() * 6) + 2;
                else if (progress < 98) progress += (Math.random() * 2) + 0.5;
                progress = Math.min(progress, 98);
                progressBar.style.width = Math.round(progress) + "%";
            }, 350);
        }

        function stopFakeProgress() {
            if (fakeProgressTimer) {
                clearInterval(fakeProgressTimer);
                fakeProgressTimer = null;
                if (progressBar) progressBar.style.width = "100%";
            }
        }

        window.startUpload = function() {
            const btn = document.getElementById("btnUpload");
            const err = document.getElementById("uploadError");

            if (!fileInput || !fileInput.files || fileInput.files.length === 0) {
                if (err) err.style.display = 'block';
                return false;
            }

            if (err) err.style.display = 'none';
            overlay.setAttribute('aria-hidden', 'false');
            if (btn) btn.disabled = true;
            // Start simulated progress; server completion should cause navigation (stop not required here)
            startFakeProgress();
            return true;
        };

        // Drag-and-drop support with class toggles
        if (dropZone && fileInput) {
            ['dragenter','dragover'].forEach(ev => dropZone.addEventListener(ev, e => {
                e.preventDefault(); dropZone.classList.add('show-drag');
            }));
            ['dragleave','dragend','drop'].forEach(ev => dropZone.addEventListener(ev, e => {
                dropZone.classList.remove('show-drag');
            }));
            dropZone.addEventListener('drop', e => {
                e.preventDefault();
                if (e.dataTransfer && e.dataTransfer.files) {
                    fileInput.files = e.dataTransfer.files;
                    updateFileLabel(fileInput);
                }
            });
            // keyboard support: Enter/Space open file picker
            dropZone.addEventListener('keydown', e => {
                if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fileInput.click(); }
            });
            dropZone.addEventListener('click', () => fileInput.click());
        }

        // Expose updateFileLabel for onchange
        window.updateFileLabel = updateFileLabel;
    })();
</script>