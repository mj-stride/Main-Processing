@{
    ViewData["Title"] = "Upload CSV";
    ViewData["Section"] = "Processing";
}

<div class="mx-auto w-100" style="max-width: 800px;">

    <div id="loadingOverlay" role="status" aria-hidden="true" aria-live="polite"
         style="position: fixed; inset: 0; background: rgba(15, 23, 42, 0.7); backdrop-filter: blur(3px); display: none; align-items: center; justify-content: center; z-index: 9999;">

        <div id="loadingCard" class="premium-card p-4 text-center mb-0" style="width: min(460px, 92vw);">
            <div class="spinner-border mb-3" role="status" style="color: var(--color-primary); width: 2.2rem; height: 2.2rem;"></div>
            <div id="loadingTitle" class="fw-bold mb-1" style="font-size: 1.15rem; color: var(--color-text-main);">Processing CSV…</div>
            <div id="loadingMsg" class="small text-muted mb-3">Uploading and compiling your telemetry files. Please wait.</div>

            <div class="progress mb-2" style="height: 10px; border-radius: 999px; background-color: var(--color-border);">
                <div id="progressBar" class="progress-bar" role="progressbar" aria-valuemin="0" aria-valuemax="100"
                     style="background: linear-gradient(90deg, var(--color-primary), #2f6db5); width: 0%; transition: width 0.35s ease;"></div>
            </div>

            <div class="small mt-2" style="color: var(--color-text-muted); font-size: 0.8rem;">Do not refresh or use the browser back button.</div>
        </div>
    </div>

    <header class="mb-4 d-flex align-items-center gap-3">
        <div class="rounded-3 d-flex align-items-center justify-content-center shadow-sm flex-shrink-0"
             style="background-color: var(--color-accent); color: #ffffff; width: 60px; height: 60px;">
            <i class="bi bi-gear-wide-connected" style="font-size: 2.2rem;"></i>
        </div>
        <div>
            <h1 class="h3 fw-bold mb-0" style="color: var(--color-text-main);">@ViewData["Title"]</h1>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Upload Geotab telemetry packages for parsing</p>
        </div>
    </header>

    <section class="premium-card mb-4">
        <h5 class="fw-bold mb-4" style="color: var(--color-primary);">Select File Packages</h5>

        <form id="uploadForm" asp-action="Upload" asp-controller="Home"
              method="post" enctype="multipart/form-data" autocomplete="off" onsubmit="return startUpload();">

            <input type="file" name="files" id="csvFiles" multiple accept=".csv" class="d-none" />

            <div id="dropZone" role="button" tabindex="0" aria-controls="csvFiles"
                 title="Click or drop CSV files here" class="drop-zone mb-3">
                <i class="bi bi-filetype-csv"></i>
                <p>Drag &amp; drop or click to browse <b>.csv</b> files</p>
                <span class="drop-zone-subtext">Supports multiple files</span>
            </div>

            <div id="fileLabel" aria-live="polite"></div>

            <div id="uploadError" class="alert alert-danger mt-3 py-2 text-center small fw-semibold" style="display: none;">
                <i class="bi bi-exclamation-triangle-fill me-1"></i> Please select at least one .csv file.
            </div>

            <div class="d-flex justify-content-center mt-4">
                <button id="btnUpload" type="submit" class="btn-ttds w-auto px-5">
                    <i class="bi bi-cloud-upload-fill me-2"></i> Upload Package
                </button>
            </div>
        </form>
    </section>

</div>

@section Scripts {
    <script>
        (function () {
            let fakeProgressTimer = null;
            const dropZone = document.getElementById('dropZone');
            const fileInput = document.getElementById('csvFiles');
            const progressBar = document.getElementById('progressBar');
            const overlay = document.getElementById('loadingOverlay');

            window.addEventListener('pageshow', function () {
                if (fileInput) fileInput.value = '';
                const label = document.getElementById('fileLabel');
                if (label) label.innerHTML = '';
                if (overlay) {
                    overlay.style.display = 'none';
                    overlay.setAttribute('aria-hidden', 'true');
                }
                const btn = document.getElementById('btnUpload');
                if (btn) btn.disabled = false;
                if (fakeProgressTimer) clearInterval(fakeProgressTimer);
            });

            function updateFileLabel(input) {
                const label = document.getElementById('fileLabel');
                if (!label) return;

                if (input.files && input.files.length > 0) {
                    const err = document.getElementById('uploadError');
                    if (err) err.style.display = 'none';

                    const files = Array.from(input.files);
                    const items = files.map(f => {
                        const kb = (f.size / 1024).toFixed(1);
                        return `
                            <div class="d-flex align-items-center justify-content-between p-2 px-3 rounded-2 mb-1 border"
                                 style="background-color: var(--color-surface); border-color: var(--color-border) !important;">
                                <div class="d-flex align-items-center gap-2 text-truncate me-3">
                                    <i class="bi bi-filetype-csv" style="color: var(--color-accent);"></i>
                                    <span class="small fw-medium text-dark text-truncate">${f.name}</span>
                                </div>
                                <span class="badge text-secondary border flex-shrink-0"
                                      style="background-color: var(--color-bg); font-weight: 600;">${kb} KB</span>
                            </div>
                        `;
                    }).join('');

                    label.innerHTML = `
                        <div class="mt-3">
                            <p class="small fw-bold mb-2" style="color: var(--color-primary);">
                                <i class="bi bi-folder2-open me-1"></i>
                                ${files.length} file${files.length > 1 ? 's' : ''} queued
                            </p>
                            <div style="max-height: 200px; overflow-y: auto; padding-right: 4px;">
                                ${items}
                            </div>
                        </div>
                    `;
                } else {
                    label.innerHTML = '';
                }
            }

            function startFakeProgress() {
                if (!progressBar) return;
                progressBar.style.width = '0%';
                let progress = 0;
                if (fakeProgressTimer) clearInterval(fakeProgressTimer);

                fakeProgressTimer = setInterval(() => {
                    if (progress < 60)      progress += (Math.random() * 10) + 6;
                    else if (progress < 85) progress += (Math.random() * 6) + 2;
                    else if (progress < 98) progress += (Math.random() * 2) + 0.5;

                    progress = Math.min(progress, 98);
                    progressBar.style.width = Math.round(progress) + '%';
                }, 350);
            }

            window.startUpload = function () {
                const btn = document.getElementById('btnUpload');
                const err = document.getElementById('uploadError');

                if (!fileInput || !fileInput.files || fileInput.files.length === 0) {
                    if (err) err.style.display = 'block';
                    return false;
                }

                if (err) err.style.display = 'none';

                if (overlay) {
                    overlay.setAttribute('aria-hidden', 'false');
                    overlay.style.display = 'flex';
                }

                if (btn) btn.disabled = true;
                startFakeProgress();
                return true;
            };

            if (dropZone && fileInput) {
                ['dragenter', 'dragover'].forEach(ev => dropZone.addEventListener(ev, e => {
                    e.preventDefault();
                    dropZone.classList.add('drop-zone--active');
                }));

                ['dragleave', 'dragend', 'drop'].forEach(ev => dropZone.addEventListener(ev, e => {
                    dropZone.classList.remove('drop-zone--active');
                }));

                dropZone.addEventListener('drop', e => {
                    e.preventDefault();
                    if (e.dataTransfer && e.dataTransfer.files) {
                        fileInput.files = e.dataTransfer.files;
                        updateFileLabel(fileInput);
                    }
                });

                dropZone.addEventListener('keydown', e => {
                    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fileInput.click(); }
                });

                dropZone.addEventListener('click', () => fileInput.click());
                fileInput.addEventListener('change', () => updateFileLabel(fileInput));
            }
        })();
    </script>
}