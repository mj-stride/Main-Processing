@model TtdsWeb.Models.MultiMapViewModel
@using System.Text.Json
@using System.Text.Encodings.Web

@{
    ViewData["Title"] = "Datasets Preview";
    var jsonOpts = new JsonSerializerOptions
    {
        PropertyNamingPolicy = null,
        Encoder = JavaScriptEncoder.UnsafeRelaxedJsonEscaping
    };

    var anchorSource = (string)(ViewBag.AnchorSource ?? "cp"); // "cp" or "km"
    var selectedRegion = (string)(ViewBag.SelectedRegion ?? "");
    var selectedRoads = (IEnumerable<string>)(ViewBag.SelectedRoads ?? new List<string>());
    var anchorDataServer = ViewBag.AnchorData ?? new List<object>();
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap 5 & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- Leaflet -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.3/dist/leaflet.css" />

    <style>
        :root {
            --ttds-primary: #1d4470;
            --ttds-accent: #2f6db5;
        }

        body {
            background: #eeeeee;
            font-family: 'Segoe UI', Arial, sans-serif;
            margin: 0;
        }

        .navbar-ttds {
            background: var(--ttds-primary);
        }

            .navbar-brand, .navbar-ttds .nav-link, .navbar-ttds .navbar-text {
                color: #fff !important;
            }

        .card-ttds {
            border: none;
            box-shadow: 0 8px 24px rgba(0,0,0,.07);
        }

            .card-ttds .card-header {
                background: #1d4470;
                color: #fff;
            }

        #map {
            height: 70vh;
            min-height: 520px;
            border-radius: .5rem;
            border: 1px solid #e5e7eb;
        }

        .cp-label {
            font-size: 12px;
            font-weight: 600;
            color: #111;
            background: #fff;
            border: 1px solid #ddd;
            border-radius: .25rem;
            padding: 1px 4px;
            box-shadow: 0 1px 4px rgba(0,0,0,.1);
        }

        .dir-pill {
            margin-right: .35rem;
            margin-bottom: .35rem;
        }

        .list-scroll {
            max-height: 36vh;
            overflow: auto;
            border: 1px solid #e9ecef;
            border-radius: .25rem;
            padding: .5rem .75rem;
            background: #fff;
        }

        .road-search {
            position: sticky;
            top: 0;
            background: #fff;
            z-index: 2;
            padding-bottom: .5rem;
        }

        .analyze-bar {
            position: sticky;
            bottom: 0;
            z-index: 1030;
            background: #fff;
            border-top: 1px solid #e5e7eb;
            padding: .75rem 1rem;
            box-shadow: 0 -4px 16px rgba(0,0,0,.06);
        }

        .tag-soft {
            background: #eef2f7;
            color: #3a4a65;
            border-radius: 1rem;
            padding: .15rem .6rem;
            font-size: .85rem;
            margin-left: .25rem;
            display: inline-block;
        }

        .legend-dot {
            display: inline-block;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            margin-right: .4rem;
            vertical-align: middle;
        }

        .badge-dir {
            background: #edf2ff;
            color: var(--ttds-primary);
        }
    </style>
</head>

<body>
    <!-- Topbar -->
    <div style="background:#211d70; color:#eeeeee; font-size:0.95rem; font-weight:600; padding:14px 32px; letter-spacing:0.01em;">
        TTDS – Datasets Preview
    </div>

    <div class="container-fluid">
        <div class="row g-3">

            <!-- LEFT -->
            <div class="col-12 col-lg-8">
                <div class="card card-ttds mb-3">
                    <div class="card-header d-flex align-items-center justify-content-between">
                        <div class="h6 mb-0"><i class="bi bi-map me-2"></i>Preview Map</div>
                        <div class="small">
                            <span class="legend-dot" style="background:#1f77b4"></span> Trip paths
                            <span class="ms-3 legend-dot" style="background:purple"></span> CP
                            <span class="ms-3 legend-dot" style="background:#d9534f"></span> KM
                        </div>
                    </div>
                    <div class="card-body">
                        <div id="map"></div>
                    </div>
                </div>

                <div class="card card-ttds">
                    <div class="card-header d-flex align-items-center justify-content-between">
                        <div class="h6 mb-0"><i class="bi bi-diagram-3 me-2"></i>Datasets</div>
                        <div>
                            <span class="badge rounded-pill badge-dir me-1">NB</span>
                            <span class="badge rounded-pill badge-dir me-1">SB</span>
                            <span class="badge rounded-pill badge-dir me-1">EB</span>
                            <span class="badge rounded-pill badge-dir">WB</span>
                        </div>
                    </div>

                    <div class="card-body">
                        <div id="dir-filters" class="mb-2"></div>

                        <form id="analyzeForm" method="post" action="/analyze_multi">
                            <div class="d-flex mb-2">
                                <button type="button" id="btnSelectAll" class="btn btn-sm me-2" style="border-radius:999px; border:1.5px solid #1d4470; color:#1d4470; background:transparent;">
                                    <i class="bi bi-check2-all"></i> Select All
                                </button>
                                <button type="button" id="btnClearAll" class="btn btn-sm me-auto" style="border-radius:999px; border:1.5px solid #bbb; color:#555; background:transparent;">
                                    <i class="bi bi-x-circle"></i> Clear
                                </button>
                                <span class="small text-muted">Only checked datasets will be analyzed.</span>
                            </div>

                            <div id="ds-list" class="list-scroll"></div>

                            <div class="analyze-bar mt-2 d-flex align-items-center justify-content-between">
                                <div class="small text-muted">
                                    <i class="bi bi-info-circle me-1"></i>
                                    Choose datasets and click Analyze.
                                </div>
                                <button type="submit" style="background:#1d4470; color:#eeeeee; border:none; border-radius:999px; font-size:0.88rem; font-weight:600; padding:9px 24px; cursor:pointer;">
                                    <i class="bi bi-lightning-charge-fill me-1"></i> Analyze Selected
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- RIGHT -->
            <div class="col-12 col-lg-4">
                <div class="card card-ttds mb-3">
                    <div class="card-header h6 mb-0">
                        <i class="bi bi-funnel-fill me-2"></i>Anchor Filter
                    </div>
                    <div class="card-body">
                        <form id="kmFilterForm" method="post" action="/anchor_preview">
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Anchor Source</label>
                                <select name="source" id="sourceSel" class="form-select">
                                    @if (anchorSource == "cp")
                                    {
                                        <option value="cp" selected>Control Points (CP)</option>
                                        <option value="km">Kilometer Posts (KM)</option>
                                    }
                                    else
                                    {
                                        <option value="cp">Control Points (CP)</option>
                                        <option value="km" selected>Kilometer Posts (KM)</option>
                                    }
                                </select>
                                <div class="form-text">Switch between KM posts and Control Points.</div>
                            </div>

                            <div id="kmOnlyPanel" style="display:@(anchorSource == "km" ? "block" : "none");">
                                <div class="mb-2">
                                    <label class="form-label fw-semibold">Region</label>
                                    <select name="region" id="regionSel" class="form-select">
                                        <option value="">-- Any Region --</option>
                                    </select>
                                </div>

                                <div class="mb-2">
                                    <label class="form-label fw-semibold">Road (multi-select)</label>
                                    <div class="road-search">
                                        <input id="roadFilterInput" class="form-control form-control-sm" placeholder="Search road names..." />
                                    </div>
                                    <select name="roads" id="roadSel" multiple size="8" class="form-select"></select>
                                    <div class="form-text">
                                        Hold <code>Ctrl</code>/<code>Cmd</code> to select multiple roads.
                                    </div>
                                </div>

                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-pin-map-fill me-1"></i> Apply KM Filter
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary" id="btnClearRoads">Clear Roads</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="card card-ttds">
                    <div class="card-header h6 mb-0">
                        <i class="bi bi-geo-fill me-2"></i>Control Points (CP) Tools
                    </div>
                    <div class="card-body" id="cpTools">
                        <div class="mb-3">
                            <label class="form-label fw-semibold mb-1">Upload CP CSV (CP mode only)</label>
                            <form id="cpForm" enctype="multipart/form-data">
                                <div class="input-group">
                                    <input type="file" name="cp_file" accept=".csv" class="form-control" />
                                    <button type="button" id="btnUploadCp" class="btn btn-outline-primary">
                                        <i class="bi bi-upload"></i> Upload
                                    </button>
                                </div>
                            </form>
                        </div>

                        <div class="d-flex gap-2 mb-3">
                            <button type="button" id="btnDownloadCp" class="btn btn-outline-secondary">
                                <i class="bi bi-download"></i> Download Current CP
                            </button>
                            <button type="button" id="btnToggleAddCp" class="btn btn-outline-success">
                                Add-CP Mode: OFF
                            </button>
                        </div>
                        <a href="/download_detected_cp?format=csv" class="btn btn-success">
                            Download Detected Anchor CP CSV
                        </a>

                        <a href="/download_detected_cp?format=geojson" class="btn btn-outline-success">
                            Download Detected Anchor CP GeoJSON
                        </a>
                        <div class="small text-muted">
                            KM mode auto-enables Add-CP. Click on the map to add CP.
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- JS -->
    <script src="https://unpkg.com/leaflet@1.9.3/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        /* ---------- Data from server ---------- */
        const items = @Html.Raw(JsonSerializer.Serialize(Model.Items ?? new List<TtdsWeb.Models.MultiMapViewModel.Item>(), jsonOpts));
        const anchorData = @Html.Raw(JsonSerializer.Serialize(anchorDataServer, jsonOpts));
        const anchorMode = "@anchorSource";  // "cp" or "km"
        const preRegion = @Html.Raw(JsonSerializer.Serialize(selectedRegion ?? "", jsonOpts));
        const preRoads = @Html.Raw(JsonSerializer.Serialize(selectedRoads ?? new List<string>(), jsonOpts));

        /* ---------- Elements ---------- */
        const sourceSel = document.getElementById('sourceSel');
        const kmPanel = document.getElementById('kmOnlyPanel');
        const regionSel = document.getElementById('regionSel');
        const roadSel = document.getElementById('roadSel');
        const roadFilter = document.getElementById('roadFilterInput');
        const kmFilterForm = document.getElementById('kmFilterForm');

        function showKmPanel() {
            const isKm = (sourceSel.value === 'km');
            kmPanel.style.display = isKm ? 'block' : 'none';
        }

        function submitKmFilterForm() {
            if (!kmFilterForm) return;
            [...kmFilterForm.querySelectorAll('input[name="roads"]')].forEach(x => x.remove());

            const selected = Array.from(roadSel?.selectedOptions || []).map(o => o.value).filter(Boolean);
            selected.forEach(val => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'roads';
                input.value = val;
                kmFilterForm.appendChild(input);
            });
            kmFilterForm.submit();
        }

        async function loadRegions() {
            regionSel.innerHTML = '<option value="">-- Any Region --</option>';
            try {
                const r = await fetch('/km/regions');
                const arr = await r.json();
                (arr || []).forEach(v => {
                    const opt = document.createElement('option');
                    opt.value = v;
                    opt.textContent = v;
                    if (preRegion && preRegion === v) opt.selected = true;
                    regionSel.appendChild(opt);
                });
            } catch (e) { console.error(e); }
        }

        async function loadRoads(region) {
            roadSel.innerHTML = '';
            try {
                const url = '/km/roads' + (region ? ('?region=' + encodeURIComponent(region)) : '');
                const r = await fetch(url);
                const arr = await r.json();

                (arr || []).forEach(v => {
                    const opt = document.createElement('option');
                    opt.value = v;
                    opt.textContent = v;
                    if (Array.isArray(preRoads) && preRoads.includes(v)) opt.selected = true;
                    roadSel.appendChild(opt);
                });
            } catch (e) { console.error(e); }
        }

        roadFilter?.addEventListener('input', () => {
            const query = (roadFilter.value || '').toLowerCase();
            Array.from(roadSel.options).forEach(opt => {
                opt.style.display = opt.textContent.toLowerCase().includes(query) ? 'block' : 'none';
            });
        });

        regionSel?.addEventListener('change', async () => {
            await loadRoads(regionSel.value || '');
            if (sourceSel?.value === 'km') submitKmFilterForm();
        });

        sourceSel?.addEventListener('change', async () => {
            showKmPanel();
            syncAddCpForMode();
            await refreshCpList();
            submitKmFilterForm();
        });

        document.getElementById('btnClearRoads')?.addEventListener('click', () => {
            Array.from(roadSel.options).forEach(o => o.selected = false);
        });

        /* ---------- Map ---------- */
        const map = L.map('map');
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19, attribution: '© OpenStreetMap'
        }).addTo(map);

        function defaultCenter() { return [14.5995, 120.9842]; }
        let center = defaultCenter();
        if (items.length && items[0].Coords && items[0].Coords.length) {
            center = [items[0].Coords[0][0], items[0].Coords[0][1]];
        }
        map.setView(center, 13);

        /* ---------- Render trip polylines + list ---------- */
        const DIR_ORDER = ["NB","SB","EB","WB","Unknown"];
        const byDir = {}; DIR_ORDER.forEach(d => byDir[d] = []);
        (items || []).forEach(it => {
            const dir = (it.Direction || "Unknown").toUpperCase();
            if (!byDir[dir]) byDir[dir] = [];
            byDir[dir].push(it);
        });

        const bounds = L.latLngBounds();
        const dsLayers = {};

        const dirFilters = document.getElementById('dir-filters');
        ["All","NB","SB","EB","WB","Unknown"].forEach(lbl => {
            const b = document.createElement('button');
            b.type='button';
            b.className = 'btn btn-sm ' + (lbl === "All" ? 'btn-primary' : 'btn-outline-primary') + ' dir-pill';
            b.textContent = lbl;
            b.addEventListener('click', () => {
                document.querySelectorAll('.dir-group').forEach(g => {
                    g.style.display = (lbl === "All" || g.dataset.dir === lbl) ? '' : 'none';
                });
                document.querySelectorAll('.dir-pill').forEach(x => x.classList.replace('btn-primary','btn-outline-primary'));
                b.classList.replace('btn-outline-primary','btn-primary');
            });
            dirFilters.appendChild(b);
        });

        const dsListDiv = document.getElementById('ds-list');
        DIR_ORDER.forEach(dir => {
            const list = byDir[dir];
            if (!list.length) return;

            const groupDiv = document.createElement('div');
            groupDiv.className = 'dir-group mb-2';
            groupDiv.dataset.dir = dir;

            const h = document.createElement('div');
            h.innerHTML = `<span class="fw-semibold">${dir}</span> <span class="tag-soft">${list.length} file(s)</span>`;
            h.className = 'mb-1';
            groupDiv.appendChild(h);

            list.forEach((it) => {
                const row = document.createElement('div');
                row.className = 'form-check';

                const cb = document.createElement('input');
                cb.type = 'checkbox';
                cb.checked = true;
                cb.className = 'form-check-input';
                cb.id = `ds_${it.Id}`;
                cb.dataset.id = it.Id;

                const label = document.createElement('label');
                label.style.marginLeft = '6px';
                label.className = 'form-check-label';
                label.setAttribute('for', `ds_${it.Id}`);

                const peakLabel = (it.PeakLabel || "Off-Peak");
                label.innerHTML = `${it.Name} <span class="tag-soft ms-1">${peakLabel}</span>`;

                row.appendChild(cb);
                row.appendChild(label);
                groupDiv.appendChild(row);

                const latlngs = (it.Coords || []).map(p => [p[0], p[1]]);
                if (latlngs.length > 1) {
                    latlngs.forEach(p => bounds.extend(p));

                    const layer = L.polyline(latlngs, { color: '#1f77b4', weight: 4, opacity: 1 })
                        .bindPopup(`<b>${it.Name}</b><br>Direction: ${dir}<br>Peak: ${peakLabel}`);

                    layer.addTo(map);
                    dsLayers[it.Id] = layer;

                    cb.addEventListener('change', e => {
                        const id = e.target.dataset.id;
                        const lyr = dsLayers[id];
                        if (!lyr) return;
                        if (e.target.checked) lyr.addTo(map);
                        else map.removeLayer(lyr);
                    });
                }
            });

            dsListDiv.appendChild(groupDiv);
        });

        if (bounds.isValid()) map.fitBounds(bounds.pad(0.1));

        document.getElementById('btnSelectAll')?.addEventListener('click', () => {
            document.querySelectorAll('#ds-list input[type=checkbox]').forEach(cb => cb.checked = true);
            Object.values(dsLayers).forEach(lyr => lyr.addTo(map));
        });

        document.getElementById('btnClearAll')?.addEventListener('click', () => {
            document.querySelectorAll('#ds-list input[type=checkbox]').forEach(cb => cb.checked = false);
            Object.values(dsLayers).forEach(lyr => map.removeLayer(lyr));
        });

        /* ---------- Anchors from server (KM/CP points) ---------- */
        const anchorLayer = L.layerGroup().addTo(map);

        function renderAnchorsFromServer() {
            anchorLayer.clearLayers();
            const isKM = (anchorMode === 'km');
            const colr = isKM ? '#d9534f' : 'purple';
            const labelPrefix = isKM ? 'KM:' : 'CP:';

            (anchorData || []).forEach(a => {
                if (a && !isNaN(a.lat) && !isNaN(a.lon)) {
                    const m = L.circleMarker([a.lat, a.lon], {
                        radius: 4, color: colr, fillColor: colr, fillOpacity: 0.9
                    }).addTo(anchorLayer);

                    m.bindTooltip(`${labelPrefix} ${a.id}`, {
                        permanent: true, direction: 'right', offset: [8,0], className: 'cp-label'
                    });
                }
            });
        }
        renderAnchorsFromServer();

        /* ---------- CP Tools ---------- */
        let addCpMode = false;
        const cpMarkers = {};

        function syncAddCpForMode() {
            const isKm = (sourceSel?.value === 'km');
            if (isKm) addCpMode = true;

            const btn = document.getElementById('btnToggleAddCp');
            if (btn) {
                btn.textContent = isKm
                    ? 'Add-CP Mode: ON (KM Auto)'
                    : (addCpMode ? 'Disable Add-CP Mode' : 'Enable Add-CP Mode');
            }
        }

        async function refreshCpList() {
            const mode = (sourceSel?.value === 'km') ? 'km' : 'cp';
            try {
                const res = await fetch('/get_cp?mode=' + mode);
                if (!res.ok) throw new Error('get_cp HTTP ' + res.status);

                const cp = await res.json();

                Object.values(cpMarkers).forEach(m => map.removeLayer(m));
                for (const k of Object.keys(cpMarkers)) delete cpMarkers[k];

                const color = (mode === 'km') ? '#d9534f' : 'purple';

                (cp || []).forEach(row => {
                    const m = L.circleMarker([row.lat, row.lng], {
                        radius: 4, color: color, fillColor: color, fillOpacity: 0.9
                    }).addTo(map);

                    m.bindTooltip(`${mode === 'km' ? 'Manual CP' : 'CP'}: ${row.id}`, {
                        permanent: true, direction: 'right', offset: [8,0], className: 'cp-label'
                    });

                    cpMarkers[row.id] = m;
                });
            } catch (err) {
                console.error('get_cp failed', err);
            }
        }

        document.getElementById('btnToggleAddCp')?.addEventListener('click', () => {
            const isKm = (sourceSel?.value === 'km');
            if (isKm) { addCpMode = true; syncAddCpForMode(); return; }
            addCpMode = !addCpMode;
            syncAddCpForMode();
        });

        document.getElementById('btnUploadCp')?.addEventListener('click', async () => {
            if (sourceSel?.value !== 'cp') { alert('Upload CP CSV only applies to CP mode.'); return; }
            try {
                const form = document.getElementById('cpForm');
                const fd = new FormData(form);
                const res = await fetch('/upload_cp', { method: 'POST', body: fd });
                if (!res.ok) throw new Error('upload_cp HTTP ' + res.status);
                const j = await res.json();
                alert(j.message || 'Uploaded.');
                await refreshCpList();
            } catch (e) {
                console.error(e);
                alert('Upload failed.');
            }
        });

        document.getElementById('btnDownloadCp')?.addEventListener('click', () => {
            if (sourceSel?.value !== 'cp') { alert('Download CP is only for CP mode.'); return; }
            window.location.href = '/download_cp';
        });

        map.on('click', async (ev) => {
            if (!addCpMode) return;

            const mode = (sourceSel?.value === 'km') ? 'km' : 'cp';
            const name = prompt(mode === 'km'
                ? "Enter Manual Control Point name (KM mode):"
                : "Enter Control Point name (CP mode):");

            if (name === null) return;
            if (!name.trim()) { alert("Name is required."); return; }

            try {
                const res = await fetch('/add_cp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        lat: ev.latlng.lat,
                        lng: ev.latlng.lng,
                        name: name.trim(),
                        mode: mode
                    })
                });

                if (!res.ok) throw new Error('add_cp HTTP ' + res.status);
                await refreshCpList();
                alert(`Added ${name.trim()} (${mode.toUpperCase()} mode)`);
            } catch (err) {
                console.error('add_cp failed', err);
                alert("Failed to add control point");
            }
        });

        /* ---------- Analyze Selected Datasets ---- */
        const analyzeForm = document.getElementById('analyzeForm');
        if (analyzeForm) {
            analyzeForm.addEventListener('submit', (e) => {
                const checked = [...document.querySelectorAll('#ds-list input[type=checkbox]:checked')]
                                .map(cb => cb.dataset.id);

                if (!checked.length) { e.preventDefault(); alert('Select at least one dataset.'); return; }

                [...analyzeForm.querySelectorAll('input[name=selected_files]')].forEach(x => x.remove());
                checked.forEach(id => {
                    const h = document.createElement('input');
                    h.type = 'hidden';
                    h.name = 'selected_files';
                    h.value = id;
                    analyzeForm.appendChild(h);
                });
            });
        }

        /* ---------- Init ---------- */
        document.addEventListener('DOMContentLoaded', async () => {
            sourceSel.value = (anchorMode === 'km') ? 'km' : 'cp';
            showKmPanel();

            await loadRegions();
            await loadRoads(preRegion || '');

            syncAddCpForMode();
            await refreshCpList();
        });
    </script>
    <footer style="text-align:center; font-size:0.78rem; color:#888; padding:1rem;">
        &copy; 2025 Travel Time and Delay Survey
    </footer>
</body>
</html>
