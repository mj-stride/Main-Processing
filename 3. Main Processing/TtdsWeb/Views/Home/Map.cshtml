@model TtdsWeb.Models.AnalyzeViewModel
<!DOCTYPE html>
<html>
<head>
    <title>Step 2: Select Control Points</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <style>
        #map {
            height: 600px;
            width: 100%;
        }

        body {
            font-family: sans-serif;
            padding: 20px;
        }

        h2, h3 {
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <h2>🗺️ Route Map</h2>
    <div id="map"></div>
    <br>

    <h3>📤 Step 2: Upload KM Post/Control Points CSV</h3>
    <form id="cpUploadForm" enctype="multipart/form-data" method="post">
        <input type="file" name="cp_file" accept=".csv" required>
        <button type="submit">Upload Control Points</button>
    </form>
    <h3>📊 Step 3: Analyze Trip</h3>
    <br>
     <button onclick="location.href='/analyze'">📊 Analyze Travel Time & Delays</button>
    <button onclick="location.href='/download_cp'">⬇️ Download CPs</button>
    <button onclick="fetch('/get_cp').then(()=>{ fetch('/update_cp_position',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({cp_id:'noop',lat:0,lng:0})}) })" style="display:none">noop</button>

    <script>
        const coords = @Html.Raw(JsonSerializer.Serialize(Model.Coords));
        const map = L.map('map').setView(coords[0], 14);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19 }).addTo(map);

        const latlngs = coords.map(c => [c[0], c[1]]);
        L.polyline(latlngs, { color: 'blue' }).addTo(map);

        let cpCount = 0;

        function addCPMarker(cp) {
            const marker = L.marker([cp.lat, cp.lng], { draggable: true })
                .addTo(map)
                .bindPopup(cp.id || `CP${cpCount}`)
                .on('dragend', function (event) {
                    const pos = event.target.getLatLng();
                    updateCPPosition(cp.id, pos.lat, pos.lng);
                });
        }

        function updateCPPosition(cpId, lat, lng) {
            fetch('/update_cp_position', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ cp_id: cpId, lat, lng })
            });
        }

        map.on('click', async function (e) {
            cpCount++;
            const cpName = "CP" + cpCount;
            const lat = e.latlng.lat;
            const lng = e.latlng.lng;

            addCPMarker({ id: cpName, lat, lng });

            await fetch('/add_cp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ latitude: lat, longitude: lng })
            });
        });

        document.getElementById('cpUploadForm').addEventListener('submit', async function (event) {
            event.preventDefault();
            const formData = new FormData(this);
            const response = await fetch('/upload_cp', { method: 'POST', body: formData });

            if (response.ok) {
                const result = await response.json();
                alert(result.message || "Control Points uploaded!");

                const cpRes = await fetch('/get_cp');
                const cpList = await cpRes.json();
                cpCount = cpList.length;
                cpList.forEach(addCPMarker);
            } else {
                const err = await response.text();
                alert("Error: " + err);
            }
        });
    </script>
</body>
</html>
