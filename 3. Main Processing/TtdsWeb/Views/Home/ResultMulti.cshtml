@model TtdsWeb.Models.MultiAnalyzeViewModel
@using System.Text.Json
@using System.Text.Json.Serialization
@using System.Linq

@{
    ViewData["Title"] = "Multi Dataset Analysis";
    ViewData["Section"] = "Multi Dataset Analysis";

    var jsonOpts = new JsonSerializerOptions
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        NumberHandling = JsonNumberHandling.AllowNamedFloatingPointLiterals,
        DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull
    };

    string hhmmss(double? minutes) => TimeSpan.FromMinutes(minutes ?? 0).ToString(@"hh\:mm\:ss");
    string kmFmt(double? v) => (v ?? 0).ToString("0.##");
    string kphFmt(double? v) => (v ?? 0).ToString("0.##");

    double safeDouble(object? v)
    {
        if (v == null) return 0;
        if (v is double d) return d;
        if (v is float f) return f;
        if (v is int i) return i;
        if (v is long l) return l;
        if (double.TryParse(v.ToString(), out var x)) return x;
        return 0;
    }
}
@functions {
    (string vehCode, string vehName, string tripNo, string dtToken, string date)? ParseTripInfo(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return null;

        var mv = System.Text.RegularExpressions.Regex.Match(
            name, @"\bGPX_(\d+)_",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);

        var vehCode = mv.Success ? mv.Groups[1].Value : "0";
        var vehName = vehCode switch
        {
            "1" => "PrivateCar",
            "2" => "UV",
            "3" => "Jeepney",
            "4" => "BUS",
            _ => "UnknownVehicle"
        };

        var m = System.Text.RegularExpressions.Regex.Match(
            name, @"-(\d+)_((\d{8})-(\d{6}))",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);

        if (!m.Success)
            return (vehCode, vehName, "0", "00000000-000000", "00000000");

        return (vehCode, vehName, m.Groups[1].Value, m.Groups[2].Value, m.Groups[3].Value);
    }

    string PeriodFolder(string? peakCodeOrLabel)
    {
        var p = (peakCodeOrLabel ?? "").ToUpperInvariant();
        if (p.Contains("AM")) return "AM";
        if (p.Contains("MID")) return "MID";
        if (p.Contains("PM")) return "PM";
        return "OFF";
    }
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.3/dist/leaflet.css" />
    <style>
        /* ── Map & sidebar ── */
        #map {
            height: 520px;
            width: 100%;
            border: 1px solid var(--color-border);
            border-radius: 12px;
        }

        #ds-toggle {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: 12px;
            box-shadow: var(--shadow-md);
            padding: 1rem;
            max-height: 520px;
            display: flex;
            flex-direction: column;
        }

            #ds-toggle h4 {
                color: var(--color-primary);
                font-size: 0.95rem;
                font-weight: 700;
                margin: 0 0 0.75rem;
            }

        #ds-list {
            overflow-y: auto;
            flex: 1;
            padding-right: 4px;
        }

        .ds-row {
            margin-bottom: 4px;
        }

        /* ── CP labels ── */
        .cp-label {
            font-size: 12px;
            font-weight: bold;
            color: #111;
            background: transparent;
            border: none;
            box-shadow: none;
        }

        /* ── Peak sections ── */
        .peak-section {
            margin-top: 2rem;
            border-top: 3px solid var(--color-primary);
            padding-top: 1rem;
        }

        .peak-title {
            font-size: 1.3rem;
            font-weight: 700;
            margin: 0 0 0.75rem;
            color: var(--color-primary);
        }

        /* ── Dataset accordion ── */
        .dataset-section {
            margin-top: 1.25rem;
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: 12px;
            box-shadow: var(--shadow-sm);
            overflow: hidden;
        }

        .dataset-section-header {
            background: var(--color-primary);
            color: #fff;
            padding: 0.85rem 3rem 0.85rem 1.25rem;
            cursor: pointer;
            user-select: none;
            position: relative;
        }

            .dataset-section-header .ds-title {
                font-size: 0.92rem;
                font-weight: 700;
                margin: 0;
                color: #fff;
                word-break: break-all;
            }

            .dataset-section-header .ds-meta {
                font-size: 0.78rem;
                color: #a8c4e0;
                margin: 0;
            }

        .dataset-section.collapsed .dataset-section-body {
            display: none;
        }

        .dataset-section-body {
            padding: 1.25rem;
        }

            .dataset-section-body h4 {
                font-size: 0.88rem;
                font-weight: 700;
                color: var(--color-primary);
                margin: 1.25rem 0 0.5rem;
                display: flex;
                align-items: center;
                gap: 6px;
            }

                .dataset-section-body h4:first-child {
                    margin-top: 0;
                }

        /* ── Two-col chart grid ── */
        .grid-two {
            display: grid;
            grid-template-columns: 1fr 420px;
            gap: 1.5rem;
            align-items: start;
            margin-top: 1rem;
        }

            .grid-two > div {
                background: var(--color-bg);
                border: 1px solid var(--color-border);
                border-radius: 12px;
                padding: 1rem;
            }

            .grid-two h4 {
                font-size: 0.88rem;
                font-weight: 700;
                color: var(--color-primary);
                margin: 0 0 0.75rem;
            }

        /* ── Tables (scoped to avoid clobbering Bootstrap) ── */
        .ttds-table {
            border-collapse: collapse;
            width: 100%;
            margin-top: 12px;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            font-size: 0.85rem;
        }

            .ttds-table th,
            .ttds-table td {
                border: none;
                border-bottom: 1px solid var(--color-border);
                padding: 10px 14px;
                text-align: center;
            }

            .ttds-table th {
                background-color: var(--color-primary);
                color: #fff;
                font-weight: 600;
                font-size: 0.82rem;
                letter-spacing: 0.02em;
            }

            .ttds-table td {
                background-color: var(--color-surface);
                color: #1a1a2e;
            }

            .ttds-table tr:last-child td {
                border-bottom: none;
            }

            .ttds-table tbody tr:hover td {
                background-color: #f0f5fb;
            }

            .ttds-table tbody tr:nth-child(even) td {
                background-color: var(--color-bg);
            }

            .ttds-table tbody tr:nth-child(even):hover td {
                background-color: #f0f5fb;
            }

        .sum-table {
            width: 100%;
            border-radius: 10px;
            border: 1px solid var(--color-border);
            box-shadow: var(--shadow-sm);
            margin-top: 10px;
            border-collapse: collapse;
            font-size: 0.88rem;
        }

            .sum-table th,
            .sum-table td {
                text-align: left;
                padding: 10px 16px;
                border: none;
                border-bottom: 1px solid var(--color-border);
            }

            .sum-table th {
                background-color: var(--color-primary);
                color: #fff;
                font-weight: 600;
                width: 220px;
            }

            .sum-table td {
                background-color: var(--color-surface);
                color: #1a1a2e;
                font-weight: 500;
            }

            .sum-table tr:last-child th, .sum-table tr:last-child td {
                border-bottom: none;
            }

            .sum-table tr:hover td {
                background-color: #f0f5fb;
            }

        /* ── Charts ── */
        canvas {
            background-color: white;
            display: block;
            width: 100% !important;
        }

        .chart-wrap {
            position: relative;
            width: 100%;
        }

        .chart-wrap-tall {
            height: 380px;
        }

        .chart-wrap-medium {
            height: 280px;
        }

        .chart-wrap-small {
            height: 260px;
        }

        /* ── Filter box ── */
        .filter-box {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: 12px;
            box-shadow: var(--shadow-sm);
            padding: 1.25rem;
            margin-bottom: 1rem;
        }

            .filter-box h4 {
                margin: 0 0 10px;
                color: var(--color-primary);
                font-size: 0.95rem;
                font-weight: 700;
            }

        .muted {
            color: var(--color-text-muted);
            font-size: 12px;
            margin-top: 4px;
        }

        /* ── Bottom action bar ── */
        .action-bar {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: var(--color-surface);
            border-top: 2px solid var(--color-border);
            padding: 14px 32px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.08);
        }

        /* ── Export actions ── */
        .export-actions {
            margin: 30px auto;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
        }

            .export-actions form {
                width: 100%;
                display: flex;
                justify-content: center;
            }
    </style>
}

<div style="max-width: 1400px; margin: 0 auto; padding-bottom: 6rem;">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold mb-0" style="font-size: 1.5rem; color: var(--color-primary);">
            <i class="bi bi-map me-2" style="color: var(--color-accent);"></i>
            Multi Dataset Travel Time &amp; Delay Analysis
        </h2>
        <a href="/" class="btn-action">
            <i class="bi bi-arrow-left"></i> Back to Upload
        </a>
    </div>

    @{
        var regions = Model.RegionList ?? new List<string>();
        var roadsByRegion = Model.RoadsByRegion ?? new Dictionary<string, List<string>>();
        var defaultRegion = Model.SelectedRegion ?? regions.FirstOrDefault() ?? "";
        var defaultRoad = Model.SelectedRoad
        ?? (roadsByRegion.ContainsKey(defaultRegion) ? roadsByRegion[defaultRegion].FirstOrDefault() : "")
        ?? "";
    }

    <div class="filter-box">
        <h4><i class="bi bi-funnel me-1"></i> Preview Filters</h4>
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <label class="fw-bold text-nowrap">Region:</label>
            <select id="regionSelect" name="region" form="exportForm" class="form-control" style="width: 160px;">
                @foreach (var r in regions)
                {
                    <option value="@r" selected="@(r == defaultRegion)">@r</option>
                }
            </select>

            <label class="fw-bold text-nowrap">Road / Section:</label>
            <select id="roadSelect" name="roadNameOrSections" form="exportForm" class="form-control" style="width: 280px;">
                @if (!string.IsNullOrWhiteSpace(defaultRegion) && roadsByRegion.ContainsKey(defaultRegion))
                {
                    foreach (var rd in roadsByRegion[defaultRegion])
                    {
                        <option value="@rd" selected="@(rd == defaultRoad)">@rd</option>
                    }
                }
            </select>

            <label class="fw-bold text-nowrap">Period:</label>
            <select id="periodSelect" name="period" form="exportForm" class="form-control" style="width: 100px;">
                <option value="ALL">ALL</option>
                <option value="AM">AM</option>
                <option value="MID">MID</option>
                <option value="PM">PM</option>
            </select>
        </div>
        <div class="muted mt-2">These values will be used for the ZIP folder naming.</div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-12 col-lg-9">
            <div id="map"></div>
        </div>
        <div class="col-12 col-lg-3">
            <div id="ds-toggle">
                <h4>Datasets on map</h4>
                <div id="ds-list"></div>
                <div class="muted">Tip: toggle datasets to hide/show on map.</div>
            </div>
        </div>
    </div>

    @if (Model.PeakGroups != null && Model.PeakGroups.Any())
    {
        for (int pg = 0; pg < Model.PeakGroups.Count; pg++)
        {
            var g = Model.PeakGroups[pg];

            <div class="peak-section" id="peak-@pg">
                <h2 class="peak-title">
                    <i class="bi bi-map me-2"></i>Map for @g.PeakLabel
                </h2>
                <div class="muted"><i class="bi bi-clock-history me-1"></i>@g.PeakLabel (@g.PeakCode)</div>

                @if (g.OverallSummary != null)
                {
                    <h2><i class="bi bi-pin-angle-fill me-2"></i>Overall Summary (This Peak Period)</h2>
                    <table class="sum-table">
                        <tbody>
                            <tr><th>Avg Travel Time (min)</th><td>@g.OverallSummary.TotalTravelTimeMin</td></tr>
                            <tr><th>Avg Distance (km)</th><td>@g.OverallSummary.TotalDistanceKm</td></tr>
                            <tr><th>Avg Travel Speed</th><td>@g.OverallSummary.AvgTravelSpeed</td></tr>
                            <tr><th>Avg Running Speed</th><td>@g.OverallSummary.AvgRunningSpeed</td></tr>
                            <tr><th>Avg Delay (min)</th><td>@g.OverallSummary.TotalDelayMin</td></tr>
                            <tr><th>Avg Delay Length (m)</th><td>@g.OverallSummary.TotalDelayLength</td></tr>
                        </tbody>
                    </table>
                }

                @if (g.DirectionSummaries != null && g.DirectionSummaries.Any())
                {
                    var dirDict = g.DirectionSummaries
                    .GroupBy(d => (d.Direction ?? "Unknown").ToUpperInvariant())
                    .ToDictionary(x => x.Key, x => x.First());

                    var sb = dirDict.ContainsKey("SB") ? dirDict["SB"] : null;
                    var nb = dirDict.ContainsKey("NB") ? dirDict["NB"] : null;
                    var eb = dirDict.ContainsKey("EB") ? dirDict["EB"] : null;
                    var wb = dirDict.ContainsKey("WB") ? dirDict["WB"] : null;

                    <h2><i class="bi bi-signpost-split-fill me-2"></i>Directional Averages (This Peak Period)</h2>
                    <table class="sum-table">
                        <thead>
                            <tr>
                                <th></th>
                                @if (sb != null)
                                {
                                    <th>Southbound</th>
                                }
                                @if (nb != null)
                                {
                                    <th>Northbound</th>
                                }
                                @if (eb != null)
                                {
                                    <th>Eastbound</th>
                                }
                                @if (wb != null)
                                {
                                    <th>Westbound</th>
                                }
                                <th>Units</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Avg Travel Time</td>
                                @if (sb != null)
                                {
                                    <td>@hhmmss(sb.AvgTravelTimeMin)</td>
                                }
                                @if (nb != null)
                                {
                                    <td>@hhmmss(nb.AvgTravelTimeMin)</td>
                                }
                                @if (eb != null)
                                {
                                    <td>@hhmmss(eb.AvgTravelTimeMin)</td>
                                }
                                @if (wb != null)
                                {
                                    <td>@hhmmss(wb.AvgTravelTimeMin)</td>
                                }
                                <td>hh:mm:ss</td>
                            </tr>
                            <tr>
                                <td>Avg Distance</td>
                                @if (sb != null)
                                {
                                    <td>@kmFmt(sb.AvgDistanceKm)</td>
                                }
                                @if (nb != null)
                                {
                                    <td>@kmFmt(nb.AvgDistanceKm)</td>
                                }
                                @if (eb != null)
                                {
                                    <td>@kmFmt(eb.AvgDistanceKm)</td>
                                }
                                @if (wb != null)
                                {
                                    <td>@kmFmt(wb.AvgDistanceKm)</td>
                                }
                                <td>km</td>
                            </tr>
                            <tr>
                                <td>Avg Travel Speed</td>
                                @if (sb != null)
                                {
                                    <td>@kphFmt(sb.AvgTravelSpeed)</td>
                                }
                                @if (nb != null)
                                {
                                    <td>@kphFmt(nb.AvgTravelSpeed)</td>
                                }
                                @if (eb != null)
                                {
                                    <td>@kphFmt(eb.AvgTravelSpeed)</td>
                                }
                                @if (wb != null)
                                {
                                    <td>@kphFmt(wb.AvgTravelSpeed)</td>
                                }
                                <td>kph</td>
                            </tr>
                            <tr>
                                <td>Avg Running Speed</td>
                                @if (sb != null)
                                {
                                    <td>@kphFmt(sb.AvgRunningSpeed)</td>
                                }
                                @if (nb != null)
                                {
                                    <td>@kphFmt(nb.AvgRunningSpeed)</td>
                                }
                                @if (eb != null)
                                {
                                    <td>@kphFmt(eb.AvgRunningSpeed)</td>
                                }
                                @if (wb != null)
                                {
                                    <td>@kphFmt(wb.AvgRunningSpeed)</td>
                                }
                                <td>kph</td>
                            </tr>
                            <tr>
                                <td>Avg Delay Time</td>
                                @if (sb != null)
                                {
                                    <td>@hhmmss(sb.AvgDelayMin)</td>
                                }
                                @if (nb != null)
                                {
                                    <td>@hhmmss(nb.AvgDelayMin)</td>
                                }
                                @if (eb != null)
                                {
                                    <td>@hhmmss(eb.AvgDelayMin)</td>
                                }
                                @if (wb != null)
                                {
                                    <td>@hhmmss(wb.AvgDelayMin)</td>
                                }
                                <td>hh:mm:ss</td>
                            </tr>
                            <tr>
                                <td>Avg Delay Length</td>
                                @if (sb != null)
                                {
                                    <td>@kmFmt(safeDouble(sb.AvgDelayLength) / 1000.0)</td>
                                }
                                @if (nb != null)
                                {
                                    <td>@kmFmt(safeDouble(nb.AvgDelayLength) / 1000.0)</td>
                                }
                                @if (eb != null)
                                {
                                    <td>@kmFmt(safeDouble(eb.AvgDelayLength) / 1000.0)</td>
                                }
                                @if (wb != null)
                                {
                                    <td>@kmFmt(safeDouble(wb.AvgDelayLength) / 1000.0)</td>
                                }
                                <td>km</td>
                            </tr>
                        </tbody>
                    </table>
                }

                @for (int idx = 0; idx < (g.Datasets?.Count ?? 0); idx++)
                {
                    var ds = g.Datasets[idx];
                    var globalIndex = $"{pg}-{idx}";

                    var info = ParseTripInfo(ds.Name);
                    var vehName = info?.vehName ?? "UnknownVehicle";
                    var tripNo = info?.tripNo ?? "0";
                    var dtToken = info?.dtToken ?? "00000000-000000";
                    var dateTok = info?.date ?? "00000000";
                    var periodTok = PeriodFolder(ds.PeakCode ?? ds.PeakLabel);
                    var dirTok = (ds.Direction ?? "UNK").Trim().ToUpperInvariant();

                    <div class="dataset-section" id="peak-@pg-ds-@idx">
                        <div class="dataset-section-header">
                            <p class="ds-title"><i class="bi bi-file-earmark-text me-2"></i>@ds.Name</p>
                            <p class="ds-meta">
                                <i class="bi bi-clock me-1"></i> Peak: <b style="color:#fff;">@ds.PeakLabel</b>
                                &nbsp;·&nbsp;
                                <i class="bi bi-arrow-left-right me-1"></i> Direction: <b style="color:#fff;">@ds.Direction</b>
                            </p>
                        </div>
                        <div class="dataset-section-body">
                            <div class="grid-two">
                                <div>
                                    <h4><i class="bi bi-graph-down me-2"></i>Travel &amp; Running Speeds</h4>
                                    <div class="chart-wrap chart-wrap-tall">
                                        <canvas id="speedChart-@globalIndex" class="trip-graph"
                                                data-date="@dateTok" data-period="@periodTok"
                                                data-trip="@tripNo" data-dt="@dtToken"
                                                data-dir="@dirTok" data-veh="@vehName"
                                                data-graph="Travel & Running Speeds"></canvas>
                                    </div>
                                </div>
                                <div>
                                    <h4><i class="bi bi-pie-chart-fill me-2"></i>Delay Cause Pie</h4>
                                    <div class="chart-wrap chart-wrap-medium">
                                        <canvas id="pieChart-@globalIndex" class="trip-graph"
                                                data-date="@dateTok" data-period="@periodTok"
                                                data-trip="@tripNo" data-dt="@dtToken"
                                                data-dir="@dirTok" data-veh="@vehName"
                                                data-graph="Delay Cause Pie"></canvas>
                                    </div>
                                    <h4 style="margin-top: 16px;"><i class="bi bi-bar-chart-fill me-2"></i>CP-to-CP Delay Bar</h4>
                                    <div class="chart-wrap chart-wrap-small">
                                        <canvas id="barChart-@globalIndex" class="trip-graph"
                                                data-date="@dateTok" data-period="@periodTok"
                                                data-trip="@tripNo" data-dt="@dtToken"
                                                data-dir="@dirTok" data-veh="@vehName"
                                                data-graph="CP-to-CP Delay Bar"></canvas>
                                    </div>
                                </div>
                            </div>

                            <h4><i class="bi bi-calculator-fill me-2"></i>Summary</h4>
                            <table class="sum-table">
                                <tbody>
                                    <tr><th>Total Travel Time (min)</th><td>@ds.Summary?.TotalTravelTimeMin</td></tr>
                                    <tr><th>Total Distance (km)</th><td>@ds.Summary?.TotalDistanceKm</td></tr>
                                    <tr><th>Avg Travel Speed</th><td>@ds.Summary?.AvgTravelSpeed</td></tr>
                                    <tr><th>Avg Running Speed</th><td>@ds.Summary?.AvgRunningSpeed</td></tr>
                                    <tr><th>Total Delay (min)</th><td>@ds.Summary?.TotalDelayMin</td></tr>
                                    <tr><th>Total Delay Length (m)</th><td>@ds.Summary?.TotalDelayLength</td></tr>
                                </tbody>
                            </table>

                            <h4><i class="bi bi-table me-2"></i>Segment Analysis</h4>
                            <table class="ttds-table">
                                <thead>
                                    <tr>
                                        <th>From</th>
                                        <th>To</th>
                                        <th>Start Time</th>
                                        <th>End Time</th>
                                        <th>Travel Time (sec)</th>
                                        <th>Distance (m)</th>
                                        <th>Travel Speed (km/h)</th>
                                        <th>Running Speed (km/h)</th>
                                        <th>Delays</th>
                                        <th>Delay Length (m)</th>
                                        <th>Delay Causes</th>
                                        <th>Note</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in (ds.Results ?? Enumerable.Empty<TtdsWeb.Models.SegmentResult>()))
                                    {
                                        <tr>
                                            <td>@r.From</td>
                                            <td>@r.To</td>
                                            <td>@r.StartTime</td>
                                            <td>@r.EndTime</td>
                                            <td>@r.TravelTimeSec</td>
                                            <td>@r.DistanceM</td>
                                            <td>@r.TravelSpeedKph</td>
                                            <td>@r.RunningSpeedKph</td>
                                            <td>@r.Delays</td>
                                            <td>@r.DelayLengthM</td>
                                            <td>@r.DelayCauses</td>
                                            <td>@r.Note</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        }
    }
    else
    {
        <div class="mt-3" style="color: #b00;">
            No PeakGroups were returned. Make sure your controller returns MultiAnalyzeViewModel.PeakGroups.
        </div>
    }

    @if (Model.PeakGroups != null && Model.PeakGroups.Any())
    {
        var peakDirMap = Model.PeakGroups
        .Where(x => x.DirectionSummaries != null && x.DirectionSummaries.Any())
        .ToDictionary(
        x => (x.PeakCode ?? x.PeakLabel ?? "UNKNOWN").ToUpperInvariant(),
        x => x.DirectionSummaries
        .GroupBy(d => (d.Direction ?? "UNKNOWN").ToUpperInvariant())
        .ToDictionary(k => k.Key, k => k.First()));

        var allDirs = peakDirMap.Values
        .SelectMany(d => d.Keys).Distinct().OrderBy(d => d).ToList();

        string dirFull(string d) => d switch
        {
            "NB" => "Northbound",
            "SB" => "Southbound",
            "EB" => "Eastbound",
            "WB" => "Westbound",
            _ => d
        };

        var peakOrder = new[] { "AM", "MID", "PM" };
        var peaksSorted = peakDirMap.Keys
        .OrderBy(k => Array.IndexOf(peakOrder, k) == -1 ? 999 : Array.IndexOf(peakOrder, k))
        .ThenBy(k => k).ToList();

        <div class="peak-section" id="dir-all-periods">
            <h2 class="peak-title">
                <i class="bi bi-signpost-split-fill me-2"></i>
                Directional Averages (Separate Table per Time Period)
            </h2>
            <div class="muted">AM / MID / PM shown separately; directions are columns.</div>

            @if (peakDirMap.Count == 0)
            {
                <div class="muted mt-2" style="color: #b00;">
                    No DirectionSummaries found.
                </div>
            }
            else
            {
                foreach (var pk in peaksSorted)
                {
                    <h3 class="mt-3"><i class="bi bi-clock-history me-2"></i>@pk</h3>
                    <table class="sum-table">
                        <thead>
                            <tr>
                                <th>Metric</th>
                                @foreach (var d in allDirs)
                                {
                                    <th>@dirFull(d)</th>
                                }
                                <th>Units</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><b>Avg Travel Time</b></td>
                                @foreach (var d in allDirs)
                                {
                                    var has = peakDirMap[pk].TryGetValue(d, out var s);
                                    <td>@(has? hhmmss(s.AvgTravelTimeMin) : "-")</td>
                                }
                                <td>hh:mm:ss</td>
                            </tr>
                            <tr>
                                <td><b>Avg Distance</b></td>
                                @foreach (var d in allDirs)
                                {
                                    var has = peakDirMap[pk].TryGetValue(d, out var s);
                                    <td>@(has? kmFmt(s.AvgDistanceKm) : "-")</td>
                                }
                                <td>km</td>
                            </tr>
                            <tr>
                                <td><b>Avg Travel Speed</b></td>
                                @foreach (var d in allDirs)
                                {
                                    var has = peakDirMap[pk].TryGetValue(d, out var s);
                                    <td>@(has? kphFmt(s.AvgTravelSpeed) : "-")</td>
                                }
                                <td>kph</td>
                            </tr>
                            <tr>
                                <td><b>Avg Running Speed</b></td>
                                @foreach (var d in allDirs)
                                {
                                    var has = peakDirMap[pk].TryGetValue(d, out var s);
                                    <td>@(has? kphFmt(s.AvgRunningSpeed) : "-")</td>
                                }
                                <td>kph</td>
                            </tr>
                            <tr>
                                <td><b>Avg Delay Time</b></td>
                                @foreach (var d in allDirs)
                                {
                                    var has = peakDirMap[pk].TryGetValue(d, out var s);
                                    <td>@(has? hhmmss(s.AvgDelayMin) : "-")</td>
                                }
                                <td>hh:mm:ss</td>
                            </tr>
                            <tr>
                                <td><b>Avg Delay Length</b></td>
                                @foreach (var d in allDirs)
                                {
                                    var has = peakDirMap[pk].TryGetValue(d, out var s);
                                    <td>@(has? kmFmt(safeDouble(s.AvgDelayLength) / 1000.0) : "-")</td>
                                }
                                <td>km</td>
                            </tr>
                        </tbody>
                    </table>
                }
            }
        </div>
    }

    <form id="exportForm" method="post" action="/export_multi_csv" style="display:none;">
        @if (Model.PeakGroups != null)
        {
            foreach (var g in Model.PeakGroups)
                foreach (var item in (g.Datasets ?? Enumerable.Empty<dynamic>()))
                {
                    <input type="hidden" name="selected_files" value="@item.Id" />
                }
        }
    </form>
    <form id="allZipForm" method="post" action="/export_all_zip" style="display:none;">
        <input type="hidden" name="region" id="allZipRegion" />
        <input type="hidden" name="roadNameOrSections" id="allZipRoad" />
        @if (Model.PeakGroups != null)
        {
            foreach (var g in Model.PeakGroups)
                foreach (var ds in (g.Datasets ?? Enumerable.Empty<dynamic>()))
                {
                    <input type="hidden" name="selected_files" value="@ds.Id" />
                }
        }
    </form>
    <form id="dirZipForm" style="display:none;"><input type="hidden" name="region" id="dirZipRegion" /><input type="hidden" name="roadNameOrSections" id="dirZipRoad" /></form>
    <form id="segZipForm" style="display:none;"><input type="hidden" name="region" id="segZipRegion" /><input type="hidden" name="roadNameOrSections" id="segZipRoad" /></form>
    <form id="shapesZipForm" style="display:none;"><input type="hidden" name="region" id="shapesZipRegion" /><input type="hidden" name="roadNameOrSections" id="shapesZipRoad" /></form>

</div><!-- /content wrapper -->
<div class="action-bar">
    <button type="button" id="btnDownloadAllWithGraphsBar" class="btn-ttds w-auto px-4">
        <i class="bi bi-download"></i> Download ALL (Tables + Shapes + Graphs)
    </button>
    <a href="/report" class="btn-ttds w-auto px-4" style="background: var(--color-accent); text-decoration: none;">
        Next: Generate Report <i class="bi bi-arrow-right ms-1"></i>
    </a>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.3/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>

    <script>
        // ── White background plugin for Chart.js export ──
        Chart.register({
            id: 'whiteBackground',
            beforeDraw(chart) {
                const ctx = chart.canvas.getContext('2d');
                ctx.save();
                ctx.globalCompositeOperation = 'destination-over';
                ctx.fillStyle = '#ffffff';
                ctx.fillRect(0, 0, chart.width, chart.height);
                ctx.restore();
            }
        });

        // ── Server data ──
        const cpData     = @Html.Raw(JsonSerializer.Serialize(Model.CpData, jsonOpts));
        const peakGroups = @Html.Raw(JsonSerializer.Serialize(Model.PeakGroups, jsonOpts));
        const datasets   = (peakGroups || []).flatMap(g => g?.datasets || []);
        const roadsByRegionJs = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(roadsByRegion));

        // ── Helpers ──
        function safePart(s) {
            return (s || '').toString().trim()
                .replace(/[\\/:*?"<>|]/g, '-')
                .replace(/\s+/g, '_');
        }

        function safeNum(v) {
            if (v === null || v === undefined) return 0;
            if (typeof v !== 'number') v = Number(v);
            return isFinite(v) ? v : 0;
        }

        function getFilters() {
            return {
                reg:    document.getElementById('regionSelect')?.value  || 'UnknownRegion',
                road:   document.getElementById('roadSelect')?.value    || 'UnknownRoad',
                period: document.getElementById('periodSelect')?.value  || 'ALL'
            };
        }

        function wireForm(formId, regionHiddenId, roadHiddenId) {
            const f = document.getElementById(formId);
            if (!f) return;
            f.addEventListener('submit', () => {
                const { reg, road } = getFilters();
                const r  = document.getElementById(regionHiddenId);
                const rd = document.getElementById(roadHiddenId);
                if (r)  r.value  = reg;
                if (rd) rd.value = road;
            });
        }

        wireForm('dirZipForm',    'dirZipRegion',    'dirZipRoad');
        wireForm('segZipForm',    'segZipRegion',    'segZipRoad');
        wireForm('shapesZipForm', 'shapesZipRegion', 'shapesZipRoad');
        wireForm('allZipForm',    'allZipRegion',    'allZipRoad');

        // ── Region → Road cascade ──
        document.getElementById('regionSelect')?.addEventListener('change', function () {
            const roads   = roadsByRegionJs[this.value] || [];
            const roadSel = document.getElementById('roadSelect');
            roadSel.innerHTML = '';
            roads.forEach(rd => {
                const opt = document.createElement('option');
                opt.value = rd; opt.textContent = rd;
                roadSel.appendChild(opt);
            });
        });

        // ── Map ──
        const map = L.map('map');
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 18 }).addTo(map);
        const bounds = L.latLngBounds();

        (cpData || []).forEach(cp => {
            if (cp?.lat == null || cp?.lon == null) return;
            const m = L.circleMarker([cp.lat, cp.lon], { radius: 1, fillColor: 'gray', fillOpacity: 1 }).addTo(map);
            m.bindTooltip(`CP: ${cp.cp_id}`, { permanent: true, direction: 'right', offset: [8, 0], className: 'cp-label' });
            bounds.extend([cp.lat, cp.lon]);
        });

        const DS_COLORS = ["#1f77b4","#ff7f0e","#2ca02c","#d62728","#9467bd","#8c564b","#e377c2","#7f7f7f","#bcbd22","#17becf"];
        const dsLayers  = {};
        const dsListDiv = document.getElementById('ds-list');

        (datasets || []).forEach((ds, i) => {
            const id = ds?.id || `ds-${i}`;

            const wrap = document.createElement('div'); wrap.className = 'ds-row';
            const cb   = document.createElement('input');
            cb.type = 'checkbox'; cb.checked = true;
            cb.id = 'ds-toggle-' + i; cb.dataset.id = id;

            const lbl = document.createElement('label');
            lbl.htmlFor     = cb.id;
            lbl.textContent = ` ${ds?.name || ('Dataset ' + (i + 1))} (${ds?.peakLabel || 'Off-Peak'})`;

            wrap.appendChild(cb); wrap.appendChild(lbl);
            dsListDiv.appendChild(wrap);

            const g = L.layerGroup().addTo(map);
            dsLayers[id] = g;

            (ds?.segments || []).forEach(seg => {
                if (!seg?.path || seg.path.length < 2) return;
                const color   = seg.color || DS_COLORS[i % DS_COLORS.length];
                const latlngs = seg.path.map(p => [p[0], p[1]]);
                latlngs.forEach(ll => bounds.extend(ll));
                L.polyline(latlngs, { color, weight: 5, opacity: 0.9 })
                    .bindPopup(`<b>${seg.fromCp ?? ''} → ${seg.toCp ?? ''}</b><br>
                                Direction: ${seg.direction ?? 'N/A'}<br>
                                Speed: ${seg.speed ?? 'N/A'} km/h<br>
                                Cause: ${seg.cause ?? 'None'}<br>
                                Status: ${seg.status ?? 'Unknown'}`)
                    .addTo(g);
            });

            cb.addEventListener('change', ev => {
                const layer = dsLayers[ev.target.dataset.id];
                if (!layer) return;
                if (ev.target.checked) layer.addTo(map); else map.removeLayer(layer);
            });
        });

        if (bounds.isValid()) map.fitBounds(bounds.pad(0.10));
        else map.setView([14.6, 121.0], 12);

        // ── Charts ──
        const CAUSE_MAP = {
            "Loading and Unloading": { color: "blue" },
            "Intersection":          { color: "orange" },
            "Traffic Light":         { color: "red" },
            "Pedestrian Crossing":   { color: "purple" },
            "Animal Crossing":       { color: "brown" },
            "Vehicle Crossing":      { color: "maroon" },
            "Road Construction":     { color: "gray" },
            "Blocked by Vehicle":    { color: "black" },
            "Others":                { color: "pink" }
        };

        function buildStepSeries(rows, speedKey) {
            const pts = [];
            let km = 0, prevY = null;
            rows.forEach(r => {
                const d_m  = safeNum(r["Distance (m)"]);
                const y    = safeNum(r[speedKey]);
                if (!isFinite(d_m) || d_m <= 0) return;
                const nextKm = km + d_m / 1000;
                if (isFinite(y)) {
                    if (prevY == null)           pts.push({ x: km, y });
                    else if (y !== prevY) { pts.push({ x: km, y: prevY }); pts.push({ x: km, y }); }
                    pts.push({ x: nextKm, y });
                    prevY = y;
                }
                km = nextKm;
            });
            return pts;
        }

        (peakGroups || []).forEach((pg, pgIndex) => {
            (pg?.datasets || []).forEach((ds, dsIndex) => {
                const key    = `${pgIndex}-${dsIndex}`;
                const pieCtx = document.getElementById('pieChart-'   + key)?.getContext('2d');
                const barCtx = document.getElementById('barChart-'   + key)?.getContext('2d');
                const spdCtx = document.getElementById('speedChart-' + key)?.getContext('2d');
                if (!pieCtx || !barCtx || !spdCtx) return;

                const results = ds?.results || [];
                const resLite = results.map(r => ({
                    "From":                  r.from         ?? '',
                    "To":                    r.to           ?? '',
                    "Distance (m)":          safeNum(r.distanceM),
                    "Travel Speed (km/h)":   safeNum(r.travelSpeedKph),
                    "Running Speed (km/h)":  safeNum(r.runningSpeedKph),
                    "Delays":                safeNum(r.delays),
                    "Delay Length (m)":      safeNum(r.delayLengthM),
                    "Delay Causes":          r.delayCauses  ?? ''
                }));

                const delayCauseCounts = {};
                const delayCPCounts    = {};

                resLite.forEach(row => {
                    const cpPair = `${row['From']} - ${row['To']}`;
                    const causes = (row['Delay Causes'] || '').split(',').map(s => s.trim()).filter(Boolean);
                    if (!causes.length) return;
                    causes.forEach(c => { delayCauseCounts[c] = (delayCauseCounts[c] || 0) + 1; });
                    if (!delayCPCounts[cpPair]) delayCPCounts[cpPair] = {};
                    causes.forEach(c => { delayCPCounts[cpPair][c] = (delayCPCounts[cpPair][c] || 0) + 1; });
                });

                // Pie
                const pieLabels = Object.keys(delayCauseCounts);
                new Chart(pieCtx, {
                    type: 'pie',
                    data: {
                        labels: pieLabels,
                        datasets: [{
                            data:            pieLabels.map(l => delayCauseCounts[l]),
                            backgroundColor: pieLabels.map(l => CAUSE_MAP[l]?.color || 'gray')
                        }]
                    },
                    options: {
                        maintainAspectRatio: false,
                        plugins: {
                            title: { display: true, text: 'Delay Causes' },
                            datalabels: {
                                formatter: (value, ctx) => {
                                    const total = ctx.chart.data.datasets[0].data.reduce((s, v) => s + v, 0);
                                    const pct   = total ? ((value / total) * 100).toFixed(1) : 0;
                                    return `${ctx.chart.data.labels[ctx.dataIndex]}\n${pct}%`;
                                },
                                color: '#fff', font: { weight: 'bold', size: 10 }, align: 'center'
                            }
                        }
                    },
                    plugins: [ChartDataLabels]
                });

                // Stacked Bar
                const pieOrder       = Object.entries(delayCauseCounts).sort((a, b) => b[1] - a[1]).map(e => e[0]);
                const detectedCauses = pieOrder.filter(c => delayCauseCounts[c] > 0);
                let stackedLabels    = Object.keys(delayCPCounts);
                const totalsPerPair  = Object.fromEntries(
                    stackedLabels.map(l => [l, Object.values(delayCPCounts[l] || {}).reduce((s, v) => s + v, 0)])
                );
                stackedLabels.sort((a, b) => (totalsPerPair[b] || 0) - (totalsPerPair[a] || 0));

                new Chart(barCtx, {
                    type: 'bar',
                    data: {
                        labels:   stackedLabels,
                        datasets: detectedCauses.map(cause => ({
                            label:           cause,
                            backgroundColor: CAUSE_MAP[cause]?.color || 'gray',
                            data:            stackedLabels.map(l => delayCPCounts[l]?.[cause] || 0),
                            stack:           'causes'
                        }))
                    },
                    options: {
                        plugins: {
                            title: { display: true, text: 'Delays per CP Segment (Stacked by Cause)' },
                            legend: {
                                position: 'bottom',
                                labels: {
                                    boxWidth: 14, font: { size: 11 },
                                    filter: (item, data) => data.datasets[item.datasetIndex].data.some(v => v > 0)
                                }
                            }
                        },
                        responsive: true, maintainAspectRatio: false,
                        scales: {
                            x: { stacked: true, ticks: { font: { size: 10 }, maxRotation: 45, minRotation: 30 } },
                            y: { stacked: true, beginAtZero: true, ticks: { font: { size: 11 } } }
                        },
                        layout: { padding: { bottom: 12 } }
                    }
                });

                // Speed line
                const travelStep  = buildStepSeries(resLite, "Travel Speed (km/h)");
                const runningStep = buildStepSeries(resLite, "Running Speed (km/h)");
                const maxKm       = Math.ceil(resLite.reduce((s, r) => s + safeNum(r["Distance (m)"]), 0) / 1000);

                new Chart(spdCtx, {
                    type: 'line',
                    data: {
                        datasets: [
                            { label: "Travel Speed (KPH)",  data: travelStep,  parsing: false, fill: false, borderWidth: 2, pointRadius: 3, tension: 0 },
                            { label: "Running Speed (KPH)", data: runningStep, parsing: false, fill: false, borderWidth: 2, pointRadius: 3, tension: 0 }
                        ]
                    },
                    options: {
                        responsive: true, maintainAspectRatio: false,
                        plugins: {
                            title:  { display: true, text: "Travel Speed and Running Speed Comparison" },
                            legend: { position: 'top' }
                        },
                        scales: {
                            x: { type: 'linear', title: { display: true, text: "Distance (km)" }, ticks: { stepSize: 1, callback: v => Math.round(v) }, min: 0, max: maxKm || 1 },
                            y: { title: { display: true, text: "Speed (km/h)" }, beginAtZero: true }
                        }
                    }
                });
            });
        });

        // ── Accordion ──
        document.querySelectorAll('.dataset-section').forEach(section => {
            section.classList.add('collapsed');
            const header  = section.querySelector('.dataset-section-header');
            const chevron = document.createElement('i');
            chevron.className = 'bi bi-chevron-down';
            chevron.style.cssText = 'position:absolute; right:20px; top:50%; transform:translateY(-50%) rotate(0deg); color:var(--color-accent); font-size:1rem; transition:transform 0.2s;';
            header.appendChild(chevron);
            header.addEventListener('click', () => {
                section.classList.toggle('collapsed');
                chevron.style.transform = section.classList.contains('collapsed')
                    ? 'translateY(-50%) rotate(0deg)'
                    : 'translateY(-50%) rotate(180deg)';
            });
        });

        // ── Graph collection ──
        function collectGraphs(reg, road) {
            return Array.from(document.querySelectorAll('canvas.trip-graph')).map(c => ({
                folder:   `${safePart(reg)}/${safePart(road)}/${safePart(c.dataset.date || '00000000')}/${safePart(c.dataset.veh || 'UnknownVehicle')}/Graphs/${safePart(c.dataset.period || 'OFF')}`,
                fileName: `Trip-${safePart(c.dataset.trip || '0')}_${safePart(c.dataset.dt || '00000000-000000')}_${safePart(c.dataset.dir || 'UNK')}_${safePart(c.dataset.graph || c.id)}.jpg`,
                dataUrl:  c.toDataURL('image/jpeg', 0.92)
            }));
        }

        // ── Download ALL ──
        async function doDownloadAll() {
            const { reg, road } = getFilters();
            const selectedIds   = Array.from(document.querySelectorAll('input[name="selected_files"]')).map(x => x.value);

            try {
                const res = await fetch('/export_all_with_graphs_zip', {
                    method:  'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify({ region: reg, roadNameOrSections: road, selectedIds, graphs: collectGraphs(reg, road) })
                });

                if (!res.ok) { alert('Download failed: ' + await res.text()); return; }

                const url = URL.createObjectURL(await res.blob());
                const a   = document.createElement('a');
                a.href = url; a.download = `${safePart(reg)}_${safePart(road)}.zip`;
                document.body.appendChild(a); a.click(); a.remove();
                URL.revokeObjectURL(url);
            } catch (err) {
                alert('Download error: ' + err.message);
            }
        }

        document.getElementById('btnDownloadAllWithGraphsBar')?.addEventListener('click', doDownloadAll);

        // ── Download Graphs only ──
        document.getElementById('btnDownloadGraphs')?.addEventListener('click', async () => {
            const { reg, road } = getFilters();
            try {
                const res = await fetch('/export_graphs_zip', {
                    method:  'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify({ region: reg, roadNameOrSections: road, items: collectGraphs(reg, road) })
                });
                if (!res.ok) { alert('Graphs download failed: ' + await res.text()); return; }
                const url = URL.createObjectURL(await res.blob());
                const a   = document.createElement('a');
                a.href = url; a.download = `GRAPHS_${safePart(reg)}_${safePart(road)}.zip`;
                document.body.appendChild(a); a.click(); a.remove();
                URL.revokeObjectURL(url);
            } catch (err) {
                alert('Graphs error: ' + err.message);
            }
        });
    </script>
}