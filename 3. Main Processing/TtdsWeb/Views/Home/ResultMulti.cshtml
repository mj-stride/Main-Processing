<body>

    <div style="position:sticky; top:0; z-index:999; background:#211d70; color:#eeeeee; font-size:0.95rem; font-weight:600; padding:14px 32px; letter-spacing:0.01em; display:flex; justify-content:space-between; align-items:center;">
        <span>TTDS – Multi Dataset Analysis</span>
        <a href="/dashboard" style="display:inline-flex; align-items:center; gap:8px; padding:8px 20px; border:none; border-radius:8px; background:#da471f; color:#eeeeee; font-size:0.85rem; font-weight:600; text-decoration:none; transition:background 0.18s;"
           onmouseover="this.style.background='#c23d19'"
           onmouseout="this.style.background='#da471f'">
            <i class="bi bi-columns-gap"></i> Dashboard
        </a>
    </div>

    <div style="max-width:1400px; margin:0 auto; padding:1.5rem 1.5rem 6rem;">

        <div style="display:flex; justify-content:space-between; align-items:center; margin:0 0 1rem;">
            <h2 style="font-size:1.5rem; font-weight:700; margin:0; color:#1d4470;">
                <i class="bi bi-map me-2" style="color:#da471f;"></i> Multi Dataset Travel Time & Delay Analysis
            </h2>
            <a href="/" style="display:inline-flex; align-items:center; gap:8px; padding:8px 20px; border:2px solid #1d4470; border-radius:999px; color:#1d4470; font-size:0.85rem; font-weight:600; text-decoration:none; background:transparent; transition:background 0.18s, color 0.18s;"
               onmouseover="this.style.background='#1d4470'; this.style.color='#ffffff'"
               onmouseout="this.style.background='transparent'; this.style.color='#1d4470'">
                <i class="bi bi-arrow-left"></i> Back to Upload
            </a>
        </div>

    @{
        var regions = Model.RegionList ?? new List<string>();
        var roadsByRegion = Model.RoadsByRegion ?? new Dictionary<string, List<string>>();

        var defaultRegion = Model.SelectedRegion ?? regions.FirstOrDefault() ?? "";
        var defaultRoad = Model.SelectedRoad
        ?? (roadsByRegion.ContainsKey(defaultRegion) ? roadsByRegion[defaultRegion].FirstOrDefault() : "")
        ?? "";
    }

    @* FILTERS (used for ZIP folder naming) *@
        <div class="filter-box" style="background:#ffffff; border:1px solid #ccc; border-radius:16px; box-shadow:0 2px 12px rgba(0,0,0,0.08); padding:1.25rem; margin:0 0 1rem;">
            <h4 style="margin:0 0 10px 0; color:#1d4470; font-size:0.95rem; font-weight:700;">
                <i class="bi bi-funnel me-1"></i> Preview Filters
            </h4>

            <div style="display:flex; align-items:center; gap:16px; flex-wrap:wrap;">

                <label style="font-weight:700; white-space:nowrap;">Region:</label>
                <select id="regionSelect" name="region" form="exportForm" style="width:160px; padding:6px 10px; border-radius:8px; border:1px solid #ccc; font-size:0.88rem;">
                    @foreach (var r in regions)
                    {
                        <option value="@r" selected="@(r == defaultRegion)">@r</option>
                    }
                </select>

                <label style="font-weight:700; white-space:nowrap;">Road / Section:</label>
                <select id="roadSelect" name="roadNameOrSections" form="exportForm" style="width:280px; padding:6px 10px; border-radius:8px; border:1px solid #ccc; font-size:0.88rem;">
                @if (!string.IsNullOrWhiteSpace(defaultRegion) && roadsByRegion.ContainsKey(defaultRegion))
                {
                    foreach (var rd in roadsByRegion[defaultRegion])
                    {
                        <option value="@rd" selected="@(rd == defaultRoad)">@rd</option>
                    }
                }
            </select>

            <script>
                // Bake the full roads map into JS so region change updates road dropdown instantly
                const roadsByRegion = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(roadsByRegion));

                document.getElementById('regionSelect')?.addEventListener('change', function () {
                    const region = this.value;
                    const roads = roadsByRegion[region] || [];
                    const roadSel = document.getElementById('roadSelect');
                    roadSel.innerHTML = '';
                    roads.forEach(rd => {
                        const opt = document.createElement('option');
                        opt.value = rd;
                        opt.textContent = rd;
                        roadSel.appendChild(opt);
                    });
                });
            </script>

                <label style="font-weight:700; white-space:nowrap;">Period:</label>
                <select id="periodSelect" name="period" form="exportForm" style="width:100px; padding:6px 10px; border-radius:8px; border:1px solid #ccc; font-size:0.88rem;">
                    <option value="ALL">ALL</option>
                    <option value="AM">AM</option>
                    <option value="MID">MID</option>
                    <option value="PM">PM</option>
                </select>

            </div>
            <div class="muted" style="margin-top:8px;">These values will be used for the ZIP folder naming.</div>
    </div>

    <div id="top-wrap">
        <div><div id="map"></div></div>

        <div id="ds-toggle">
            <h4 style="margin-top:0">Datasets on map</h4>
            <div id="ds-list"></div>
            <div class="muted">Tip: toggle datasets to hide/show on map.</div>
        </div>
    </div>

    @* =========================
       PER-PEAK RENDERING
       ========================= *@

    @if (Model.PeakGroups != null && Model.PeakGroups.Any())
    {
        for (int pg = 0; pg < Model.PeakGroups.Count; pg++)
        {
            var g = Model.PeakGroups[pg];

            <div class="peak-section" id="peak-@pg">
                    <h2 class="peak-title">
                        <i class="bi bi-map me-2"></i>
                        Map for @g.PeakLabel
                    </h2>
                    <div class="muted">
                        <i class="bi bi-clock-history me-1"></i>
                        @g.PeakLabel (@g.PeakCode)
                    </div>

                @* Overall Summary *@
                @if (g.OverallSummary != null)
                {
                        <h2>
                            <i class="bi bi-pin-angle-fill me-2"></i>
                            Overall Summary (This Peak Period)
                        </h2>
                    <table class="sum-table">
                        <tbody>
                            <tr><th>Avg Travel Time (min)</th><td>@g.OverallSummary.TotalTravelTimeMin</td></tr>
                            <tr><th>Avg Distance (km)</th><td>@g.OverallSummary.TotalDistanceKm</td></tr>
                            <tr><th>Avg Travel Speed</th><td>@g.OverallSummary.AvgTravelSpeed</td></tr>
                            <tr><th>Avg Running Speed</th><td>@g.OverallSummary.AvgRunningSpeed</td></tr>
                            <tr><th>Avg Delay (min)</th><td>@g.OverallSummary.TotalDelayMin</td></tr>
                            <tr><th>Avg Delay Length (m)</th><td>@g.OverallSummary.TotalDelayLength</td></tr>
                        </tbody>
                    </table>
                }

                @* Directional Averages (per peak) *@
                @if (g.DirectionSummaries != null && g.DirectionSummaries.Any())
                {
                    var dirDict = g.DirectionSummaries
                    .GroupBy(d => (d.Direction ?? "Unknown").ToUpperInvariant())
                    .ToDictionary(x => x.Key, x => x.First());

                    var sb = dirDict.ContainsKey("SB") ? dirDict["SB"] : null;
                    var nb = dirDict.ContainsKey("NB") ? dirDict["NB"] : null;
                    var eb = dirDict.ContainsKey("EB") ? dirDict["EB"] : null;
                    var wb = dirDict.ContainsKey("WB") ? dirDict["WB"] : null;

                        <h2>
                            <i class="bi bi-signpost-split-fill me-2"></i>
                            Directional Averages (This Peak Period)
                        </h2>

                    <table class="sum-table">
                        <thead>
                            <tr>
                                <th></th>
                                @if (sb != null)
                                {
                                    <th>Southbound</th>
                                }
                                @if (nb != null)
                                {
                                    <th>Northbound</th>
                                }
                                @if (eb != null)
                                {
                                    <th>Eastbound</th>
                                }
                                @if (wb != null)
                                {
                                    <th>Westbound</th>
                                }
                                <th>Units</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Avg Travel Time</td>
                                @if (sb != null)
                                {
                                    <td>@hhmmss(sb.AvgTravelTimeMin)</td>
                                }
                                @if (nb != null)
                                {
                                    <td>@hhmmss(nb.AvgTravelTimeMin)</td>
                                }
                                @if (eb != null)
                                {
                                    <td>@hhmmss(eb.AvgTravelTimeMin)</td>
                                }
                                @if (wb != null)
                                {
                                    <td>@hhmmss(wb.AvgTravelTimeMin)</td>
                                }
                                <td>hh:mm:ss</td>
                            </tr>
                            <tr>
                                <td>Avg Distance</td>
                                @if (sb != null)
                                {
                                    <td>@kmFmt(sb.AvgDistanceKm)</td>
                                }
                                @if (nb != null)
                                {
                                    <td>@kmFmt(nb.AvgDistanceKm)</td>
                                }
                                @if (eb != null)
                                {
                                    <td>@kmFmt(eb.AvgDistanceKm)</td>
                                }
                                @if (wb != null)
                                {
