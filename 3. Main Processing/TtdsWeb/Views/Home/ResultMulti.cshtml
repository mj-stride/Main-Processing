    <script>
        function safePart(s) {
          return (s || '')
            .toString()
            .trim()
            .replace(/[\\/:*?"<>|]/g, '-')   // windows-invalid chars
            .replace(/\s+/g, '_');
        }

        function canvasToJpegDataUrl(canvas) {
          // JPEG keeps size smaller; plugin already paints white bg
          return canvas.toDataURL("image/jpeg", 0.92);
        }

                function collectGraphs(region, road) {
          const nodes = Array.from(document.querySelectorAll('canvas.trip-graph'));
          const items = [];

          for (const c of nodes) {
            const date = safePart(c.dataset.date || '00000000');
            const period = safePart(c.dataset.period || 'OFF');
            const trip = safePart(c.dataset.trip || '0');
            const dt = safePart(c.dataset.dt || '00000000-000000');
            const dir = safePart(c.dataset.dir || 'UNK');
            const veh = safePart(c.dataset.veh || 'UnknownVehicle');

            const graphName = safePart(c.dataset.graph || c.id || 'Graph');

            // ✅ FIXED (no double Graphs)
            const folder = `${safePart(region)}/${safePart(road)}/${date}/${veh}/Graphs/${period}`;

            const fileName = `Trip-${trip}_${dt}_${dir}_${graphName}.jpg`;

            items.push({ folder, fileName, dataUrl: canvasToJpegDataUrl(c) });
          }

          return items;
        }

    </script>
    <script>
                document.getElementById("btnDownloadGraphs")?.addEventListener("click", async () => {
          const { reg, road } = getFilters();
          const items = collectGraphs(reg, road);

          const res = await fetch("/export_graphs_zip", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              region: reg,
              roadNameOrSections: road,
              items // ✅ MUST be 'items'
            })
          });

          if (!res.ok) { alert("Graphs download failed: " + await res.text()); return; }

          const blob = await res.blob();
          const url = URL.createObjectURL(blob);

          const a = document.createElement("a");
          a.href = url;
          a.download = `GRAPHS_${safePart(reg)}_${safePart(road)}.zip`;
          document.body.appendChild(a);
          a.click();
          a.remove();
          URL.revokeObjectURL(url);
        });
    </script>

    <script>
                document.getElementById("btnDownloadAllWithGraphs")?.addEventListener("click", async () => {
          const { reg, road } = getFilters();

          const selectedIds = Array.from(document.querySelectorAll('input[name="selected_files"]'))
            .map(x => x.value);

          const graphs = collectGraphs(reg, road);

          const payload = {
            region: reg,
            roadNameOrSections: road,
            selectedIds,
            graphs
          };

          const res = await fetch("/export_all_with_graphs_zip", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });

          if (!res.ok) { alert("ALL download failed: " + await res.text()); return; }

          const blob = await res.blob();
          const url = URL.createObjectURL(blob);

          const a = document.createElement("a");
          a.href = url;
          a.download = `${safePart(reg)}_${safePart(road)}.zip`;
          document.body.appendChild(a);
          a.click();
          a.remove();
          URL.revokeObjectURL(url);
        });

    </script>
        <script>
            document.querySelectorAll(".dataset-section").forEach(section => {
                        section.classList.add("collapsed");

                        // inject chevron icon into header
                        const header = section.querySelector(".dataset-section-header");
                        const chevron = document.createElement("i");
                        chevron.className = "bi bi-chevron-down";
                        chevron.style.cssText = "position:absolute; right:20px; top:50%; transform:translateY(-50%); color:#da471f; font-size:1rem; transition:transform 0.2s;";
                        header.appendChild(chevron);

                        header.addEventListener("click", () => {
                            section.classList.toggle("collapsed");
                            const isCollapsed = section.classList.contains("collapsed");
                            chevron.style.transform = isCollapsed
                                ? "translateY(-50%) rotate(0deg)"
                                : "translateY(-50%) rotate(180deg)";
                        });

                        // set initial state
                        chevron.style.transform = "translateY(-50%) rotate(0deg)";
                    });
        </script>
