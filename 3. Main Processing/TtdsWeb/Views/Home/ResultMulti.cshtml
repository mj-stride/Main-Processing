@model TtdsWeb.Models.MultiAnalyzeViewModel
@using System.Text.Json
@using System.Text.Json.Serialization
@using System.Linq

@{
    var jsonOpts = new JsonSerializerOptions
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        NumberHandling = JsonNumberHandling.AllowNamedFloatingPointLiterals,
        DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull
    };

    // Helpers (nullable-safe)
    string hhmmss(double? minutes) => TimeSpan.FromMinutes(minutes ?? 0).ToString(@"hh\:mm\:ss");
    string kmFmt(double? v) => (v ?? 0).ToString("0.##");
    string kphFmt(double? v) => (v ?? 0).ToString("0.##");

    // Safe numeric conversion (works for double / double? / int / etc.)
    double safeDouble(object? v)
    {
        if (v == null) return 0;
        if (v is double d) return d;
        if (v is float f) return f;
        if (v is int i) return i;
        if (v is long l) return l;
        if (double.TryParse(v.ToString(), out var x)) return x;
        return 0;
    }
}
@functions {
    // Extracts: tripNo and dtToken from "...-<tripNo>_YYYYMMDD-HHMMSS_..."
    // Example: GPX_1_...-3_20250716-180525_snapped.csv  -> tripNo=3, dtToken=20250716-180525, date=20250716
    (string vehCode, string vehName, string tripNo, string dtToken, string date)? ParseTripInfo(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return null;

        // 1 = Private Car, 2 = UV, 3 = Jeepney, 4 = BUS
        var mv = System.Text.RegularExpressions.Regex.Match(
            name,
            @"\bGPX_(\d+)_",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase
        );

        var vehCode = mv.Success ? mv.Groups[1].Value : "0";
        var vehName = vehCode switch
        {
            "1" => "PrivateCar",
            "2" => "UV",
            "3" => "Jeepney",
            "4" => "BUS",
            _ => "UnknownVehicle"
        };

        var m = System.Text.RegularExpressions.Regex.Match(
            name,
            @"-(\d+)_((\d{8})-(\d{6}))",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase
        );

        if (!m.Success)
            return (vehCode, vehName, "0", "00000000-000000", "00000000");

        var tripNo = m.Groups[1].Value;
        var dtToken = m.Groups[2].Value;
        var date = m.Groups[3].Value;

        return (vehCode, vehName, tripNo, dtToken, date);
    }


    string PeriodFolder(string? peakCodeOrLabel)
    {
        var p = (peakCodeOrLabel ?? "").ToUpperInvariant();
        if (p.Contains("AM")) return "AM";
        if (p.Contains("MID")) return "MID";
        if (p.Contains("PM")) return "PM";
        return "OFF";
    }
}


<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Multi Dataset Analysis</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.3/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.3/dist/leaflet.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <script>
        // Force white background for all Chart.js canvases (screen + export)
        Chart.register({
          id: 'whiteBackground',
          beforeDraw(chart) {
            const ctx = chart.canvas.getContext('2d');
            ctx.save();
            ctx.globalCompositeOperation = 'destination-over';
            ctx.fillStyle = '#ffffff';
            ctx.fillRect(0, 0, chart.width, chart.height);
            ctx.restore();
          }
        });

        // When the ALL zip form is submitted (if you still keep it)
        (function () {
          const f = document.getElementById('allZipForm');
          if (!f) return;

          f.addEventListener('submit', function () {
            const r = document.getElementById('regionSelect');
            const rd = document.getElementById('roadSelect');

            const reg = r?.value || 'UnknownRegion';
            const road = rd?.value || 'UnknownRoad';  

            document.getElementById('allZipRegion').value = reg;
            document.getElementById('allZipRoad').value = road;
          });
        })();
    </script>

    <script>
        function dataUrlFromCanvas(canvas) {
          try {
            // PNG is safest for charts
            return canvas.toDataURL("image/png");
          } catch (e) {
            return null;
          }
        }

        function getSelectedDatasetIds() {
          // adjust selector to match your checkbox names
          return Array.from(document.querySelectorAll('input[name="selected_files"]:checked'))
            .map(x => x.value);
        }

        function buildGraphsPayload(region, road) {
          // IMPORTANT: add data-export-name to each canvas you want exported
          const canvases = Array.from(document.querySelectorAll("canvas[data-export-name]"));

          const graphs = canvases.map(c => {
            const fileName = c.getAttribute("data-export-name") || "graph.png";
            const folder = `${safePart(region)}/${safePart(road)}/${date}/${veh}/Graphs/${period}`;


            return {
              folder,
              fileName: fileName.toLowerCase().endsWith(".png") ? fileName : (fileName + ".png"),
              dataUrl: dataUrlFromCanvas(c)
            };
          }).filter(g => g.dataUrl);

          return graphs;
        }

        async function exportAllWithGraphs() {
          // read the same UI controls used on MapMulti
          const region = (document.querySelector("#regionSel")?.value || "UnknownRegion").trim();

          // for roads use the multi-select so server receives the selected roads (comma-joined)
          const roadSel = document.querySelector("#roadSel");
          const roadArr = Array.from((roadSel?.selectedOptions || [])).map(o => o.value).filter(Boolean);
          const road = (roadArr.length ? roadArr.join(',') : "UnknownRoad").trim();

          const payload = {
            region,
            roadNameOrSections: road,
            selectedIds: getSelectedDatasetIds(),
            graphs: buildGraphsPayload(region, road)
          };

          const res = await fetch("/export_all_with_graphs_zip", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });

          if (!res.ok) {
            const msg = await res.text();
            alert("Export failed: " + msg);
            return;
          }

          const blob = await res.blob();
          const url = window.URL.createObjectURL(blob);

          const a = document.createElement("a");
          a.href = url;
          a.download = `${region}_${road}.zip`;
          document.body.appendChild(a);
          a.click();
          a.remove();

          window.URL.revokeObjectURL(url);
        }

        document.getElementById("btnExportAllWithGraphs")
          ?.addEventListener("click", exportAllWithGraphs);
    </script>

    <script>
        function getFilters() {
          const reg = document.getElementById('regionSelect')?.value || 'UnknownRegion';
          const road = document.getElementById('roadSelect')?.value || 'UnknownRoad';
          const period = document.getElementById('periodSelect')?.value || 'ALL';
          return { reg, road, period };
        }

        function wireForm(formId, regionHiddenId, roadHiddenId) {
          const f = document.getElementById(formId);
          if (!f) return;

          f.addEventListener('submit', function () {
            const { reg, road } = getFilters();
            const r = document.getElementById(regionHiddenId);
            const rd = document.getElementById(roadHiddenId);
            if (r) r.value = reg;
            if (rd) rd.value = road;
          });
        }

        // wire the existing POST forms (IDs unchanged)
        wireForm('dirZipForm', 'dirZipRegion', 'dirZipRoad');
        wireForm('segZipForm', 'segZipRegion', 'segZipRoad');
        wireForm('shapesZipForm', 'shapesZipRegion', 'shapesZipRoad');
        wireForm('allZipForm', 'allZipRegion', 'allZipRoad');
    </script>

